@namespace TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Core
@using Microsoft.AspNetCore.Components.Forms

@* Presentational form for blog-post create/edit. No @inject — all I/O lives in BlogPostEditorPage.
   Contract:
     - ViewModel carries field values + validation errors (set by the page).
     - OnValidSubmit fires when EditForm validation passes; the page then calls GetContentAsync()
       before mapping to the write DTO.
     - AuthorStories populates the optional story-link picker. Pass an empty list on create if
       the author has no published stories. Null = suppress the picker entirely.
   Mirrors StoryPropertiesForm (no tags, no cover). *@

<InlineAlert Messages="@ViewModel.ServerValidationErrors" />

<EditForm Model="@ViewModel" OnValidSubmit="HandleValidSubmit" FormName="blog-post-properties-form"
          class="flex flex-col gap-6">
    <DataAnnotationsValidator />

    @* ── Title ───────────────────────────────────────────────────────────────── *@
    <div class="flex flex-col gap-1">
        <label class="text-sm font-semibold text-(--color-text)">Title</label>
        <InputText @bind-Value="ViewModel.Title"
                   class="rounded-md border border-(--color-border) bg-(--color-surface) px-3 py-2 text-(--color-text) focus:outline-none focus:ring-2 focus:ring-(--color-action-ink)"
                   placeholder="Post title" />
        <ValidationMessage For="@(() => ViewModel.Title)" class="text-sm text-(--color-danger)" />
    </div>

    @* ── Content (rich text) ──────────────────────────────────────────────────── *@
    <div class="flex flex-col gap-1">
        <label class="text-sm font-semibold text-(--color-text)">Content</label>
        <ContentSurface Variant="ContentSurfaceVariant.Input">
            <EditorView @ref="_editor" Html="@ViewModel.Content" Placeholder="Write your post…" />
        </ContentSurface>
    </div>

    @* ── Rating + Spoilers (side by side) ────────────────────────────────────── *@
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <div class="flex flex-col gap-1">
            <label class="text-sm font-semibold text-(--color-text)">Rating</label>
            <InputSelect @bind-Value="ViewModel.Rating"
                         class="rounded-md border border-(--color-border) bg-(--color-surface) px-3 py-2 text-(--color-text) focus:outline-none focus:ring-2 focus:ring-(--color-action-ink)">
                @foreach (Rating r in Enum.GetValues<Rating>())
                {
                    <option value="@r">@r.ToString()</option>
                }
            </InputSelect>
        </div>
        <div class="flex items-center gap-3 pt-6">
            <InputCheckbox @bind-Value="ViewModel.HasSpoilers" id="has-spoilers"
                           class="h-4 w-4 rounded border-(--color-border) text-(--color-action-ink) focus:ring-(--color-action-ink)" />
            <label for="has-spoilers" class="text-sm text-(--color-text)">Contains spoilers</label>
        </div>
    </div>

    @* ── Linked story (optional) ──────────────────────────────────────────────── *@
    @if (AuthorStories is not null)
    {
        <div class="flex flex-col gap-1">
            <label class="text-sm font-semibold text-(--color-text)">Linked Story <span class="font-normal text-(--color-text-muted)">(optional)</span></label>
            <select @bind="ViewModel.StoryId"
                    class="rounded-md border border-(--color-border) bg-(--color-surface) px-3 py-2 text-(--color-text) focus:outline-none focus:ring-2 focus:ring-(--color-action-ink)">
                <option value="">— none —</option>
                @foreach ((int id, string title) in AuthorStories)
                {
                    <option value="@id">@title</option>
                }
            </select>
            <p class="text-xs text-(--color-text-muted)">Show a link to one of your stories at the top of this post.</p>
        </div>
    }

    @* ── Publish toggle ───────────────────────────────────────────────────────── *@
    <div class="flex items-center gap-3">
        <InputCheckbox @bind-Value="ViewModel.IsPublished" id="is-published"
                       class="h-4 w-4 rounded border-(--color-border) text-(--color-action-ink) focus:ring-(--color-action-ink)" />
        <label for="is-published" class="text-sm text-(--color-text)">
            Publish <span class="text-(--color-text-muted)">(uncheck to save as draft)</span>
        </label>
    </div>

    @* ── Submit ──────────────────────────────────────────────────────────────── *@
    <button type="submit"
            disabled="@ViewModel.IsLoading"
            class="self-start rounded-md bg-(--color-action) px-5 py-2 font-medium text-(--color-text) transition-colors hover:bg-(--color-action-hover) disabled:opacity-50">
        @(ViewModel.IsLoading ? "Saving…" : SubmitLabel)
    </button>
</EditForm>

@code {
    [Parameter, EditorRequired] public BlogPostPropertiesViewModel ViewModel { get; set; } = null!;
    [Parameter] public EventCallback OnValidSubmit { get; set; }

    /// <summary>
    /// Author's stories for the optional story-link picker. Null = hide the picker.
    /// Pass an empty list to show the picker with only the "— none —" option (author has no stories).
    /// </summary>
    [Parameter] public IReadOnlyList<(int Id, string Title)>? AuthorStories { get; set; }

    [Parameter] public string SubmitLabel { get; set; } = "Save";

    private EditorView? _editor;

    /// <summary>Pull the current editor HTML. Called by the page on submit before building the DTO.</summary>
    public async Task<string> GetContentAsync() =>
        _editor is not null ? await _editor.GetHtmlAsync() : string.Empty;

    // Push counterpart for draft restore (DraftAutosave) — Quill ignores later Html parameter
    // changes, so restored content must go through EditorView.SetHtmlAsync.
    public async Task SetContentAsync(string html)
    {
        if (_editor is not null) await _editor.SetHtmlAsync(html);
    }

    private async Task HandleValidSubmit() => await OnValidSubmit.InvokeAsync();
}
