@page "/blog/{BlogPostId:int}/{*Slug}"
@namespace TheCanalaveLibrary.SharedUI
@inject IBlogPostWriteService BlogPostService
@inject IPollReadService PollReadService
@inject IPublicUrlProvider PublicUrlProvider
@inject ILogger<BlogPostPage> Logger
@inject NavigationManager Nav
@using TheCanalaveLibrary.Core
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Logging

@* Read-only blog-post view page. Slug is cosmetic — only BlogPostId (int) is the key.
   Pattern 1: separate view and edit pages (cross-cutting.md "Two content-editing patterns").
   Injects IBlogPostWriteService (which : IBlogPostReadService) so the authenticated like-toggle
   can call ToggleLikeAsync. Author-only affordances (Edit link) are controlled by @if (isAuthor);
   the server gate is the real authority (layer3.5-structure.md §"Author-Conditional Rendering").
   Anonymous visitors can view published posts — no @attribute [Authorize] here.
   [PersistentState] on Post and Polls eliminates the prerender→interactive double-fetch flicker;
   OnParametersSetAsync's dispatcher reload path stays a plain fetch (WU-ComponentSoundness). *@

@if (_isLoading)
{
    <p class="text-(--color-text-muted)"><em>Loading…</em></p>
}
else if (_gate is not null && Post is null)
{
    @* Mature interstitial (WU-AccessGate): the post exists but the viewer hasn't consented. *@
    <ContentGateInterstitial Metadata="@_gate" />
}
else if (_notFound || Post is null)
{
    <p class="text-(--color-danger)">Post not found.</p>
}
else
{
    bool isAuthor = _currentUserId.HasValue && _currentUserId == Post.AuthorId;
    @if (Post.Rating == Rating.M)
    {
        @* Adult labels on the revealed branch too — the URL is adult regardless of consent. *@
        <AdultContentMetaTags />
    }

    <PageTitle>@Post.Title</PageTitle>
    <SocialMetaTags Title="@Post.Title" Description="@OgDescription" ImageUrl="@OgImageUrl" Url="@OgUrl" OgType="article"/>

    <article class="mx-auto max-w-2xl px-4 py-8 flex flex-col gap-6">

        @* ── Title ─────────────────────────────────────────────────────────── *@
        <h1 class="text-3xl font-bold text-(--color-text)">@Post.Title</h1>

        @* ── Meta row ──────────────────────────────────────────────────────── *@
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-(--color-text-muted)">
            @if (Post.AuthorDisplayName is not null)
            {
                <a href="/profile/@Post.AuthorId"
                   class="text-(--color-action-ink) hover:underline">@Post.AuthorDisplayName</a>
                <span>·</span>
            }
            <span>@Post.DateCreated.ToString("MMMM d, yyyy")</span>
            <span>·</span>
            <span>@Post.Rating</span>
            @if (Post.HasSpoilers)
            {
                <span>·</span>
                <span class="font-medium text-(--color-warning)">⚠ Spoilers</span>
            }
            @if (!Post.IsPublished && isAuthor)
            {
                <span>·</span>
                <span class="rounded bg-(--color-surface) px-1.5 py-0.5 text-xs font-medium text-(--color-text-muted) ring-1 ring-(--color-border)">Draft</span>
            }
        </div>

        @* ── Linked story ──────────────────────────────────────────────────── *@
        @if (Post.LinkedStoryTitle is not null && Post.StoryId.HasValue)
        {
            <div class="text-sm text-(--color-text-muted)">
                About:
                <a href="/story/@Post.StoryId"
                   class="text-(--color-action-ink) hover:underline">@Post.LinkedStoryTitle</a>
            </div>
        }

        @* ── Content ───────────────────────────────────────────────────────── *@
        <ContentSurface Variant="ContentSurfaceVariant.Reading">
            <div class="prose prose-sm max-w-none text-(--color-text)">
                <RichTextView HtmlContent="@Post.Content" />
            </div>
        </ContentSurface>

        @* ── Like button + author Edit link ─────────────────────────────────── *@
        <div class="flex items-center gap-4">
            @if (_currentUserId is not null)
            {
                <button type="button"
                        disabled="@_likeBusy"
                        @onclick="HandleLikeAsync"
                        class="flex items-center gap-1.5 text-sm transition-colors disabled:opacity-50 @(_isLiked ? "text-(--color-action-ink)" : "text-(--color-text-muted) hover:text-(--color-action-ink)")">
                    @(_isLiked ? "♥" : "♡") @_likeCount
                </button>
            }
            else
            {
                <span class="text-sm text-(--color-text-muted)">♡ @_likeCount</span>
            }

            @if (isAuthor)
            {
                <a href="/blog/@Post.BlogPostId/edit"
                   class="text-sm text-(--color-action-ink) hover:underline">Edit</a>
            }
        </div>

        <InlineAlert Message="@_likeError" />

    </article>

    @* ── Polls (Feature 37) — blocks after the post content, before comments.
         Authors manage polls in the edit page; here they render vote-only. ──── *@
    @if (Polls is { Length: > 0 })
    {
        <div class="mx-auto max-w-2xl px-4 pb-8">
            <CanalaveErrorBoundary Label="polls" Compact="true">
                <div class="flex flex-col gap-4">
                    @foreach (PollDto poll in Polls)
                    {
                        <PollView @key="poll.PollId"
                                  Poll="poll"
                                  CurrentUserId="_currentUserId"
                                  OnPollChanged="p => HandlePollChanged(poll.PollId, p)" />
                    }
                </div>
            </CanalaveErrorBoundary>
        </div>
    }

    @* ── Comments ─────────────────────────────────────────────────────────────── *@
    <div class="mx-auto max-w-2xl px-4 pb-8">
        <CanalaveErrorBoundary Label="comments" Compact="true">
            <CommentSection BlogPostId="@((int?)BlogPostId)"
                            CurrentUserId="@_currentUserId" />
        </CanalaveErrorBoundary>
    </div>
}

@code {
    [Parameter] public int BlogPostId { get; set; }

    /// <summary>Cosmetic catch-all — ignored on load; only BlogPostId is the key.</summary>
    [Parameter] public string? Slug { get; set; }

    /// <summary>Provided by the router/layout auth cascade. Null on anonymous render.</summary>
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    // Persisted across the prerender→interactive handoff — the restore-or-fetch guard in
    // OnInitializedAsync skips the refetch when [PersistentState] restored these from the
    // prerender payload (layer5-wasm.md §"Avoiding the double fetch"). Both DTOs carry only
    // what the page already renders (poll voter lists are pre-filtered server-side per
    // PollDto's visibility contract), so persisting adds no exposure.
    [PersistentState] public BlogPostDto? Post { get; set; }
    [PersistentState] public PollDto[]? Polls { get; set; }

    private bool _isLoading = true;
    private bool _notFound;

    // Interstitial metadata when the post exists but the viewer hasn't consented
    // (WU-AccessGate). Deterministic per viewer — not persisted; consent forces a
    // full-document navigation.
    private GatedMetadataDto? _gate;

    // Current viewer (null = anonymous).
    private int? _currentUserId;

    // Like state — initialised from Post, then updated optimistically.
    private int _likeCount;
    private bool _isLiked;
    private bool _likeBusy;
    private string? _likeError;

    private bool _initialized;
    private int _loadedBlogPostId = int.MinValue; // sentinel; no real BlogPostId equals this

    // Open Graph/Twitter meta (WU-Seo). No cover field on BlogPostDto — falls back to the
    // site-default image (see audit/Seo.md "Open" re: SVG re-use). Content is sanitized HTML.
    private string? OgDescription => Post is null ? null : SocialDescriptionHelper.Clean(Post.Content);
    private string OgImageUrl => PublicUrlProvider.AbsoluteImageUrl(null, "/img/default-cover.svg");
    private string OgUrl => PublicUrlProvider.AbsolutePageUrl($"/blog/{BlogPostId}");

    protected override async Task OnInitializedAsync()
    {
        // One-time: resolve the authenticated user id (auth doesn't change mid-session).
        if (AuthState is not null)
        {
            AuthenticationState state = await AuthState;
            string? idStr = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            _currentUserId = int.TryParse(idStr, out int parsedId) ? parsedId : null;
        }

        // Restore-or-fetch: when [PersistentState] restored the prerender payload, skip the
        // refetch and just re-seed the derived like state. LoadPostAsync stays a plain fetch —
        // it also serves OnParametersSetAsync's param-change reload, which must never
        // short-circuit on a previous post's persisted state (layer3-logic.md gotcha).
        if (Post is null || Polls is null)
        {
            await LoadPostAsync();
        }
        else
        {
            _loadedBlogPostId = BlogPostId;
            _likeCount = Post.LikeCount;
            _isLiked   = Post.IsLikedByCurrentUser;
            _isLoading = false;
        }
        _initialized = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        // Fires when the same BlogPostPage instance is reused for a different BlogPostId.
        if (!_initialized) return;
        if (BlogPostId == _loadedBlogPostId) return;
        _notFound = false;
        _likeError = null;
        await LoadPostAsync();
    }

    // Loads the blog post and seeds optimistic like state.
    // Called from both OnInitializedAsync (first load) and OnParametersSetAsync (post change).
    private async Task LoadPostAsync()
    {
        _isLoading = true;
        _loadedBlogPostId = BlogPostId;
        _gate = null;
        _notFound = false;

        // Parallel load is sanctioned (layer2-services.md — factory-per-method read contexts).
        Task<BlogPostDto?> postTask = BlogPostService.GetByIdAsync(BlogPostId);
        Task<PollDto[]> pollsTask = PollReadService.GetPollsForBlogPostAsync(BlogPostId);
        await Task.WhenAll(postTask, pollsTask);

        Post = postTask.Result;
        Polls = pollsTask.Result;
        if (Post is null)
        {
            _notFound = true;
            Polls = [];
            // Gated-existence read (WU-AccessGate): a mature-gated post → interstitial (reveal
            // target = the post for profile posts, the GROUP for group posts); truly absent /
            // unpublished / taken down → real 404.
            _gate = await BlogPostService.GetBlogPostGateAsync(BlogPostId);
            if (_gate is null)
                Nav.NotFound();
        }
        else
        {
            _likeCount = Post.LikeCount;
            _isLiked   = Post.IsLikedByCurrentUser;
        }
        _isLoading = false;
    }

    private void HandlePollChanged(int pollId, PollDto? updated)
    {
        Polls = updated is null
            ? (Polls ?? []).Where(p => p.PollId != pollId).ToArray()
            : (Polls ?? []).Select(p => p.PollId == pollId ? updated : p).ToArray();
    }

    private async Task HandleLikeAsync()
    {
        if (_likeBusy || _currentUserId is null) return;

        // Optimistic update.
        bool newLiked = !_isLiked;
        _isLiked   = newLiked;
        _likeCount = newLiked ? _likeCount + 1 : Math.Max(0, _likeCount - 1);
        _likeError = null;
        _likeBusy  = true;
        StateHasChanged();

        try
        {
            BlogPostLikeResultDto result = await BlogPostService.ToggleLikeAsync(BlogPostId);
            _likeCount = result.LikeCount;
            _isLiked   = result.IsLiked;
        }
        catch (Exception ex)
        {
            // Rollback optimistic update.
            _isLiked   = !newLiked;
            _likeCount = newLiked ? Math.Max(0, _likeCount - 1) : _likeCount + 1;
            // Exception-message discipline: raw ex.Message never reaches the UI; unexpected → log.
            if (!ExceptionPresenter.IsUserFacing(ex))
                Logger.LogError(ex, "Toggling like on blog post {BlogPostId} failed unexpectedly", BlogPostId);
            _likeError = ExceptionPresenter.GetUserMessage(ex);
        }
        finally
        {
            _likeBusy = false;
            StateHasChanged();
        }
    }
}
