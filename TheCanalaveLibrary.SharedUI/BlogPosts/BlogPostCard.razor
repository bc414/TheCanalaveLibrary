@namespace TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Core

@* Leaf component — displays a single blog-post listing in the profile feed or group blog section.
   No @inject. Data comes from BlogPostListingDto (title, snippet, date, rating, spoilers).
   Navigates to the full blog-post view page via the title anchor.

   Owner affordances (WU30): when IsOwner is true, the card shows a Draft badge
   (for unpublished posts) and an Edit link in the footer row. The title anchor and Edit link
   are siblings, not nested (nested <a> is invalid HTML). GroupDesktop/GroupMobile pass no owner
   params — they get the pure view-only card with IsPublished always true. *@

<div class="flex flex-col gap-1.5 rounded-lg border border-[--color-border] bg-[--color-surface] p-4 transition-shadow hover:shadow-sm">

    @* ── Title row ───────────────────────────────────────────────────────────── *@
    <div class="flex items-start justify-between gap-2">
        <a href="/blog/@Post.BlogPostId/@SlugFromTitle(Post.Title)"
           class="font-semibold text-[--color-text] leading-snug hover:underline hover:text-[--color-primary]">
            @Post.Title
        </a>

        @* Draft badge — shown to the owner for unpublished posts *@
        @if (!Post.IsPublished)
        {
            <span class="shrink-0 rounded-full bg-[--color-warning]/15 px-2 py-0.5 text-xs font-medium text-[--color-warning]">
                Draft
            </span>
        }
    </div>

    @* ── Meta chips (rating + spoilers + date) ───────────────────────────────── *@
    <div class="flex flex-wrap items-center gap-2 text-xs text-[--color-text-muted]">
        <span>@Post.Rating</span>
        @if (Post.HasSpoilers)
        {
            <span class="font-medium text-[--color-warning]">⚠ Spoilers</span>
        }
        <span>@Post.DateCreated.ToString("MMM d, yyyy")</span>
    </div>

    @* ── Content snippet ─────────────────────────────────────────────────────── *@
    @if (!string.IsNullOrEmpty(Post.ContentSnippet))
    {
        <p class="text-sm text-[--color-text-muted] leading-relaxed line-clamp-3">@Post.ContentSnippet</p>
    }

    @* ── Footer controls — Edit (owner only) + Report (others only) ─────────── *@
    @if ((IsOwner && EditHref is not null) || OnReport.HasDelegate)
    {
        <div class="mt-1 flex gap-3 border-t border-[--color-border] pt-2">
            @if (IsOwner && EditHref is not null)
            {
                <a href="@EditHref"
                   class="text-xs font-medium text-[--color-primary] hover:underline">
                    Edit
                </a>
            }
            @if (!IsOwner && OnReport.HasDelegate)
            {
                <button type="button"
                        class="text-xs font-medium text-[--color-text-muted] hover:text-danger hover:underline"
                        @onclick="() => OnReport.InvokeAsync(Post.BlogPostId)">
                    Report
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public BlogPostListingDto Post { get; set; } = null!;

    /// <summary>
    /// True when the active viewer owns this post — shows draft badge and footer edit link.
    /// Defaults to false so existing group-feed usages are unaffected.
    /// </summary>
    [Parameter] public bool IsOwner { get; set; }

    /// <summary>
    /// The edit URL to link to in the footer controls row (e.g. <c>/blog/{id}/edit</c>).
    /// Only rendered when <see cref="IsOwner"/> is also true — use null to suppress the link.
    /// </summary>
    [Parameter] public string? EditHref { get; set; }

    /// <summary>Raised when the viewer clicks "Report" — receives the blog post id.</summary>
    [Parameter] public EventCallback<int> OnReport { get; set; }

    /// <summary>
    /// Generates a URL-safe slug from the post title for cosmetic routing — the server ignores
    /// it and uses <see cref="BlogPostListingDto.BlogPostId"/> only. Mirrors the slug generation
    /// convention for StoryPage (also cosmetic).
    /// </summary>
    private static string SlugFromTitle(string title)
    {
        if (string.IsNullOrWhiteSpace(title)) return string.Empty;
        // Lowercase, collapse non-alphanum runs to a hyphen, trim leading/trailing hyphens.
        return System.Text.RegularExpressions.Regex.Replace(
                   title.ToLowerInvariant().Replace('\'', '-'),
                   @"[^a-z0-9]+", "-")
               .Trim('-');
    }
}
