@page "/blog/new"
@page "/blog/{BlogPostId:int}/edit"
@namespace TheCanalaveLibrary.SharedUI
@attribute [Authorize]
@inject IBlogPostWriteService BlogPostService
@inject IPollWriteService PollService
@inject IStoryReadService StoryService
@inject NavigationManager NavigationManager
@inject ILogger<BlogPostEditorPage> Logger
@using TheCanalaveLibrary.Core
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Logging

@* Blog-post create/edit page — Pattern 1 edit side (cross-cutting.md "Two content-editing patterns").
   View side is BlogPostPage. This page owns routing, auth, data-load, and DTO-mapping.
   BlogPostPropertiesForm is a presentational child (no inject, bUnit-testable). *@

<PageTitle>@(BlogPostId.HasValue ? "Edit Post" : "New Post")</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (_isLoading)
        {
            <p class="text-(--color-text-muted)"><em>Loading…</em></p>
        }
        else if (_forbidden)
        {
            <p class="text-(--color-danger)">You don't have permission to edit this post.</p>
        }
        else
        {
            <div class="mx-auto max-w-2xl px-4 py-8">
                <h1 class="mb-6 inline-block rounded-md border border-(--color-border) bg-(--color-surface-raised) px-4 py-1.5 font-display text-xl font-semibold text-(--color-text)">
                    @(BlogPostId.HasValue ? "Edit Post" : "New Post")
                </h1>

                @* ── Draft safety (cross-cutting.md §"Error Handling Strategy") ── *@
                <div class="mb-4">
                    <DraftAutosave @ref="_autosave" @key="@DraftKey"
                                   DraftKey="@DraftKey"
                                   Capture="CaptureDraftAsync"
                                   OnRestore="RestoreDraftAsync" />
                </div>

                <div class="rounded-xl border border-(--color-border) bg-(--color-surface) p-6">
                    <BlogPostPropertiesForm @ref="_form"
                                            ViewModel="_viewModel"
                                            AuthorStories="_authorStories"
                                            SubmitLabel="@(BlogPostId.HasValue ? "Save Changes" : "Create Post")"
                                            OnValidSubmit="HandleValidSubmit" />
                </div>

                @* ── Polls (Feature 37) — author manages the post's polls here; the view page
                     renders them vote-only. New posts must be saved first (polls need the id). *@
                <div class="mt-6 flex flex-col gap-4">
                    <h2 class="text-sm font-semibold text-(--color-text)">Polls</h2>
                    @if (!BlogPostId.HasValue)
                    {
                        <p class="text-sm text-(--color-text-muted)">Save the post first to add polls.</p>
                    }
                    else
                    {
                        @foreach (PollDto poll in _polls)
                        {
                            <PollView @key="poll.PollId"
                                      Poll="poll"
                                      CurrentUserId="@ResolvedUserId"
                                      CanManage="true"
                                      OnPollChanged="p => HandlePollChanged(poll.PollId, p)"
                                      OnEditRequested="StartPollEdit" />
                        }

                        @if (_pollEditing is not null)
                        {
                            <div class="rounded-xl border border-(--color-border) bg-(--color-surface) p-4">
                                <h3 class="mb-3 text-sm font-semibold text-(--color-text)">
                                    @(_pollEditingId is null ? "New poll" : "Edit poll")
                                </h3>
                                <PollEditorForm Model="_pollEditing"
                                                ConfigLocked="@_pollEditingConfigLocked"
                                                SubmitLabel="@(_pollEditingId is null ? "Create Poll" : "Save Changes")"
                                                IsBusy="@_pollSaving"
                                                Errors="@_pollErrors"
                                                OnSubmit="SavePollAsync"
                                                OnCancel="CancelPollEditor" />
                            </div>
                        }
                        else
                        {
                            <button type="button" @onclick="StartPollCreate"
                                    class="self-start rounded-md bg-(--color-mission) px-4 py-1.5 text-sm font-medium text-white transition-colors hover:bg-(--color-mission-hover)">
                                Add Poll
                            </button>
                        }
                    }
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <p class="text-(--color-danger)">You must be signed in to write a blog post.</p>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter] public int? BlogPostId { get; set; }

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private BlogPostPropertiesForm? _form;
    private DraftAutosave? _autosave;
    private BlogPostPropertiesViewModel _viewModel = new();

    /// <summary>Null suppresses the story-link picker (should not happen once loaded — author always gets at least an empty list).</summary>
    /// <remarks>Deliberately NOT [PersistentState]: ValueTuple state doesn't survive the STJ
    /// persistence payload, and it's supplementary picker data, not the page's primary content.</remarks>
    private IReadOnlyList<(int Id, string Title)>? _authorStories;

    // Persisted across the prerender→interactive handoff — the loaded-for-edit source only
    // (layer5-wasm.md §"Avoiding the double fetch"). The ??= guard in OnInitializedAsync skips
    // the second GetForEditAsync; _viewModel is re-seeded deterministically from this. Live
    // form/editor state, DraftAutosave, and the polls management list stay ephemeral.
    [PersistentState] public BlogPostEditDto? EditSource { get; set; }

    private bool _isLoading = true;
    private bool _forbidden;

    // ── Polls (Feature 37) ─────────────────────────────────────────────────────
    private PollDto[] _polls = [];
    private PollEditDto? _pollEditing;
    private int? _pollEditingId;          // null = creating
    private bool _pollEditingConfigLocked;
    private bool _pollSaving;
    private IReadOnlyList<string>? _pollErrors;
    private int? ResolvedUserId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Resolve the current user's numeric id so we can load their stories for the picker.
        int? currentUserId = await ResolveCurrentUserIdAsync();
        ResolvedUserId = currentUserId;

        if (currentUserId is null)
        {
            _isLoading = false;
            return;
        }

        // Populate the story picker in parallel with loading the edit data.
        Task<IReadOnlyList<(int Id, string Title)>> storiesTask = LoadAuthorStoriesAsync(currentUserId.Value);

        if (BlogPostId.HasValue)
        {
            // ??= restore-or-fetch: skip the refetch when [PersistentState] restored the
            // prerender pass's load. The owner pre-check and view-model seeding run either way.
            EditSource ??= await BlogPostService.GetForEditAsync(BlogPostId.Value);

            if (EditSource is null)
            {
                NavigationManager.NavigateTo("/not-found");
                return;
            }

            // UX-level owner pre-check (the real gate is in ServerBlogPostWriteService).
            if (EditSource.AuthorId.HasValue && EditSource.AuthorId != currentUserId)
            {
                _forbidden = true;
                _isLoading = false;
                return;
            }

            PopulateViewModelFromEdit(EditSource);
            _polls = await PollService.GetPollsForBlogPostAsync(BlogPostId.Value);
        }

        _authorStories = await storiesTask;
        _isLoading = false;
    }

    // ── Polls (Feature 37) — inline manage panel, mirrors PollsPage's editor flow ──

    private void StartPollCreate()
    {
        _pollEditingId = null;
        _pollEditingConfigLocked = false;
        _pollErrors = null;
        _pollEditing = new PollEditDto
        {
            Options = [new PollOptionEditDto(null, ""), new PollOptionEditDto(null, "")],
        };
    }

    private void StartPollEdit(PollDto poll)
    {
        _pollEditingId = poll.PollId;
        _pollEditingConfigLocked = poll.ConfigLocked;
        _pollErrors = null;
        _pollEditing = new PollEditDto
        {
            PollName = poll.PollName,
            Description = poll.Description,
            DateOpened = poll.DateOpened,
            DateClosed = poll.DateClosed,
            AllowMultiple = poll.AllowMultiple,
            ResultsVisibility = poll.ResultsVisibility,
            AnonymityMode = poll.AnonymityMode,
            Options = poll.Options
                .OrderBy(o => o.SortOrder)
                .Select(o => new PollOptionEditDto(o.PollOptionId, o.Text))
                .ToList(),
        };
    }

    private void CancelPollEditor()
    {
        _pollEditing = null;
        _pollEditingId = null;
        _pollErrors = null;
    }

    private async Task SavePollAsync()
    {
        if (_pollEditing is null || _pollSaving || !BlogPostId.HasValue) return;
        _pollSaving = true;
        _pollErrors = null;

        try
        {
            // datetime-local yields Kind=Unspecified; entered values are UTC by contract
            // (Npgsql rejects non-UTC writes to timestamptz).
            if (_pollEditing.DateOpened is DateTime opened)
                _pollEditing.DateOpened = DateTime.SpecifyKind(opened, DateTimeKind.Utc);
            if (_pollEditing.DateClosed is DateTime closed)
                _pollEditing.DateClosed = DateTime.SpecifyKind(closed, DateTimeKind.Utc);

            if (_pollEditingId is int pollId)
                await PollService.UpdatePollAsync(pollId, _pollEditing);
            else
                await PollService.CreateBlogPostPollAsync(BlogPostId.Value, _pollEditing);

            CancelPollEditor();
            _polls = await PollService.GetPollsForBlogPostAsync(BlogPostId.Value);
        }
        catch (Exception ex)
        {
            if (!ExceptionPresenter.IsUserFacing(ex))
                Logger.LogError(ex, "Saving poll {PollId} on blog post {BlogPostId} failed unexpectedly",
                    _pollEditingId, BlogPostId);
            _pollErrors = ExceptionPresenter.GetUserMessages(ex);
        }
        finally
        {
            _pollSaving = false;
        }
    }

    private void HandlePollChanged(int pollId, PollDto? updated)
    {
        _polls = updated is null
            ? _polls.Where(p => p.PollId != pollId).ToArray()
            : _polls.Select(p => p.PollId == pollId ? updated : p).ToArray();
    }

    private async Task<IReadOnlyList<(int Id, string Title)>> LoadAuthorStoriesAsync(int authorId)
    {
        IReadOnlyList<int> storyIds = await StoryService.GetStoryIdsByAuthorAsync(authorId);
        if (storyIds.Count == 0) return [];

        StoryListingDto[] listings = await StoryService.GetListingsByIdsAsync(storyIds);
        return listings.Select(l => (l.StoryId, l.Title)).ToArray();
    }

    private void PopulateViewModelFromEdit(BlogPostEditDto dto)
    {
        _viewModel.Title        = dto.Title;
        _viewModel.Content      = dto.Content;
        _viewModel.Rating       = dto.Rating;
        _viewModel.HasSpoilers  = dto.HasSpoilers;
        _viewModel.StoryId      = dto.StoryId;
        _viewModel.IsPublished  = dto.IsPublished;
    }

    private async Task HandleValidSubmit()
    {
        _viewModel.IsLoading = true;
        _viewModel.ServerValidationErrors.Clear();

        try
        {
            // Pull content from the EditorView (pull-on-submit — layer3-logic.md §"EditorView Pull-on-Submit").
            string content = _form is not null ? await _form.GetContentAsync() : string.Empty;
            _viewModel.Content = content;

            if (BlogPostId.HasValue)
            {
                await BlogPostService.UpdateBlogPostAsync(new UpdateBlogPostDto
                {
                    BlogPostId  = BlogPostId.Value,
                    Title       = _viewModel.Title,
                    Content     = _viewModel.Content,
                    Rating      = _viewModel.Rating,
                    HasSpoilers = _viewModel.HasSpoilers,
                    StoryId     = _viewModel.StoryId,
                    IsPublished = _viewModel.IsPublished
                });
                if (_autosave is not null) await _autosave.ClearAsync(); // persisted save supersedes the local backup
                // forceLoad: same-component redirect on a Quill-hosting page — the in-place diff
                // around Quill's JS-inserted toolbar crashes the WASM renderer (Blazored.TextEditor#71;
                // Global Flip wave finding — see StoryEditorPage's twin comment).
                NavigationManager.NavigateTo($"/blog/{BlogPostId.Value}/edit", forceLoad: true);
            }
            else
            {
                int newId = await BlogPostService.CreateProfileBlogPostAsync(new CreateProfileBlogPostDto
                {
                    Title       = _viewModel.Title,
                    Content     = _viewModel.Content,
                    Rating      = _viewModel.Rating,
                    HasSpoilers = _viewModel.HasSpoilers,
                    StoryId     = _viewModel.StoryId
                });
                if (_autosave is not null) await _autosave.ClearAsync(); // persisted save supersedes the local backup
                // Navigate to the view page after creation; slug is cosmetic (derived from title at link time).
                NavigationManager.NavigateTo($"/blog/{newId}");
            }
        }
        catch (UnauthorizedAccessException)
        {
            _forbidden = true;
        }
        catch (Exception ex)
        {
            if (!ExceptionPresenter.IsUserFacing(ex))
                Logger.LogError(ex, "Saving blog post {BlogPostId} failed unexpectedly", BlogPostId);
            _viewModel.ServerValidationErrors.AddRange(ExceptionPresenter.GetUserMessages(ex));
        }
        finally
        {
            _viewModel.IsLoading = false;
        }
    }

    // ── Draft safety (DraftAutosave contract) ─────────────────────────────────────
    private string DraftKey => BlogPostId.HasValue ? $"draft:blogpost:{BlogPostId.Value}" : "draft:blogpost:new";

    private async Task<Dictionary<string, string?>?> CaptureDraftAsync()
    {
        if (_form is null || _isLoading) return null;
        return new Dictionary<string, string?>
        {
            ["Title"] = _viewModel.Title,
            ["Content"] = await _form.GetContentAsync(),
        };
    }

    private async Task RestoreDraftAsync(IReadOnlyDictionary<string, string?> fields)
    {
        if (_form is null) return;
        _viewModel.Title = fields.GetValueOrDefault("Title") ?? _viewModel.Title;
        await _form.SetContentAsync(fields.GetValueOrDefault("Content") ?? string.Empty);
        StateHasChanged();
    }

    private async Task<int?> ResolveCurrentUserIdAsync()
    {
        if (AuthState is null) return null;
        AuthenticationState state = await AuthState;
        string? idStr = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        return int.TryParse(idStr, out int id) ? id : null;
    }
}
