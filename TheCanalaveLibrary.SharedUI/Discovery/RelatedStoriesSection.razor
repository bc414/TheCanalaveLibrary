@namespace TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Core
@inject ICoOccurrenceReadService CoOccurrence
@inject IStoryReadService StoryReadService
@inject IUserStoryInteractionReadService UsiReadService
@inject IDiscoveryDefaultsReadService DiscoveryDefaults

@* Coordination composite — Feature 61, embedded "keep discovering" tail on the story detail page
   (spec §5.28/§5.30, WU-RelatedStories). Self-loading, modeled on RecommendationSection: injects
   its own read services, owns its own filter re-query. Two StoryDeck grids (Also Favorited / Also
   Recommended), one shared UserStoryInteractionFilter above them (not ResultsFilterPanel — no tag/
   FTS axes apply to a co-occurrence read scoped to one story). Co-occurrence score is never
   displayed (server-side ranking only). A subsection with zero related stories hides entirely;
   both empty ⇒ the whole component renders nothing.
   [PersistentState] on the two hydrated listing arrays only — per-viewer interaction states and
   the filter's seeded defaults are ephemeral, reloaded fresh every time (same treatment as
   StoryPage's _usiState). Outer Margin Rule: root has no m-*. *@

@if (BothEmpty)
{
    @* Nothing to discover from this story yet — render nothing rather than an empty-state stub
       on an otherwise-complete page. *@
}
else
{
    <div class="flex flex-col gap-6">
        @if (CurrentUserId is not null)
        {
            <details class="rounded-md border border-(--color-border) bg-surface px-3 py-2">
                <summary class="cursor-pointer text-sm font-medium text-(--color-text)">
                    Filter these suggestions
                </summary>
                <div class="mt-2">
                    <UserStoryInteractionFilter ExcludedKinds="@_excludedInteractions"
                                                OnChanged="HandleFilterChangedAsync" />
                </div>
            </details>
        }

        @if (FavoritedStories is null || FavoritedStories.Count > 0)
        {
            <section>
                <h2 class="text-base font-semibold text-(--color-text) mb-3">Also Favorited</h2>
                <StoryDeck Stories="FavoritedStories"
                           UserStoryInteractionStates="_favoritedStates"
                           CurrentUserId="CurrentUserId"
                           EmptyMessage="No related stories yet." />
            </section>
        }

        @if (RecommendedStories is null || RecommendedStories.Count > 0)
        {
            <section>
                <h2 class="text-base font-semibold text-(--color-text) mb-3">Also Recommended</h2>
                <StoryDeck Stories="RecommendedStories"
                           UserStoryInteractionStates="_recommendedStates"
                           CurrentUserId="CurrentUserId"
                           EmptyMessage="No related stories yet." />
            </section>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public int StoryId { get; set; }

    /// <summary>Null = anonymous viewer — hides the interaction filter (exclusions are inert).</summary>
    [Parameter] public int? CurrentUserId { get; set; }

    private const int Take = 6;

    // Persisted across the prerender→interactive handoff — the two hydrated listing arrays
    // survive the WASM handoff with no double-fetch. Per-viewer interaction states are NOT
    // persisted (ephemeral, cheap batch query — same treatment as StoryPage's _usiState).
    [PersistentState] public List<StoryListingDto>? FavoritedStories { get; set; }
    [PersistentState] public List<StoryListingDto>? RecommendedStories { get; set; }

    private IReadOnlyDictionary<int, UserStoryInteractionStateDto>? _favoritedStates;
    private IReadOnlyDictionary<int, UserStoryInteractionStateDto>? _recommendedStates;
    private IReadOnlyList<UserStoryInteractionTypeEnum> _excludedInteractions = [];

    private bool BothEmpty =>
        FavoritedStories is { Count: 0 } && RecommendedStories is { Count: 0 };

    protected override async Task OnInitializedAsync()
    {
        // Both subsections share one filter and one seeded default set (identical today for
        // AlsoFavorited/AlsoRecommended — see the Stage note if they ever diverge).
        _excludedInteractions =
            [.. await DiscoveryDefaults.GetDefaultExcludedInteractionsAsync(SiteSearchModes.AlsoFavorited)];

        if (FavoritedStories is null || RecommendedStories is null)
        {
            await LoadAsync();
        }
        else
        {
            // [PersistentState] restored the listings from the prerender payload — skip the
            // mart reads, but interaction states are per-viewer ephemeral and always reload.
            await LoadStatesAsync();
        }
    }

    private async Task LoadAsync()
    {
        var favorited = await CoOccurrence.GetAlsoFavoritedAsync(StoryId, Take, _excludedInteractions);
        var recommended = await CoOccurrence.GetAlsoRecommendedAsync(StoryId, Take, _excludedInteractions);

        FavoritedStories = [.. await StoryReadService.GetListingsByIdsAsync(
            [.. favorited.Select(r => r.RelatedStoryId)])];
        RecommendedStories = [.. await StoryReadService.GetListingsByIdsAsync(
            [.. recommended.Select(r => r.RelatedStoryId)])];

        await LoadStatesAsync();
    }

    private async Task LoadStatesAsync()
    {
        if (CurrentUserId is null)
        {
            _favoritedStates = null;
            _recommendedStates = null;
            return;
        }

        _favoritedStates = await UsiReadService.GetStatesByStoryIdsAsync(
            [.. (FavoritedStories ?? []).Select(s => s.StoryId)]);
        _recommendedStates = await UsiReadService.GetStatesByStoryIdsAsync(
            [.. (RecommendedStories ?? []).Select(s => s.StoryId)]);
    }

    private async Task HandleFilterChangedAsync(IReadOnlyList<UserStoryInteractionTypeEnum> excluded)
    {
        _excludedInteractions = excluded;
        await LoadAsync();
        StateHasChanged();
    }
}
