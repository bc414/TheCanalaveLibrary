@page "/discover"
@namespace TheCanalaveLibrary.SharedUI
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@inject IStoryReadService StoryReadService
@inject IUserStoryInteractionReadService InteractionReadService
@inject IDiscoveryDefaultsReadService DiscoveryDefaults
@inject ITagReadService TagReadService

@* SearchPage — /discover (WU28, spec §5.3 / §5.28; former SearchDesktop composite folded in
   2026-07-18, WU-ResponsiveMerge — single responsive tree, page owns its markup).
   Loads §8.7 defaults on init and preloads a random batch (area is never blank).
   AllowAnonymous: discovery is public.
   Layout: ResultsFilterPanel sidebar + StoryDeck with Give-me-more / pagination; the sidebar
   stacks above the deck at narrow (desktop composition is the base).

   Two modes keyed on _filter.Sort:
   - Random: Items accumulates across batches; "Give me more" appends a fresh draw.
   - Sorted (DatePublished / Relevance): offset pagination via GetListingsAsync.

   [PersistentState] on DefaultExcludedInteractions and Items eliminates the prerender→interactive
   double fetch on full document loads (layer5-wasm.md §"Avoiding the double fetch"). Only the
   INITIAL load reads the persisted payload — every user-driven search/page/batch afterward is a
   plain assignment to the same properties. Per-viewer interaction states (_states) stay ephemeral
   and are reloaded on hydration. *@

<div class="flex flex-col gap-6 items-start px-3 py-4 md:flex-row md:px-4">

    @* ── ResultsFilterPanel sidebar (stacks above the deck at narrow) ──────────────────── *@
    <aside class="w-full md:w-72 md:shrink-0 rounded-lg border border-(--color-border) bg-(--color-surface-raised) p-4">
        <h2 class="mb-3 text-sm font-bold text-(--color-text-muted) uppercase tracking-wide">Filters</h2>
        <ResultsFilterPanel OnSearch="@HandleFilterChangedAsync"
                            InitialFilter="@_filter"
                            InitialIncludedTags="@_includedTagChips"
                            InitialExcludedTags="@_excludedTagChips"
                            AvailableSorts="@AvailableSorts"
                            ShowTextSearch="true"
                            ShowTagFilter="true"
                            ShowInteractionFilters="true"
                            ShowTagIncludeModeToggle="true" />
    </aside>

    @* ── Main area: StoryDeck + mode-dependent controls ─────────────────────────────────── *@
    <div class="w-full min-w-0 flex-1 flex flex-col gap-4">

        @if (IsRandomMode)
        {
            @* Random mode: no pagination; deck TotalCount == Items.Count forces TotalPages=1
               so PaginationControls self-hides. "Give me more" button appears below the deck. *@
            <StoryDeck Stories="@(Items ?? [])"
                       UserStoryInteractionStates="@_states"
                       CurrentUserId="@_currentUserId"
                       EmptyMessage="No stories found for these filters. Try broadening your search."
                       CurrentPage="1"
                       PageSize="@(Items?.Length ?? 0)"
                       TotalCount="@(Items?.Length ?? 0)"
                       OnReport="@(id => _reportDialog.OpenAsync(ReportedEntityType.Story, id))" />

            <button type="button"
                    class="self-center rounded-md bg-(--color-mission) px-5 py-2 text-sm font-medium text-white hover:bg-(--color-mission-hover) active:bg-(--color-mission-hover) transition-colors disabled:opacity-50"
                    disabled="@_isLoadingMore"
                    @onclick="HandleLoadMoreAsync">
                @(_isLoadingMore ? "Loading…" : "Give me more")
            </button>
        }
        else
        {
            @* Sorted mode: real pagination; no give-me-more button. *@
            <StoryDeck Stories="@(Items ?? [])"
                       UserStoryInteractionStates="@_states"
                       CurrentUserId="@_currentUserId"
                       EmptyMessage="No stories found for these filters. Try broadening your search."
                       CurrentPage="@_filter.Page"
                       PageSize="@_filter.PageSize"
                       TotalCount="@_totalCount"
                       OnPageChanged="@HandlePageChangedAsync"
                       OnReport="@(id => _reportDialog.OpenAsync(ReportedEntityType.Story, id))" />
        }

        <ReportDialog @ref="_reportDialog" />
    </div>

</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private const int RandomBatchSize = 20;

    private int? _currentUserId;
    private StoryFilterDto _filter = new() { Sort = DefaultSortOrder.Random };

    // §8.7 default exclusions for the SearchPage surface — fetched at prerender, restored at
    // hydration ([PersistentState] requires a public property). Array, not IReadOnlyList: STJ
    // round-trips concrete types most predictably in the persisted payload.
    [PersistentState]
    public UserStoryInteractionTypeEnum[]? DefaultExcludedInteractions { get; set; }

    // Accumulation array — appended to in random mode; replaced on sort change or filter change.
    // Persisted so the initial random batch survives the prerender→interactive handoff; later
    // batches/pages overwrite it with plain assignments.
    [PersistentState]
    public StoryListingDto[]? Items { get; set; }

    // In random mode TotalCount is Items.Length (deterministic proxy — see LoadRandomBatchAsync),
    // so it is recomputed on restore rather than persisted.
    private int _totalCount;
    private IReadOnlyDictionary<int, UserStoryInteractionStateDto> _states =
        new Dictionary<int, UserStoryInteractionStateDto>();

    // Resolved tag chips for seeding the panel (loaded when InitialFilter carries tag ids).
    private IReadOnlyList<TagChipDto> _includedTagChips = [];
    private IReadOnlyList<TagChipDto> _excludedTagChips = [];

    private bool _isLoadingMore;

    // ── Presentation state (from the former SearchDesktop composite) ──────────────
    private ReportDialog _reportDialog = default!;

    private bool IsRandomMode => _filter.Sort == DefaultSortOrder.Random;

    private static readonly IReadOnlyList<DefaultSortOrder> AvailableSorts =
        [DefaultSortOrder.Random, DefaultSortOrder.DatePublished, DefaultSortOrder.Relevance];

    protected override async Task OnInitializedAsync()
    {
        // Resolve current user id (nullable — anonymous viewers are fully supported).
        if (AuthState is not null)
        {
            var state = await AuthState;
            string? idClaim = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(idClaim, out int userId)) _currentUserId = userId;
        }

        // Seed filter with §8.7 defaults for the SearchPage surface (??= restore-or-fetch idiom).
        DefaultExcludedInteractions ??=
            [.. await DiscoveryDefaults.GetDefaultExcludedInteractionsAsync(SiteSearchModes.SearchPage)];

        _filter = _filter with { ExcludedInteractions = DefaultExcludedInteractions };

        if (Items is null)
        {
            // Pre-load initial random batch — spec §5.28: area is never blank on load.
            await LoadRandomBatchAsync(append: false);
        }
        else
        {
            // Restored from the prerender payload: no listing refetch. Recompute the random-mode
            // TotalCount proxy and reload only the per-viewer interaction states — ephemeral
            // supplementary state, deterministic per viewer, so the re-fetch is flicker-free
            // (same treatment as StoryPage's _usiState).
            _totalCount = Items.Length;
            await LoadInteractionStatesAsync();
        }
    }

    // ── Filter changes (panel Apply) ──────────────────────────────────────────────────────────────

    private async Task HandleFilterChangedAsync(StoryFilterDto filter)
    {
        _filter = filter with { Page = 1 };

        // Resolve tag chips for the new filter (feeds back into panel seed on next render).
        await ResolveTagChipsAsync();

        // Reset accumulation on any filter/mode change.
        Items = [];
        _totalCount = 0;

        if (_filter.Sort == DefaultSortOrder.Random)
            await LoadRandomBatchAsync(append: false);
        else
            await LoadSortedPageAsync();
    }

    // ── Sorted pagination ─────────────────────────────────────────────────────────────────────────

    private async Task HandlePageChangedAsync(int page)
    {
        _filter = _filter with { Page = page };
        await LoadSortedPageAsync();
    }

    private async Task LoadSortedPageAsync()
    {
        (Items, _totalCount) = await StoryReadService.GetListingsAsync(_filter);
        await LoadInteractionStatesAsync();
    }

    // ── Random mode ───────────────────────────────────────────────────────────────────────────────

    private async Task HandleLoadMoreAsync()
    {
        _isLoadingMore = true;
        await LoadRandomBatchAsync(append: true);
        _isLoadingMore = false;
    }

    private async Task LoadRandomBatchAsync(bool append)
    {
        StoryListingDto[] batch = await StoryReadService.GetRandomBatchAsync(_filter, RandomBatchSize);

        StoryListingDto[] items = append ? [.. Items ?? [], .. batch] : batch;
        Items = items;
        // In random mode TotalCount is not meaningful (stateless draw); use item count as a proxy
        // so StoryDeck's PaginationControls self-hides (TotalCount == PageSize == Items.Count → TotalPages=1).
        _totalCount = items.Length;

        await LoadInteractionStatesAsync();
    }

    // ── Shared helpers ────────────────────────────────────────────────────────────────────────────

    private async Task LoadInteractionStatesAsync()
    {
        if (_currentUserId.HasValue && Items is { Length: > 0 })
        {
            _states = await InteractionReadService.GetStatesByStoryIdsAsync(
                [.. Items.Select(i => i.StoryId)]);
        }
        else
        {
            _states = new Dictionary<int, UserStoryInteractionStateDto>();
        }
    }

    private async Task ResolveTagChipsAsync()
    {
        _includedTagChips = _filter.IncludedTagIds.Count > 0
            ? await TagReadService.GetTagChipsByIdsAsync(_filter.IncludedTagIds)
            : [];

        _excludedTagChips = _filter.ExcludedTagIds.Count > 0
            ? await TagReadService.GetTagChipsByIdsAsync(_filter.ExcludedTagIds)
            : [];
    }
}
