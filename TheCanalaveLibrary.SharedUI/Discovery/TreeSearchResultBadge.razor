@namespace TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Core

@* Leaf (WU44) — per-result annotation for the Automatic Tree Search tab, rendered through
   StoryDeck's CardOverlay slot. Degree badge always shown; the path chip appears only when Path
   is present (chain-of-trust edge sets only — see TreeSearchListingItemDto.Path). The path chip
   NEVER resolves or displays a user-typed node's identity (privacy model, spec §5.4): it shows
   only the story-typed hops, labeled generically by id (no per-card title lookup — avoids N+1).
   Indicator role (badges/icons that color identity, not action) per layer4-style.md "Element Roles". *@

<div class="flex flex-col items-end gap-1">
    <span class="rounded-full bg-(--color-surface-raised) px-2 py-0.5 text-xs font-medium text-(--color-text-muted) shadow-sm ring-1 ring-(--color-border)">
        @DegreeLabel
    </span>
    @if (_storyHops.Count > 1)
    {
        <span class="max-w-40 truncate rounded-full bg-(--color-surface-raised) px-2 py-0.5 text-[0.65rem] text-(--color-text-muted) shadow-sm ring-1 ring-(--color-border)"
              title="@PathTitle">
            @PathSummary
        </span>
    }
</div>

@code {
    [Parameter, EditorRequired] public int Degree { get; set; }

    /// <summary>Raw Postgres path text — see <see cref="TreeSearchPathParser"/>. Null unless the
    /// request's edge set was chain-of-trust with paths included.</summary>
    [Parameter] public string? Path { get; set; }

    private IReadOnlyList<int> _storyHops = [];

    protected override void OnParametersSet() =>
        _storyHops = TreeSearchPathParser.StoryIdsOnly(Path);

    private string DegreeLabel => Degree switch
    {
        1 => "1st-degree connection",
        2 => "2nd-degree connection",
        3 => "3rd-degree connection",
        _ => $"{Degree}th-degree connection"
    };

    private string PathSummary => string.Join(" → ", _storyHops.Select(id => $"#{id}"));
    private string PathTitle => $"Connected via {_storyHops.Count} stories";
}
