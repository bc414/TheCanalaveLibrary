@namespace TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Core

@* Leaf (WU44; corrected WU40, 2026-07-12) — per-result annotation for the Automatic Tree Search
   tab, rendered through StoryDeck's CardOverlay slot. Degree badge always shown; the path chip
   appears only when a path is present (chain-of-trust edge sets only).
   Privacy correction: chain-of-trust paths (HiddenGem/AuthorSpotlight — the only sets that ever
   carry a path) contain no anonymized contributor, so BOTH story and user hops render with real,
   linkable identity via the server-hydrated PathHops. A hop without a label is one the viewer
   cannot see (rating-gated bridge story) and stays an opaque #id — the silent-bridge rule holds
   for labels. The legacy ids-only rendering remains as the fallback when only the raw Path is
   supplied. Indicator role per layer4-style.md "Element Roles". *@

<div class="flex flex-col items-end gap-1">
    <span class="rounded-full bg-(--color-surface-raised) px-2 py-0.5 text-xs font-medium text-(--color-text-muted) shadow-medium ring-1 ring-(--color-border)">
        @DegreeLabel
    </span>
    @if (PathHops is { Count: > 1 })
    {
        <span class="flex max-w-48 items-center gap-1 overflow-hidden rounded-full bg-(--color-surface-raised) px-2 py-0.5 text-[0.65rem] text-(--color-text-muted) shadow-medium ring-1 ring-(--color-border)"
              title="@HopsTitle">
            @for (int i = 0; i < PathHops.Count; i++)
            {
                var hop = PathHops[i];
                if (i > 0)
                {
                    <span aria-hidden="true">→</span>
                }
                @if (hop.Label is { } label)
                {
                    <a href="@(hop.IsStory ? $"/story/{hop.Id}" : $"/user/{hop.Id}")"
                       class="max-w-16 truncate hover:underline">@label</a>
                }
                else
                {
                    <span class="shrink-0">#@hop.Id</span>
                }
            }
        </span>
    }
    else if (_storyHops.Count > 1)
    {
        <span class="max-w-40 truncate rounded-full bg-(--color-surface-raised) px-2 py-0.5 text-[0.65rem] text-(--color-text-muted) shadow-medium ring-1 ring-(--color-border)"
              title="@PathTitle">
            @PathSummary
        </span>
    }
</div>

@code {
    [Parameter, EditorRequired] public int Degree { get; set; }

    /// <summary>Raw Postgres path text — the ids-only fallback when <see cref="PathHops"/> is
    /// not supplied. See <see cref="TreeSearchPathParser"/>.</summary>
    [Parameter] public string? Path { get; set; }

    /// <summary>Server-hydrated display hops (story titles + usernames) — the preferred input;
    /// see <see cref="TreeSearchListingItemDto.PathHops"/>.</summary>
    [Parameter] public IReadOnlyList<TreeSearchPathHopDto>? PathHops { get; set; }

    private IReadOnlyList<int> _storyHops = [];

    protected override void OnParametersSet() =>
        _storyHops = PathHops is null ? TreeSearchPathParser.StoryIdsOnly(Path) : [];

    private string DegreeLabel => Degree switch
    {
        1 => "1st-degree connection",
        2 => "2nd-degree connection",
        3 => "3rd-degree connection",
        _ => $"{Degree}th-degree connection"
    };

    private string PathSummary => string.Join(" → ", _storyHops.Select(id => $"#{id}"));
    private string PathTitle => $"Connected via {_storyHops.Count} stories";
    private string HopsTitle => PathHops is null
        ? ""
        : string.Join(" → ", PathHops.Select(h => h.Label ?? $"#{h.Id}"));
}
