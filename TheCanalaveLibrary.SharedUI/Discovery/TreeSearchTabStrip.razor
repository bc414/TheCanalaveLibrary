@namespace TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Core

@* Leaf (WU44; three tabs since WU40) — the Unified Tree Search Page's tab strip: Automatic (the
   rCTE flat list), Explore (build-your-own-map), Deep Dive (bounded chain-of-trust walking).
   Used identically by TreeSearchDesktop and TreeSearchMobile. Tab selection is ephemeral UI
   state, not URL state (spec §5.26 "URL state" — only the root anchor lives in the route).
   Wayfinding role. *@

<div class="flex gap-1 border-b border-(--color-border)" role="tablist">
    <button type="button" role="tab" aria-selected="@(ActiveTab == TreeSearchTab.Automatic ? "true" : "false")"
            class="@TabClass(TreeSearchTab.Automatic)"
            @onclick="() => OnTabChanged.InvokeAsync(TreeSearchTab.Automatic)">
        Automatic
    </button>
    <button type="button" role="tab" aria-selected="@(ActiveTab == TreeSearchTab.Explore ? "true" : "false")"
            class="@TabClass(TreeSearchTab.Explore)"
            @onclick="() => OnTabChanged.InvokeAsync(TreeSearchTab.Explore)">
        Explore
    </button>
    <button type="button" role="tab" aria-selected="@(ActiveTab == TreeSearchTab.DeepDive ? "true" : "false")"
            class="@TabClass(TreeSearchTab.DeepDive)"
            @onclick="() => OnTabChanged.InvokeAsync(TreeSearchTab.DeepDive)">
        Deep Dive
    </button>
</div>

@code {
    [Parameter, EditorRequired] public TreeSearchTab ActiveTab { get; set; }
    [Parameter] public EventCallback<TreeSearchTab> OnTabChanged { get; set; }

    private string TabClass(TreeSearchTab tab) => ActiveTab == tab
        ? "px-4 py-2 text-sm font-bold text-(--color-action-ink) border-b-2 border-(--color-action-ink)"
        : "px-4 py-2 text-sm text-(--color-text-muted) hover:text-text";
}
