@namespace TheCanalaveLibrary.SharedUI
@inherits Microsoft.AspNetCore.Components.Web.ErrorBoundary
@using System.Diagnostics
@using Microsoft.Extensions.Logging
@implements IDisposable
@inject ILogger<CanalaveErrorBoundary> Logger
@inject NavigationManager Nav

@* Layered fault-containment boundary (cross-cutting.md §"Error Handling Strategy"). Subclasses
   the framework ErrorBoundary to (1) log every caught exception at Error with the island label
   and an ErrorId the fallback also shows the user (logging.md §"Unhandled exceptions"), and
   (2) auto-Recover() on navigation so a faulted island never traps the user across pages.
   Placement map (page / chrome / card / comments) lives in cross-cutting.md — wrap independent
   islands, not every component. Catches render/lifecycle/event exceptions in its subtree only;
   background-Task continuations and out-of-subtree faults still fall through to the
   #blazor-error-ui bar in App.razor (the true last resort). *@

@if (CurrentException is null)
{
    @ChildContent
}
else if (ErrorContent is not null)
{
    @ErrorContent(CurrentException)
}
else if (Compact)
{
    <div role="alert" class="rounded-md border border-(--color-danger)/40 bg-(--color-danger)/10 px-3 py-2 text-sm text-(--color-danger)">
        <span>This section hit an error.</span>
        <button type="button" class="ml-2 font-semibold underline hover:no-underline" @onclick="Recover">
            Try again
        </button>
    </div>
}
else
{
    <div role="alert" class="mx-auto my-8 max-w-md rounded-lg border border-(--color-danger)/40 bg-(--color-danger)/10 p-6 text-center">
        <p class="font-semibold text-(--color-danger)">Something went wrong displaying this page.</p>
        <p class="mt-1 text-sm text-(--color-text-muted)">
            Your other work is safe. You can try again, or navigate elsewhere.
        </p>
        <button type="button"
                class="mt-4 rounded-md bg-(--color-action) px-4 py-1.5 text-sm font-semibold text-(--color-text) transition-colors hover:bg-(--color-action-hover)"
                @onclick="Recover">
            Try again
        </button>
        @if (_errorId is not null)
        {
            <p class="mt-3 text-xs text-(--color-text-muted)">Error ID: @_errorId</p>
        }
    </div>
}

@code {
    /// <summary>
    /// Island label for the log record — e.g. "page", "chrome", "story-card", "comments".
    /// Low-cardinality; identifies WHERE the boundary sits, never entity ids.
    /// </summary>
    [Parameter] public string Label { get; set; } = "page";

    /// <summary>Compact one-liner fallback for small islands (chrome items, deck cards).</summary>
    [Parameter] public bool Compact { get; set; }

    private string? _errorId;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Nav.LocationChanged += HandleLocationChanged;
    }

    protected override Task OnErrorAsync(Exception exception)
    {
        // Trace id joins the on-screen ErrorId to this log record and its trace; CircuitId/UserId
        // arrive via the TelemetryCircuitHandler scope. Fallback id covers no-ambient-activity
        // hosts (unit tests, WASM) so the user is never shown a blank id.
        _errorId = Activity.Current?.TraceId.ToString() ?? Guid.NewGuid().ToString("N")[..16];
        Logger.LogError(exception,
            "Unhandled exception caught by error boundary {Boundary} ({ErrorId})", Label, _errorId);
        return Task.CompletedTask;
    }

    // A faulted island must not follow the user to the next page — the error state belongs to
    // the content that threw, and navigation replaces that content (docs-sanctioned pattern:
    // Recover on navigation; user-gesture Recover covers the same-page retry).
    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (CurrentException is not null)
        {
            Recover();
        }
    }

    public void Dispose() => Nav.LocationChanged -= HandleLocationChanged;
}
