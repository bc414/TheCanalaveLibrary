@namespace TheCanalaveLibrary.SharedUI

@* Universal confirm/cancel modal (spec §5.30.9). Cross-cutting container composite — no owning
   feature; cluster's feature is "modal/overlay dialogs" (canalave-conventions/SKILL.md Code
   Organization). First consumer is the chapter-comment spoiler reveal (audit/Comments.md Feature 26);
   also named for account deletion, leaving a group, deleting a custom list, unpublishing a story.

   Shell (backdrop + panel) mirrors EditorView's preview popup — see layer3.5-structure.md
   "Container Composite" ConfirmDialog example for the shared convention and why it isn't extracted
   into a further Modal primitive yet (only two consumers, two different flows). *@

@if (IsOpen)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4" @onclick="Cancel">
        <div class="max-w-md rounded-xl bg-surface p-6 shadow-lg" @onclick:stopPropagation="true">
            @if (Title is not null)
            {
                <h2 class="mb-2 text-lg font-semibold text-text">@Title</h2>
            }
            @if (ChildContent is not null)
            {
                @ChildContent
            }
            else
            {
                <p class="text-text">@Message</p>
            }
            <div class="mt-4 flex justify-end gap-2">
                <button type="button" class="rounded-md border border-[--color-border] bg-surface px-3 py-1 text-text transition-colors hover:bg-[--color-primary]/20"
                        @onclick="Cancel">
                    @CancelText
                </button>
                <button type="button" class="@(IsDestructive ? "bg-danger" : "bg-primary hover:bg-primary-strong") rounded-md px-3 py-1 text-white transition-colors"
                        @onclick="Confirm">
                    @ConfirmText
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }

    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter] public string? Title { get; set; }

    [Parameter] public string? Message { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public string ConfirmText { get; set; } = "Confirm";

    [Parameter] public string CancelText { get; set; } = "Cancel";

    [Parameter] public bool IsDestructive { get; set; }

    [Parameter] public EventCallback OnConfirm { get; set; }

    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task Confirm()
    {
        await OnConfirm.InvokeAsync();
        await Close();
    }

    private async Task Cancel()
    {
        await OnCancel.InvokeAsync();
        await Close();
    }

    private async Task Close()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }
}
