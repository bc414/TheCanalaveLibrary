@namespace TheCanalaveLibrary.SharedUI
@inject ITagReadService TagService
@inject ISpriteReadService Sprites

@* Multi-select tag picker: chips above, typeahead below. Rebuilt on CanalaveTypeahead in the
   Global Flip wave — the previous Blazored.Typeahead internals crashed the WASM renderer on the
   post-pick Value clear (archived lib, Blazored/Typeahead#221; see CanalaveTypeahead's header).
   The pick-fires-a-callback contract removed the _picked bind entirely: OnSelected appends the
   chip, the typeahead clears itself. *@

<div class="flex flex-col gap-2">
    <label class="text-sm font-bold">@Label</label>

    <div class="flex flex-wrap gap-2">
        @foreach (TagChipDto tag in _selected)
        {
            <TagChip Tag="tag" OnRemove="@(() => Remove(tag))" />
        }
    </div>

    <CanalaveTypeahead TItem="TagChipDto"
                       SearchMethod="SearchMethod"
                       OnSelected="OnPicked"
                       Placeholder="Type to search for a tag..."
                       NotFoundText="No tags found">
        <ResultTemplate Context="tag">
            <span class="inline-flex items-center gap-2">
                <span class="w-2 h-2 rounded-full @DotClass(tag.TagTypeId)"></span>
                @if (tag.SpriteIdentifier is not null && _themeCtx is not null)
                {
                    var staticSrc = Sprites.GetSpriteUrl(_themeCtx.Slug, tag.SpriteIdentifier, prefersAnimated: false);
                    var unknownSrc = $"/sprites/themes/{_themeCtx.Slug}/unknown.png";
                    <img src="@Sprites.GetSpriteUrl(_themeCtx.Slug, tag.SpriteIdentifier, _themeCtx.PrefersAnimated)"
                         data-static="@staticSrc"
                         data-unknown="@unknownSrc"
                         alt="" class="w-4 h-4" loading="lazy"
                         data-sprite-fallback />
                }
                @tag.TagName
            </span>
        </ResultTemplate>
    </CanalaveTypeahead>
</div>

@code {
    [CascadingParameter] private ThemeContext? _themeCtx { get; set; }

    [Parameter, EditorRequired]
    public TagTypeEnum TagType { get; set; }

    [Parameter]
    public string Label { get; set; } = "Tags";

    [Parameter]
    public IReadOnlyList<TagChipDto> SelectedTags { get; set; } = [];

    [Parameter]
    public EventCallback<IReadOnlyList<TagChipDto>> OnSelectionChanged { get; set; }

    private List<TagChipDto> _selected = [];

    protected override void OnInitialized()
    {
        _selected = SelectedTags.ToList();
    }

    private async Task<IEnumerable<TagChipDto>> SearchMethod(string term)
    {
        List<TagChipDto> results = await TagService.SearchTagChipsAsync(TagType, term);
        return results.Where(t => _selected.All(s => s.TagId != t.TagId));
    }

    private async Task OnPicked(TagChipDto tag)
    {
        if (_selected.All(s => s.TagId != tag.TagId))
        {
            _selected.Add(tag);
            await OnSelectionChanged.InvokeAsync(_selected);
        }
    }

    private async Task Remove(TagChipDto tag)
    {
        _selected.Remove(tag);
        await OnSelectionChanged.InvokeAsync(_selected);
    }

    // Same type-color family as TagChip's solid grounds (Phase A gate) — the dot IS the type color.
    // Fallback is a visible muted dot, not surface (the old bg-surface dot was invisible on flyouts).
    private static string DotClass(TagTypeEnum type) => type switch
    {
        TagTypeEnum.Character => "bg-(--color-tagtype-character)",
        TagTypeEnum.Setting => "bg-(--color-tagtype-setting)",
        TagTypeEnum.Genre => "bg-(--color-tagtype-genre)",
        TagTypeEnum.ContentWarning => "bg-(--color-tagtype-warning)",
        TagTypeEnum.CrossoverFandom => "bg-(--color-tagtype-crossover)",
        _ => "bg-(--color-text-muted)"
    };
}
