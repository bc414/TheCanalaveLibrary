@namespace TheCanalaveLibrary.SharedUI
@inject ISpriteReadService Sprites

<span class="@TypeClasses inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-sm" title="@Tag.Description">
    @if (Tag.SpriteIdentifier is not null && _themeCtx is not null)
    {
        var staticSrc = Sprites.GetSpriteUrl(_themeCtx.Slug, Tag.SpriteIdentifier, prefersAnimated: false);
        var unknownSrc = $"/sprites/themes/{_themeCtx.Slug}/unknown.png";
        <img src="@Sprites.GetSpriteUrl(_themeCtx.Slug, Tag.SpriteIdentifier, _themeCtx.PrefersAnimated)"
             data-static="@staticSrc"
             data-unknown="@unknownSrc"
             alt="" class="w-4 h-4" loading="lazy"
             data-sprite-fallback />
    }
    @Tag.TagName
    @if (OnRemove.HasDelegate)
    {
        <button type="button" @onclick="() => OnRemove.InvokeAsync()" aria-label="Remove tag" class="leading-none transition-opacity hover:opacity-60">✕</button>
    }
</span>

@code {
    [CascadingParameter] private ThemeContext? _themeCtx { get; set; }

    [Parameter, EditorRequired]
    public TagChipDto Tag { get; set; } = null!;

    [Parameter]
    public EventCallback OnRemove { get; set; }

    // Solid Pokémon-type-color grounds with standard black/white text (ratified at the Phase A
    // gate, 2026-07-10 — layer4-style.md "Element Roles"). Setting's Ground tan is the one light
    // ground, so it carries dark ink; the rest carry white. Fallback = neutral Indicator tint.
    private string TypeClasses => Tag.TagTypeId switch
    {
        TagTypeEnum.Character => "bg-(--color-tagtype-character) text-white",
        TagTypeEnum.Setting => "bg-(--color-tagtype-setting) text-(--color-text)",
        TagTypeEnum.Genre => "bg-(--color-tagtype-genre) text-white",
        TagTypeEnum.ContentWarning => "bg-(--color-tagtype-warning) text-white",
        TagTypeEnum.CrossoverFandom => "bg-(--color-tagtype-crossover) text-white",
        _ => "bg-(--color-text-muted)/15 text-(--color-text-muted) ring-1 ring-(--color-text-muted)/30"
    };
}
