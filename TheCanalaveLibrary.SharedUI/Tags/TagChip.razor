@namespace TheCanalaveLibrary.SharedUI
@inject ISpriteReadService Sprites

<span class="@TypeClasses inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-sm" title="@Tag.Description">
    @if (Tag.SpriteIdentifier is not null && _themeCtx is not null)
    {
        var staticSrc = Sprites.GetSpriteUrl(_themeCtx.Slug, Tag.SpriteIdentifier, prefersAnimated: false);
        var unknownSrc = $"/sprites/themes/{_themeCtx.Slug}/unknown.png";
        <img src="@Sprites.GetSpriteUrl(_themeCtx.Slug, Tag.SpriteIdentifier, _themeCtx.PrefersAnimated)"
             data-static="@staticSrc"
             data-unknown="@unknownSrc"
             alt="" class="w-4 h-4" loading="lazy"
             data-sprite-fallback />
    }
    @Tag.TagName
    @if (OnRemove.HasDelegate)
    {
        <button type="button" @onclick="() => OnRemove.InvokeAsync()" aria-label="Remove tag" class="leading-none">✕</button>
    }
</span>

@code {
    [CascadingParameter] private ThemeContext? _themeCtx { get; set; }

    [Parameter, EditorRequired]
    public TagChipDto Tag { get; set; } = null!;

    [Parameter]
    public EventCallback OnRemove { get; set; }

    private string TypeClasses => Tag.TagTypeId switch
    {
        TagTypeEnum.Character => "bg-emerald-100 text-emerald-800",
        TagTypeEnum.Setting => "bg-violet-100 text-violet-800",
        TagTypeEnum.Genre => "bg-sky-100 text-sky-800",
        TagTypeEnum.ContentWarning => "bg-rose-100 text-rose-800",
        TagTypeEnum.CrossoverFandom => "bg-amber-100 text-amber-900",
        _ => "bg-surface text-text"
    };
}
