@namespace TheCanalaveLibrary.SharedUI

@* Tag Directory — mobile composite. Browse-only (no edit controls). Unbounded sections
   (Character, Relationship, CrossoverFandom) start collapsed. WU27.5. *@

<div class="px-3 py-4">
    @foreach (var group in Directory)
    {
        bool unbounded = TagTypeLayout.IsUnbounded(group.TagType);

        @if (unbounded)
        {
            <details class="mb-4">
                <summary class="cursor-pointer list-none py-1">
                    <h2 class="inline text-base font-semibold text-text">@TagTypeLayout.Label(group.TagType)</h2>
                    <span class="ml-2 text-sm text-[--color-text-muted]">(@group.Nodes.Count)</span>
                </summary>
                <div class="mt-2">
                    <TagDirectorySection Group="group" />
                </div>
            </details>
        }
        else
        {
            <section class="mb-4">
                <h2 class="mb-2 text-base font-semibold text-text">@TagTypeLayout.Label(group.TagType)</h2>
                <TagDirectorySection Group="group" />
            </section>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public List<TagDirectoryGroupDto> Directory { get; set; } = [];
}
