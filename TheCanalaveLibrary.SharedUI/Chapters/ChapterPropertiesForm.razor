@namespace TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Core
@using Microsoft.AspNetCore.Components.Forms

@* Presentational form for chapter create/edit. No @inject — all I/O lives in ChapterEditorPage.
   Contract:
     - ViewModel carries field values + validation errors.
     - OnValidSubmit fires when EditForm validation passes; the page calls GetChapterTextAsync()
       before mapping to the write DTO.
     - StoryRating constrains the Rating picker (floor invariant: override ≥ story rating).
     - IsPrimary locks the Rating picker to inherit/equal-story (primary invariant).
     - VersionCount drives progressive versioning disclosure. *@

@if (ViewModel.ServerValidationErrors.Count > 0)
{
    <div class="rounded-lg bg-[--color-danger]/10 p-4 text-sm text-[--color-danger]" role="alert">
        <ul class="list-disc pl-4 space-y-1">
            @foreach (string error in ViewModel.ServerValidationErrors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

<EditForm Model="@ViewModel" OnValidSubmit="HandleValidSubmit" FormName="chapter-properties-form"
          class="flex flex-col gap-6">
    <DataAnnotationsValidator />

    @* ── Title ───────────────────────────────────────────────────────────────── *@
    <div class="flex flex-col gap-1">
        <label class="text-sm font-semibold text-[--color-text]">Chapter Title <span class="font-normal text-[--color-text-muted]">(optional — defaults to "Chapter N")</span></label>
        <InputText @bind-Value="ViewModel.Title"
                   class="rounded-md border border-[--color-border] bg-[--color-surface] px-3 py-2 text-[--color-text] focus:outline-none focus:ring-2 focus:ring-[--color-primary]"
                   placeholder="Chapter title" />
    </div>

    @* ── Top author's note ───────────────────────────────────────────────────── *@
    <div class="flex flex-col gap-1">
        <label class="text-sm font-semibold text-[--color-text]">
            Top Author's Note <span class="font-normal text-[--color-text-muted]">(optional)</span>
        </label>
        <EditorView @ref="_topNoteEditor" InitialHtml="@ViewModel.TopAuthorsNote" Compact="true" />
    </div>

    @* ── Chapter text ─────────────────────────────────────────────────────────── *@
    <div class="flex flex-col gap-1">
        <label class="text-sm font-semibold text-[--color-text]">Chapter Text</label>
        <EditorView @ref="_textEditor" InitialHtml="@ViewModel.ChapterText" />
    </div>

    @* ── Bottom author's note ────────────────────────────────────────────────── *@
    <div class="flex flex-col gap-1">
        <label class="text-sm font-semibold text-[--color-text]">
            Bottom Author's Note <span class="font-normal text-[--color-text-muted]">(optional)</span>
        </label>
        <EditorView @ref="_bottomNoteEditor" InitialHtml="@ViewModel.BottomAuthorsNote" Compact="true" />
    </div>

    @* ── Rating ──────────────────────────────────────────────────────────────── *@
    <div class="flex flex-col gap-1">
        <label class="text-sm font-semibold text-[--color-text]">Version Rating</label>
        @if (IsPrimary)
        {
            <p class="text-sm text-[--color-text-muted]">
                The default version inherits the story's @StoryRating rating (primary invariant).
                To change this, update the story's rating first.
            </p>
        }
        else
        {
            <InputSelect @bind-Value="ViewModel.Rating"
                         class="rounded-md border border-[--color-border] bg-[--color-surface] px-3 py-2 text-[--color-text] focus:outline-none focus:ring-2 focus:ring-[--color-primary]">
                <option value="">Same as story (@StoryRating — inherit)</option>
                @foreach (Rating r in Enum.GetValues<Rating>().Where(r => r >= StoryRating))
                {
                    <option value="@r">@r</option>
                }
            </InputSelect>
            <p class="text-xs text-[--color-text-muted]">Alternates may be rated at or above the story's rating.</p>
        }
    </div>

    @* ── Version name (progressive disclosure — only on multi-version chapters) *@
    @if (VersionCount > 1)
    {
        <div class="flex flex-col gap-1">
            <label class="text-sm font-semibold text-[--color-text]">
                Version Name <span class="font-normal text-[--color-text-muted]">(optional)</span>
            </label>
            <InputText @bind-Value="ViewModel.VersionName"
                       class="rounded-md border border-[--color-border] bg-[--color-surface] px-3 py-2 text-[--color-text] focus:outline-none focus:ring-2 focus:ring-[--color-primary]"
                       placeholder="e.g. T-rated version, Director's cut…" />
        </div>
    }

    @* ── Submit ──────────────────────────────────────────────────────────────── *@
    <div>
        <button type="submit"
                disabled="@ViewModel.IsLoading"
                class="rounded-md bg-[--color-primary] px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-[--color-primary-strong] disabled:opacity-50">
            @SubmitLabel
        </button>
    </div>

</EditForm>

@code {
    [Parameter, EditorRequired] public ChapterEditorViewModel ViewModel { get; set; } = null!;
    [Parameter, EditorRequired] public EventCallback OnValidSubmit { get; set; }
    [Parameter] public string SubmitLabel { get; set; } = "Save Chapter";
    [Parameter] public Rating StoryRating { get; set; } = Rating.E;
    [Parameter] public bool IsPrimary { get; set; }
    [Parameter] public int VersionCount { get; set; } = 1;

    private EditorView? _textEditor;
    private EditorView? _topNoteEditor;
    private EditorView? _bottomNoteEditor;

    public async Task<string> GetChapterTextAsync() => _textEditor is not null ? await _textEditor.GetHtmlAsync() : string.Empty;
    public async Task<string?> GetTopNoteAsync()
    {
        if (_topNoteEditor is null) return null;
        string html = await _topNoteEditor.GetHtmlAsync();
        return string.IsNullOrWhiteSpace(html) ? null : html;
    }
    public async Task<string?> GetBottomNoteAsync()
    {
        if (_bottomNoteEditor is null) return null;
        string html = await _bottomNoteEditor.GetHtmlAsync();
        return string.IsNullOrWhiteSpace(html) ? null : html;
    }

    private async Task HandleValidSubmit() => await OnValidSubmit.InvokeAsync();
}
