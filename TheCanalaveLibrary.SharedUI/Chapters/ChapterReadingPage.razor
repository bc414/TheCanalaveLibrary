@page "/story/{StoryId:int}/{ChapterNumber:int}"
@page "/story/{StoryId:int}/{ChapterNumber:int}/{VersionOrder:int}"
@namespace TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Core
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject ILogger<ChapterReadingPage> Logger
@inject IChapterReadService ChapterReadService
@inject IStoryArcReadService StoryArcReadService
@inject IStoryReadService StoryReadService
@inject IReadingProgressWriteService ReadingProgress
@inject IRecommendationReadService RecommendationReadService
@inject IRecommendationWriteService RecommendationWriteService
@inject IUserStoryInteractionWriteService UserStoryInteractionWriteService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IPublicUrlProvider PublicUrlProvider

@* Chapter reading page — Pattern 1 read side (cross-cutting.md "Two content-editing patterns").
   Edit side is ChapterEditorPage (WU26). Dispatcher: loads chapter DTO, TOC, version list,
   prompt-gate recommendation id, and wires reading-progress scroll JS.
   Scroll progress → RecordProgressAsync; Ch.1 ≥90% → MarkStartedAsync + reveal helpful prompt.
   [PersistentState] on Chapter/Toc/Versions eliminates the prerender→interactive double fetch;
   every reading-progress/read-mark signal stays ephemeral (layer5-wasm.md §"Avoiding the double
   fetch"). *@

@if (_gate is null)
{
    <PageTitle>@(Chapter is not null ? $"{Chapter.Title} – Chapter {ChapterNumber}" : "Chapter")</PageTitle>
}
@if (Chapter is not null)
{
    <SocialMetaTags Title="@OgTitle" Description="@OgDescription" ImageUrl="@OgImageUrl" Url="@OgUrl" OgType="article"/>
    @if (Chapter.StoryRating == Rating.M || Chapter.Rating == Rating.M)
    {
        @* Adult labels on the revealed branch too — the URL is adult regardless of consent. *@
        <AdultContentMetaTags />
    }
}

@if (_isLoading)
{
    <p class="text-(--color-text-muted)"><em>Loading…</em></p>
}
else if (_gate is not null && Chapter is null)
{
    @* Mature interstitial (WU-AccessGate): the parent story exists but the viewer hasn't
       consented. Replaces the old versioned-URL heuristic (misfired on nonexistent versions). *@
    <ContentGateInterstitial Metadata="@_gate" />
}
else if (Chapter is null)
{
    <p class="text-(--color-text-muted)">Chapter not found.</p>
}
else
{
    <div class="mx-auto max-w-2xl px-4 py-6">

        <h1 class="mb-1 text-xl font-bold text-(--color-text)">@Chapter.Title</h1>
        @* Current-arc landmark (WU45 settled): directly under the chapter title, "Arc X — name";
           nothing rendered for gap chapters (no arc contains this chapter number). *@
        @if (CurrentArcLabel is string arcLabel)
        {
            <p class="mb-1 text-sm font-medium text-(--color-text-muted)">@arcLabel</p>
        }
        <p class="mb-4 text-sm text-(--color-text-muted)">
            Chapter @Chapter.ChapterNumber
            @if (Chapter.VersionName is not null)
            {
                <span> — @Chapter.VersionName</span>
            }
        </p>

        @* Exceeds-story-rating heads-up: mature reader on an alternate that exceeds the story's
           floor rating. The primary invariant guarantees the primary never triggers this. *@
        @if (Chapter.Rating > Chapter.StoryRating)
        {
            <div class="mb-4 rounded-lg border border-(--color-border) bg-(--color-surface-raised) p-3 text-sm text-(--color-text-muted)">
                This version is rated @Chapter.Rating and exceeds the story's @Chapter.StoryRating rating.
                @if (Chapter.NextChapterNumber.HasValue)
                {
                    <a href="/story/@StoryId/@Chapter.NextChapterNumber.Value" class="ml-1 text-(--color-action-ink) hover:underline">Skip to the next chapter</a>
                }
            </div>
        }

        @* Top navigation *@
        <div class="mb-6">
            <ChapterNavigation StoryId="@StoryId"
                               CurrentChapterNumber="@Chapter.ChapterNumber"
                               CurrentVersionOrder="@Chapter.VersionOrder"
                               PreviousChapterNumber="@Chapter.PreviousChapterNumber"
                               NextChapterNumber="@Chapter.NextChapterNumber"
                               Toc="@(Toc ?? [])"
                               Versions="@(Versions ?? [])" />
        </div>

        @* Chapter body — chapter-body id is the scroll-tracking anchor for reading-progress.js *@
        @if (Chapter.TopAuthorsNote is not null)
        {
            <div class="mb-4">
                <ContentSurface Variant="ContentSurfaceVariant.Inline">
                    <RichTextView HtmlContent="@Chapter.TopAuthorsNote" />
                </ContentSurface>
            </div>
        }

        <article id="chapter-body" class="mb-6">
            <ContentSurface Variant="ContentSurfaceVariant.Reading">
                <RichTextView HtmlContent="@Chapter.ChapterText" />
            </ContentSurface>
        </article>

        @if (Chapter.BottomAuthorsNote is not null)
        {
            <div class="mb-6">
                <ContentSurface Variant="ContentSurfaceVariant.Inline">
                    <RichTextView HtmlContent="@Chapter.BottomAuthorsNote" />
                </ContentSurface>
            </div>
        }

        @* Bottom navigation *@
        <div class="mb-8">
            <ChapterNavigation StoryId="@StoryId"
                               CurrentChapterNumber="@Chapter.ChapterNumber"
                               CurrentVersionOrder="@Chapter.VersionOrder"
                               PreviousChapterNumber="@Chapter.PreviousChapterNumber"
                               NextChapterNumber="@Chapter.NextChapterNumber"
                               Toc="@(Toc ?? [])"
                               Versions="@(Versions ?? [])" />
        </div>

        @* Author-only edit link — visibility only; the write service is the real gate. *@
        @if (_isAuthor)
        {
            <div class="mb-6 text-sm">
                <a href="@EditUrl" class="text-(--color-action-ink) hover:underline">Edit this chapter</a>
            </div>
        }

        @* Comments *@
        <section aria-label="Comments">
            <CanalaveErrorBoundary Label="comments" Compact="true">
                <CommentSection ChapterId="@Chapter.ChapterId"
                                CurrentUserId="@_currentUserId"
                                UserHasCompletedStory="false" />
            </CanalaveErrorBoundary>
        </section>

        @* Recommendation helpful-prompt gate: source present + no prior success + Ch.1 scroll ≥90% *@
        @if (_recId.HasValue && _progressReached90)
        {
            <RecommendationHelpfulPrompt RecommendationId="@_recId.Value"
                                         OnRespond="HandleHelpfulPromptResponse" />
        }
    </div>
}

@code {
    [Parameter] public int StoryId { get; set; }
    [Parameter] public int ChapterNumber { get; set; }
    [Parameter] public int? VersionOrder { get; set; }

    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    // Persisted across the prerender→interactive handoff — the ??= guard in LoadChapterAsync's
    // initial-load path ensures the fetch runs once (prerender), not again on hydration.
    // Size note: Chapter.ChapterText is large HTML, so persisting it embeds a second copy in the
    // page source (once rendered, once in the persisted payload). Accepted per layer5-wasm.md
    // §"Avoiding the double fetch": it is exactly what the page renders (no added exposure), and
    // it buys zero HTTP calls on first interactive paint.
    [PersistentState] public ChapterReadingDto? Chapter { get; set; }
    [PersistentState] public ChapterTocEntryDto[]? Toc { get; set; }
    [PersistentState] public ChapterVersionDto[]? Versions { get; set; }

    // Ephemeral supplementary state — deterministic per viewer, re-fetch is flicker-free (same
    // judgment as StoryPage's _seriesMemberships/_arcs). Not persisted.
    private IReadOnlyList<StoryArcDto> _arcs = [];

    // "Arc X — Title" when the current chapter falls inside an arc; ordinal = list position
    // (arcs arrive ordered by StartChapterNumber; StoryArc has no stored SortOrder — WU45).
    private string? CurrentArcLabel
    {
        get
        {
            if (Chapter is null) return null;
            for (int i = 0; i < _arcs.Count; i++)
            {
                StoryArcDto arc = _arcs[i];
                if (Chapter.ChapterNumber >= arc.StartChapterNumber &&
                    Chapter.ChapterNumber <= arc.EndChapterNumber)
                {
                    return $"Arc {i + 1} — {arc.Title}";
                }
            }
            return null;
        }
    }
    // Lightweight listing projection (not the full StoryDetailsDTO) — the chapter DTO has no cover
    // or blurb of its own; OG tags fall back to the parent story's (WU-Seo). Loaded alongside TOC/
    // versions below, not via a heavier GetStoryByIdAsync call. Ephemeral: feeds head meta only,
    // so the prerender→interactive re-fetch is invisible.
    private StoryListingDto? _storyListing;
    private int? _currentUserId;
    private bool _isAuthor;
    private int? _recId;
    private bool _progressReached90;
    private bool _isLoading = true;

    // Interstitial metadata when the parent story exists but the viewer hasn't consented
    // (WU-AccessGate; replaced the old _gatedByRating VersionOrder heuristic). Deterministic per
    // viewer — not persisted; consent forces a full-document navigation.
    private GatedMetadataDto? _gate;

    private DotNetObjectReference<ChapterReadingPage>? _dotnetRef;
    private bool _jsRegistered;

    private bool _initialized;
    private int _loadedStoryId      = int.MinValue; // sentinel; no real StoryId equals this
    private int _loadedChapterNumber = int.MinValue; // sentinel; no real ChapterNumber equals this
    private int? _loadedVersionOrder = int.MaxValue; // sentinel; int.MaxValue is never a real VersionOrder

    // Open Graph/Twitter meta (WU-Seo) — cover/blurb fall back to the parent story's listing
    // projection (_storyListing), since the chapter DTO carries neither.
    private string OgTitle => Chapter is null ? "Chapter" : $"{Chapter.Title} – Chapter {ChapterNumber}";
    private string? OgDescription => _storyListing is null
        ? null
        : SocialDescriptionHelper.Clean(_storyListing.ShortDescription);
    private string OgImageUrl => PublicUrlProvider.AbsoluteImageUrl(_storyListing?.CoverArtRelativeUrl, "/img/default-cover.svg");
    private string OgUrl => PublicUrlProvider.AbsolutePageUrl($"/story/{StoryId}/{ChapterNumber}");

    private string EditUrl =>
        Chapter is null ? "#"
        : Chapter.VersionOrder == 0
            ? $"/story/{StoryId}/chapter/{ChapterNumber}/edit"
            : $"/story/{StoryId}/chapter/{ChapterNumber}/{Chapter.VersionOrder}/edit";

    protected override async Task OnInitializedAsync()
    {
        // One-time: resolve the authenticated user id (auth doesn't change mid-session).
        if (AuthStateTask is not null)
        {
            AuthenticationState auth = await AuthStateTask;
            string? idStr = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(idStr, out int parsedId))
                _currentUserId = parsedId;
        }

        await LoadChapterAsync(initialLoad: true);
        _initialized = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        // Fires on every same-component chapter navigation (ChapterNavigation <a href> links —
        // router-intercepted, same instance, OnInitializedAsync does NOT re-run).
        if (!_initialized) return;
        if (StoryId == _loadedStoryId && ChapterNumber == _loadedChapterNumber && VersionOrder == _loadedVersionOrder) return;

        // Dispose the existing JS scroll-progress registration before loading the new chapter
        // so readingProgress.register binds to the new chapter body, not the old one.
        await DisposeJsRegistrationAsync();
        await LoadChapterAsync(initialLoad: false);
    }

    // Loads chapter content, TOC, versions, prompt gate, and attribution.
    // initialLoad: true from OnInitializedAsync — restore-or-fetch (??=) so [PersistentState]
    // values from the prerender pass short-circuit the re-fetch. false from OnParametersSetAsync —
    // internal SPA navigations never prerender, so the previous chapter's persisted values must
    // NOT short-circuit: plain assignment (layer3-logic.md §"Route-Parameter Dispatchers").
    private async Task LoadChapterAsync(bool initialLoad)
    {
        _isLoading = true;
        _arcs = [];
        _storyListing = null;
        _isAuthor = false;
        _recId = null;
        _progressReached90 = false;
        _gate = null;

        _loadedStoryId       = StoryId;
        _loadedChapterNumber = ChapterNumber;
        _loadedVersionOrder  = VersionOrder;

        if (initialLoad)
        {
            Chapter ??= await ChapterReadService.GetChapterForReadingAsync(StoryId, ChapterNumber, VersionOrder);
        }
        else
        {
            Chapter  = await ChapterReadService.GetChapterForReadingAsync(StoryId, ChapterNumber, VersionOrder);
            Toc      = null;   // force the plain re-fetch below for the new chapter
            Versions = null;
        }

        if (Chapter is null)
        {
            // Gated-existence read (WU-AccessGate): the chapter page gates on its PARENT STORY —
            // a real answer replacing the old VersionOrder.HasValue guess, which showed a false
            // "requires mature content" for any nonexistent versioned URL of any story. An M
            // story the viewer hasn't consented to → interstitial (one story consent covers the
            // whole subtree); anything else null here → real 404. Supplementary loads are
            // deliberately skipped — no body data is fetched for an un-consented viewer.
            _gate = await StoryReadService.GetStoryGateAsync(StoryId);
            _isLoading = false;
            if (_gate is null)
                NavigationManager.NotFound();
            return;
        }

        _isAuthor = Chapter.AuthorId.HasValue && Chapter.AuthorId == _currentUserId;

        // Load TOC + accessible versions (skipped when [PersistentState] restored them) and the
        // ephemeral story listing projection (OG fallback data) + arcs in parallel.
        Task<IReadOnlyList<ChapterTocEntryDto>>? tocTask = Toc is null
            ? ChapterReadService.GetChapterTocAsync(StoryId)
            : null;
        Task<IReadOnlyList<ChapterVersionDto>>? versionsTask = Versions is null
            ? ChapterReadService.GetChapterVersionsAsync(StoryId, ChapterNumber)
            : null;
        Task<StoryListingDto[]> storyListingTask            = StoryReadService.GetListingsByIdsAsync([StoryId]);
        Task<IReadOnlyList<StoryArcDto>> arcsTask           = StoryArcReadService.GetArcsForStoryAsync(StoryId);

        List<Task> pending = [storyListingTask, arcsTask];
        if (tocTask is not null) pending.Add(tocTask);
        if (versionsTask is not null) pending.Add(versionsTask);
        await Task.WhenAll(pending);

        if (tocTask is not null)      Toc      = tocTask.Result.ToArray();
        if (versionsTask is not null) Versions = versionsTask.Result.ToArray();
        _storyListing  = storyListingTask.Result.FirstOrDefault();
        _arcs          = arcsTask.Result;

        // Prompt gate — null when: anonymous, no source, or success already recorded.
        if (_currentUserId.HasValue)
            _recId = await RecommendationReadService.GetHelpfulPromptRecommendationIdAsync(StoryId);

        // Attribution capture from ?rec= query param (fires only when the param is present).
        var uri = new Uri(NavigationManager.Uri);
        var qs = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (int.TryParse(qs["rec"], out int queryRecId) && _currentUserId.HasValue)
            _ = RecordAttributionObservedAsync(queryRecId);

        _isLoading = false;
    }

    // Fire-and-forget by contract — attribution capture must never block or fail the chapter
    // load. The loss is tolerated but observed (logging.md §"No silent catches").
    private async Task RecordAttributionObservedAsync(int recId)
    {
        try
        {
            await RecommendationWriteService.RecordAttributionSourceAsync(StoryId, recId);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Attribution-source capture failed for story {StoryId}, recommendation {RecommendationId}", StoryId, recId);
        }
    }

    // _jsRegistered is the sole gate (no firstRender check) so that re-registration works after
    // an in-place chapter change where firstRender is always false.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_jsRegistered || Chapter is null) return;
        _jsRegistered = true;
        _dotnetRef = DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeVoidAsync("readingProgress.register", _dotnetRef, "chapter-body");
        }
        catch (JSException)
        {
            // JS not available (SSR or test host). Progress tracking silently skipped.
        }
    }

    [JSInvokable]
    public async Task OnScrollProgress(float progress)
    {
        if (Chapter is null) return;
        await ReadingProgress.RecordProgressAsync(Chapter.ChapterId, progress);
        if (ChapterNumber == 1 && progress >= 0.9f && !_progressReached90)
        {
            _progressReached90 = true;
            await UserStoryInteractionWriteService.MarkStartedAsync(StoryId);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleHelpfulPromptResponse(bool wasHelpful)
    {
        if (wasHelpful && _recId.HasValue)
            await RecommendationWriteService.RecordSuccessAsync(_recId.Value);
        _recId = null;  // dismiss regardless of response
    }

    // Disposes the JS scroll-progress registration and the DotNetObjectReference.
    // Called on both component dispose and in-place chapter change (OnParametersSetAsync).
    private async Task DisposeJsRegistrationAsync()
    {
        if (_jsRegistered)
        {
            // Typed teardown states only (circuit gone / JS gone / teardown cancellation) —
            // anything else propagates and surfaces (logging.md §"No silent catches").
            try { await JS.InvokeVoidAsync("readingProgress.dispose"); }
            catch (Exception ex) when (ex is JSDisconnectedException or JSException or TaskCanceledException or ObjectDisposedException)
            {
                // Expected during page teardown — the JS side is already gone.
            }
            _jsRegistered = false;
        }
        _dotnetRef?.Dispose();
        _dotnetRef = null;
    }

    public async ValueTask DisposeAsync()
    {
        await DisposeJsRegistrationAsync();
    }
}
