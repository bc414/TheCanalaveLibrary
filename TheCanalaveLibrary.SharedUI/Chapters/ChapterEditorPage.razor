@namespace TheCanalaveLibrary.SharedUI
@page "/story/{StoryId:int}/chapter/new"
@page "/story/{StoryId:int}/chapter/{ChapterNumber:int}/edit"
@page "/story/{StoryId:int}/chapter/{ChapterNumber:int}/{VersionOrder:int}/edit"
@attribute [Authorize]
@using TheCanalaveLibrary.Core
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject IChapterWriteService ChapterService
@inject IStoryReadService StoryReadService
@inject NavigationManager NavigationManager
@inject ILogger<ChapterEditorPage> Logger
@using Microsoft.Extensions.Logging

@* Chapter create/edit page — Pattern 1 edit side (cross-cutting.md "Two content-editing patterns").
   Reading side is ChapterReadingPage (WU26). Three route patterns:
     new:          /story/{id}/chapter/new
     edit primary: /story/{id}/chapter/{ch}/edit
     edit version: /story/{id}/chapter/{ch}/{versionOrder}/edit
   Dispatcher: resolves ChapterContentId from route params, loads chapter data, maps ViewModel.
   ChapterPropertiesForm is a bUnit-testable presentational child (no inject). *@

<PageTitle>@(_isNew ? "New Chapter" : $"Edit Chapter {ChapterNumber}")</PageTitle>

@if (_isLoading)
{
    <p class="text-(--color-text-muted)"><em>Loading…</em></p>
}
else if (_forbidden)
{
    <p class="text-(--color-danger)">You don't have permission to edit this chapter.</p>
}
else
{
    <div class="mx-auto max-w-2xl px-4 py-8">
        <div class="mb-6 flex items-center justify-between gap-4">
            <h1 class="inline-block rounded-md border border-(--color-border) bg-(--color-surface-raised) px-4 py-1.5 font-display text-xl font-semibold text-(--color-text)">
                @(_isNew ? "New Chapter" : $"Edit Chapter {ChapterNumber}")
            </h1>
            @if (!_isNew)
            {
                <a href="/story/@StoryId/@ChapterNumber"
                   class="text-sm text-(--color-action-ink) hover:underline">
                    ← Back to reading
                </a>
            }
        </div>

        @* ── Version switcher (progressive — only when VersionCount > 1) ─────── *@
        @if (_versionCount > 1 && !_isNew)
        {
            <div class="mb-6 rounded-lg border border-(--color-border) bg-(--color-surface-raised) p-4">
                <h2 class="mb-2 text-sm font-semibold text-(--color-text)">Versions</h2>
                <div class="flex flex-wrap gap-2">
                    @foreach (ChapterVersionDto version in Versions ?? [])
                    {
                        bool isCurrent = version.ChapterContentId == _contentId;
                        string versionLabel = version.VersionName ?? (version.IsPrimary ? "Primary" : $"Version {version.VersionOrder}");
                        <a href="@VersionEditUrl(version)"
                           class="@(isCurrent
                               ? "rounded-md bg-(--color-action-ink)/10 px-3 py-1.5 text-sm font-semibold text-(--color-action-ink) ring-1 ring-(--color-action-ink)"
                               : "rounded-md border border-(--color-border) px-3 py-1.5 text-sm text-(--color-text) hover:bg-(--color-surface-hover)")">
                            @versionLabel
                            @if (version.IsPrimary)
                            {
                                <span class="ml-1 text-xs text-(--color-text-muted)">(default)</span>
                            }
                        </a>
                    }
                </div>
                @if (_currentVersion is not null)
                {
                    <div class="mt-3 flex flex-wrap gap-2 border-t border-(--color-border) pt-3">
                        @if (!_currentVersion.IsPrimary)
                        {
                            <button type="button"
                                    class="text-sm text-(--color-action-ink) hover:underline"
                                    @onclick="SetAsPrimaryAsync">
                                Set as default
                            </button>
                        }
                        else
                        {
                            <span class="text-sm text-(--color-text-muted)">This is the default version</span>
                        }
                    </div>
                }
            </div>
        }

        @* ── Publish toggle ──────────────────────────────────────────────────── *@
        @if (!_isNew)
        {
            <div class="mb-4 flex items-center gap-3">
                <span class="text-sm font-semibold text-(--color-text)">Status:</span>
                @if (IsPublished == true)
                {
                    <span class="text-sm text-(--color-text-muted)">Published</span>
                    <button type="button" class="text-sm text-(--color-danger) hover:underline"
                            @onclick="() => SetPublishedAsync(false)">Unpublish</button>
                }
                else
                {
                    <span class="text-sm text-(--color-text-muted)">Draft</span>
                    <button type="button" class="text-sm text-(--color-action-ink) hover:underline"
                            @onclick="() => SetPublishedAsync(true)">Publish</button>
                }
            </div>
        }

        @* ── Draft safety (cross-cutting.md §"Error Handling Strategy") ─────────── *@
        <div class="mb-4">
            <DraftAutosave @ref="_autosave" @key="@DraftKey"
                           DraftKey="@DraftKey"
                           Capture="CaptureDraftAsync"
                           OnRestore="RestoreDraftAsync" />
        </div>

        @* ── Import from file (Feature 63, WU38d — modes 1/2). New chapter: the parsed draft
             loads straight into the editor. Existing chapter: the author chooses replace-editor
             vs add-as-new-version (AddAlternateVersionAsync). Parse never commits anything. *@
        <div class="mb-4">
            <ChapterFileImport OnImported="HandleImportedDraft" />
            @if (_importedDraft is not null && !_isNew)
            {
                <div class="mt-2 flex flex-wrap items-center gap-3 text-sm">
                    <span class="text-(--color-text-muted)">Imported @_importedDraft.WordCount words —</span>
                    <button type="button" class="text-(--color-action-ink) hover:underline"
                            @onclick="ApplyImportToEditorAsync">Replace editor content</button>
                    <button type="button" class="text-(--color-action-ink) hover:underline"
                            @onclick="AddImportAsVersionAsync">Add as new version</button>
                    <button type="button" class="text-(--color-text-muted) hover:underline"
                            @onclick="() => _importedDraft = null">Cancel</button>
                </div>
            }
        </div>

        @* ── Main form ───────────────────────────────────────────────────────── *@
        <ChapterPropertiesForm @ref="_form"
                               ViewModel="_viewModel"
                               StoryRating="@(StoryRating ?? Rating.E)"
                               IsPrimary="@_isPrimary"
                               VersionCount="@_versionCount"
                               SubmitLabel="@(_isNew ? "Create Chapter" : "Save Changes")"
                               OnValidSubmit="HandleValidSubmit" />

        @* ── "Add alternate version" — progressive; hidden for new chapters ─── *@
        @if (!_isNew && _chapterId.HasValue)
        {
            <div class="mt-4 border-t border-(--color-border) pt-4">
                <button type="button"
                        class="text-sm text-(--color-text-muted) hover:text-(--color-text) hover:underline"
                        @onclick="AddAlternateAsync">
                    + Add alternate version
                </button>
            </div>
        }
    </div>
}

@code {
    [Parameter] public int StoryId { get; set; }
    [Parameter] public int? ChapterNumber { get; set; }
    [Parameter] public int? VersionOrder { get; set; }

    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    private ChapterPropertiesForm? _form;
    private DraftAutosave? _autosave;
    private ChapterEditorViewModel _viewModel = new();
    private bool _isNew;
    private bool _isLoading = true;
    private bool _forbidden;
    private bool _isPrimary = true;
    private int _versionCount = 1;
    private int? _chapterId;
    private long? _contentId;
    private ChapterVersionDto? _currentVersion;

    // Persisted loaded-for-edit SOURCE data only (layer5-wasm.md §"Avoiding the double fetch") —
    // the restore-or-fetch guards in LoadAsync skip the hydration re-fetch on full document loads.
    // The live editor state (_viewModel / ChapterPropertiesForm content / DraftAutosave) is never
    // persisted; it is re-seeded from EditSource. StoryRating is the one scalar the form needs
    // from StoryUpdateDTO — persisting the whole DTO would embed a superset this page never
    // renders (browser-exposure rule), so only the rating is kept.
    [PersistentState] public Rating? StoryRating { get; set; }
    [PersistentState] public ChapterVersionDto[]? Versions { get; set; }
    [PersistentState] public ChapterReadingDto? EditSource { get; set; }
    [PersistentState] public bool? IsPublished { get; set; }

    // Route-param tracking for same-component navigation (create → edit, or version switch).
    // Router-intercepted <a>/NavigateTo between routes served by THIS component reuses the
    // instance: OnInitializedAsync does NOT re-run — OnParametersSetAsync must reload. Same
    // pattern as ChapterReadingPage / the WU-ComponentSoundness dispatcher wave.
    private bool _initialized;
    private int _loadedStoryId;
    private int? _loadedChapterNumber;
    private int? _loadedVersionOrder;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync(initialLoad: true);
        _initialized = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_initialized) return;
        if (StoryId == _loadedStoryId && ChapterNumber == _loadedChapterNumber
            && VersionOrder == _loadedVersionOrder) return;
        await LoadAsync(initialLoad: false);
    }

    // initialLoad: true from OnInitializedAsync — restore-or-fetch (??=) so [PersistentState]
    // values from the prerender pass short-circuit the hydration re-fetch. false from
    // OnParametersSetAsync/post-mutation refreshes — internal SPA navigations never prerender,
    // so the previous route's persisted values must NOT short-circuit: clear, then plain fetch
    // (layer3-logic.md §"Route-Parameter Dispatchers").
    private async Task LoadAsync(bool initialLoad)
    {
        _isLoading = true;
        _forbidden = false;
        _viewModel = new();
        _chapterId = null;
        _contentId = null;
        _currentVersion = null;
        _isPrimary = true;
        _versionCount = 1;
        if (!initialLoad)
        {
            StoryRating = null;
            Versions = null;
            EditSource = null;
            IsPublished = null;
        }
        _loadedStoryId = StoryId;
        _loadedChapterNumber = ChapterNumber;
        _loadedVersionOrder = VersionOrder;

        _isNew = !ChapterNumber.HasValue;

        // Load story rating for the form's floor/primary invariant UI (skipped when restored).
        if (StoryRating is null)
        {
            StoryUpdateDTO? story = await StoryReadService.GetStoryForEditAsync(StoryId);
            if (story is null)
            {
                NavigationManager.NotFound();
                return;
            }
            StoryRating = story.Rating;
        }

        if (!_isNew)
        {
            // Resolve the ChapterContentId from (ChapterNumber, VersionOrder).
            Versions ??= (await ChapterService.GetChapterVersionsAsync(StoryId, ChapterNumber!.Value)).ToArray();

            long resolvedContentId;
            if (VersionOrder.HasValue)
            {
                ChapterVersionDto? v = Versions.FirstOrDefault(v => v.VersionOrder == VersionOrder.Value);
                resolvedContentId = v?.ChapterContentId
                    ?? Versions.FirstOrDefault(v => v.IsPrimary)?.ChapterContentId ?? 0;
            }
            else
            {
                resolvedContentId = Versions.FirstOrDefault(v => v.IsPrimary)?.ChapterContentId ?? 0;
            }

            if (resolvedContentId == 0)
            {
                NavigationManager.NotFound();
                return;
            }

            _contentId = resolvedContentId;
            _versionCount = Versions.Length;
            _currentVersion = Versions.FirstOrDefault(v => v.ChapterContentId == resolvedContentId);
            _isPrimary = _currentVersion?.IsPrimary ?? false;

            // Load chapter content for the form (no rating ceiling — authors see their own).
            // The service throws UnauthorizedAccessException for a non-author (the real gate,
            // both render modes) — render the forbidden state, mirroring the affordance branch below.
            try
            {
                EditSource ??= await ChapterService.GetChapterForEditAsync(resolvedContentId);
            }
            catch (UnauthorizedAccessException)
            {
                _forbidden = true;
                EditSource = null;
                Versions = null;
                _isLoading = false;
                return;
            }
            if (EditSource is null)
            {
                NavigationManager.NotFound();
                return;
            }

            // Author gate — UX only; the write service is the real authority.
            int? currentUserId = null;
            if (AuthStateTask is not null)
            {
                AuthenticationState auth = await AuthStateTask;
                string? idStr = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (int.TryParse(idStr, out int parsedId)) currentUserId = parsedId;
            }
            if (EditSource.AuthorId.HasValue && currentUserId.HasValue && EditSource.AuthorId != currentUserId)
            {
                _forbidden = true;
                // The forbidden page renders none of the fetched data — clear the persisted
                // properties so the prerender payload doesn't carry unrendered chapter source
                // (browser-exposure rule: persist only what the page renders).
                EditSource = null;
                Versions = null;
                _isLoading = false;
                return;
            }

            _chapterId = EditSource.ChapterId;

            // Publish state from TOC (GetChapterForEditAsync doesn't carry IsPublished; skipped
            // when restored).
            if (IsPublished is null)
            {
                IReadOnlyList<ChapterTocEntryDto> toc = await ChapterService.GetChapterTocAsync(StoryId);
                IsPublished = toc.FirstOrDefault(e => e.ChapterNumber == ChapterNumber!.Value)?.IsPublished ?? false;
            }

            // Populate the ViewModel (live editor state — never persisted) from the loaded-for-edit
            // source. RawRating = null means "Same as story (inherit)".
            _viewModel.Title             = EditSource.Title;
            _viewModel.ChapterText       = EditSource.ChapterText;
            _viewModel.TopAuthorsNote    = EditSource.TopAuthorsNote;
            _viewModel.BottomAuthorsNote = EditSource.BottomAuthorsNote;
            _viewModel.Rating            = EditSource.RawRating;
            _viewModel.VersionName       = EditSource.VersionName;
        }

        _isLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        _viewModel.IsLoading = true;
        _viewModel.ServerValidationErrors.Clear();
        try
        {
            string chapterText = _form is not null ? await _form.GetChapterTextAsync() : string.Empty;
            string? topNote    = _form is not null ? await _form.GetTopNoteAsync()     : null;
            string? bottomNote = _form is not null ? await _form.GetBottomNoteAsync()  : null;

            if (_isNew)
            {
                int newChapterId = await ChapterService.CreateChapterAsync(new CreateChapterDto
                {
                    StoryId           = StoryId,
                    Title             = string.IsNullOrWhiteSpace(_viewModel.Title) ? null : _viewModel.Title,
                    ChapterText       = chapterText,
                    TopAuthorsNote    = topNote,
                    BottomAuthorsNote = bottomNote,
                    Rating            = _viewModel.Rating,
                    VersionName       = _viewModel.VersionName
                });
                // CreateChapterAsync returns the new ChapterId (PK) — NOT the route's
                // ChapterNumber. Resolve the assigned number from the TOC (the service assigns
                // the next sequential number) and land on the edit page so the author can
                // publish the new draft. Navigating by ChapterId here 404'd/mis-routed —
                // found via browser pass 2026-07-01.
                _ = newChapterId; // PK retained for clarity; routing uses the number below.
                IReadOnlyList<ChapterTocEntryDto> tocAfterCreate =
                    await ChapterService.GetChapterTocAsync(StoryId);
                int newChapterNumber = tocAfterCreate.Max(t => t.ChapterNumber);
                if (_autosave is not null) await _autosave.ClearAsync(); // persisted save supersedes the local backup
                // forceLoad: same-component create→edit redirect on a Quill-hosting page — an
                // in-place re-render fine-grained-diffs around Quill's JS-inserted toolbar and
                // crashes the WASM renderer (Blazored.TextEditor#71; Global Flip wave finding —
                // see StoryEditorPage's twin comment). [PersistentState] hydrates the reload.
                NavigationManager.NavigateTo($"/story/{StoryId}/chapter/{newChapterNumber}/edit", forceLoad: true);
            }
            else if (_contentId.HasValue)
            {
                await ChapterService.UpdateChapterContentAsync(new UpdateChapterContentDto
                {
                    ChapterContentId  = _contentId.Value,
                    Title             = string.IsNullOrWhiteSpace(_viewModel.Title) ? null : _viewModel.Title,
                    ChapterText       = chapterText,
                    TopAuthorsNote    = topNote,
                    BottomAuthorsNote = bottomNote,
                    Rating            = _viewModel.Rating,
                    VersionName       = _viewModel.VersionName
                });
                if (_autosave is not null) await _autosave.ClearAsync(); // persisted save supersedes the local backup
                // Return to the reading page for this version.
                string readUrl = _isPrimary || !VersionOrder.HasValue
                    ? $"/story/{StoryId}/{ChapterNumber}"
                    : $"/story/{StoryId}/{ChapterNumber}/{VersionOrder}";
                NavigationManager.NavigateTo(readUrl);
            }
        }
        catch (UnauthorizedAccessException)
        {
            _forbidden = true;
        }
        catch (Exception ex)
        {
            if (!ExceptionPresenter.IsUserFacing(ex))
                Logger.LogError(ex, "Saving chapter failed unexpectedly for story {StoryId}, content {ChapterContentId}", StoryId, _contentId);
            _viewModel.ServerValidationErrors.AddRange(ExceptionPresenter.GetUserMessages(ex));
        }
        finally
        {
            _viewModel.IsLoading = false;
        }
    }

    // ── Draft safety (DraftAutosave contract) ─────────────────────────────────────
    private string DraftKey => _isNew
        ? $"draft:chapter:new:{StoryId}"
        : $"draft:chapter:{_contentId}";

    private async Task<Dictionary<string, string?>?> CaptureDraftAsync()
    {
        if (_form is null || _isLoading) return null;
        return new Dictionary<string, string?>
        {
            ["Title"] = _viewModel.Title,
            ["ChapterText"] = await _form.GetChapterTextAsync(),
            ["TopAuthorsNote"] = await _form.GetTopNoteAsync(),
            ["BottomAuthorsNote"] = await _form.GetBottomNoteAsync(),
            ["VersionName"] = _viewModel.VersionName,
        };
    }

    private async Task RestoreDraftAsync(IReadOnlyDictionary<string, string?> fields)
    {
        if (_form is null) return;
        _viewModel.Title = fields.GetValueOrDefault("Title") ?? _viewModel.Title;
        _viewModel.VersionName = fields.GetValueOrDefault("VersionName");
        await _form.SetChapterTextAsync(fields.GetValueOrDefault("ChapterText") ?? string.Empty);
        await _form.SetTopNoteAsync(fields.GetValueOrDefault("TopAuthorsNote"));
        await _form.SetBottomNoteAsync(fields.GetValueOrDefault("BottomAuthorsNote"));
        StateHasChanged();
    }

    // ── File import (Feature 63, WU38d — modes 1/2) ───────────────────────────────

    private ImportedChapterDraft? _importedDraft;

    private async Task HandleImportedDraft(ImportedChapterDraft draft)
    {
        if (_isNew)
        {
            await ApplyDraftAsync(draft); // nothing exists yet — straight into the editor
        }
        else
        {
            _importedDraft = draft; // existing chapter — author picks replace vs new version
        }
    }

    private async Task ApplyDraftAsync(ImportedChapterDraft draft)
    {
        if (_form is null) return;
        await _form.SetChapterTextAsync(draft.Html);
        if (string.IsNullOrWhiteSpace(_viewModel.Title) && draft.Title is not null)
        {
            _viewModel.Title = draft.Title;
        }
        StateHasChanged();
    }

    private async Task ApplyImportToEditorAsync()
    {
        if (_importedDraft is null) return;
        await ApplyDraftAsync(_importedDraft);
        _importedDraft = null;
    }

    private async Task AddImportAsVersionAsync()
    {
        if (_importedDraft is null || _chapterId is null) return;
        try
        {
            await ChapterService.AddAlternateVersionAsync(_chapterId.Value, new CreateChapterDto
            {
                StoryId = StoryId,
                Title = null, // keep the chapter's existing title
                ChapterText = _importedDraft.Html,
                Rating = null, // inherit
                VersionName = "Imported"
            });
            _importedDraft = null;
            await LoadAsync(initialLoad: false); // refresh the version switcher (plain re-fetch)
        }
        catch (Exception ex)
        {
            if (!ExceptionPresenter.IsUserFacing(ex))
                Logger.LogError(ex, "Import-as-version failed for chapter {ChapterId}", _chapterId);
            _viewModel.ServerValidationErrors.AddRange(ExceptionPresenter.GetUserMessages(ex));
        }
    }

    private async Task SetPublishedAsync(bool publish)
    {
        if (_chapterId is null) return;
        try
        {
            await ChapterService.SetPublishedAsync(_chapterId.Value, publish);
            IsPublished = publish;
        }
        catch (Exception ex)
        {
            if (!ExceptionPresenter.IsUserFacing(ex))
                Logger.LogError(ex, "Setting publish state failed unexpectedly for chapter {ChapterId}", _chapterId);
            _viewModel.ServerValidationErrors.AddRange(ExceptionPresenter.GetUserMessages(ex));
        }
    }

    private async Task SetAsPrimaryAsync()
    {
        if (_chapterId is null || _contentId is null || _currentVersion is null) return;
        try
        {
            await ChapterService.SetPrimaryVersionAsync(_chapterId.Value, _contentId.Value);
            _isPrimary = true;
            // Plain assignment — post-mutation refresh must re-fetch, never restore.
            Versions = (await ChapterService.GetChapterVersionsAsync(StoryId, ChapterNumber!.Value)).ToArray();
            _currentVersion = Versions.FirstOrDefault(v => v.ChapterContentId == _contentId.Value);
        }
        catch (Exception ex)
        {
            if (!ExceptionPresenter.IsUserFacing(ex))
                Logger.LogError(ex, "Setting primary version failed unexpectedly for chapter {ChapterId}", _chapterId);
            _viewModel.ServerValidationErrors.AddRange(ExceptionPresenter.GetUserMessages(ex));
        }
    }

    private async Task AddAlternateAsync()
    {
        if (_chapterId is null) return;
        try
        {
            long altContentId = await ChapterService.AddAlternateVersionAsync(_chapterId.Value, new CreateChapterDto
            {
                StoryId     = StoryId,
                ChapterText = "<p></p>",
                Rating      = null  // inherit by default
            });
            // Find the new version's SortOrder to build its edit URL.
            IReadOnlyList<ChapterVersionDto> updated =
                await ChapterService.GetChapterVersionsAsync(StoryId, ChapterNumber!.Value);
            ChapterVersionDto? newVer = updated.FirstOrDefault(v => v.ChapterContentId == altContentId);
            if (newVer is not null)
                // forceLoad: same-component version-switch redirect — Quill diff hazard, see the
                // create path's comment above.
                NavigationManager.NavigateTo($"/story/{StoryId}/chapter/{ChapterNumber}/{newVer.VersionOrder}/edit", forceLoad: true);
        }
        catch (Exception ex)
        {
            if (!ExceptionPresenter.IsUserFacing(ex))
                Logger.LogError(ex, "Adding an alternate version failed unexpectedly for chapter {ChapterId}", _chapterId);
            _viewModel.ServerValidationErrors.AddRange(ExceptionPresenter.GetUserMessages(ex));
        }
    }

    private string VersionEditUrl(ChapterVersionDto version) =>
        version.IsPrimary
            ? $"/story/{StoryId}/chapter/{ChapterNumber}/edit"
            : $"/story/{StoryId}/chapter/{ChapterNumber}/{version.VersionOrder}/edit";
}
