@namespace TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Core

@* Pass-through layout composite, spec §5.30 / layer3.5-structure.md "StoryDeck and StoryCard".
   Owns the three-state: null Stories = loading, empty = empty state, populated = grid.
   Injects NO service — the hosting page batch-loads StoryListingDtos and per-viewer interaction
   state (GetStatesByStoryIdsAsync) and passes them down; the deck distributes each card its slice.
   N+1 rule: never one query per card. No caret callbacks forwarded at this tier — additive when
   the first real consumer (Discovery/Report/Export) needs them (WU28/34/38).
   Outer Margin Rule: root has no m-*; parent spaces the deck. *@

@if (Stories is null)
{
    @* Loading — minimal inline; skeleton-card upgrade is additive behind this same branch *@
    <div class="flex items-center justify-center py-12 text-muted">
        <span>Loading…</span>
    </div>
}
else if (Stories.Count == 0)
{
    <div class="flex items-center justify-center py-12 text-muted">
        <span>@EmptyMessage</span>
    </div>
}
else
{
    <div class="flex flex-col gap-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var story in Stories)
            {
                <StoryCard Story="story"
                           InteractionState="@StateFor(story.StoryId)"
                           IsOwnStory="@IsOwn(story)" />
            }
        </div>
        @* PaginationControls self-hides when TotalPages <= 1 — always safe to embed *@
        <PaginationControls CurrentPage="CurrentPage"
                            PageSize="PageSize"
                            TotalCount="TotalCount"
                            OnPageChanged="OnPageChanged" />
    </div>
}

@code {
    /// <summary>
    /// The stories to display. null = loading; empty = no results; populated = render grid.
    /// </summary>
    [Parameter, EditorRequired]
    public IReadOnlyList<StoryListingDto>? Stories { get; set; }

    /// <summary>
    /// Per-viewer interaction state keyed by StoryId, batch-loaded by the hosting page via
    /// GetStatesByStoryIdsAsync. Null or missing key ⇒ all-false (no interaction recorded).
    /// </summary>
    [Parameter]
    public IReadOnlyDictionary<int, UserStoryInteractionStateDto>? InteractionStates { get; set; }

    /// <summary>
    /// The authenticated user's id. Used to compute IsOwnStory per card. Null = anonymous viewer.
    /// Pass-through composites do not inject IActiveUserContext — the dispatcher resolves this.
    /// </summary>
    [Parameter]
    public int? CurrentUserId { get; set; }

    /// <summary>Message shown in the empty state. Consumers can override per context.</summary>
    [Parameter]
    public string EmptyMessage { get; set; } = "No stories found.";

    // ── Pagination (forwarded to PaginationControls; deck holds no page state) ────────────

    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public int PageSize { get; set; }
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }

    // ── Helpers ──────────────────────────────────────────────────────────────────────────────

    private UserStoryInteractionStateDto? StateFor(int storyId)
    {
        if (InteractionStates is null) return null;
        InteractionStates.TryGetValue(storyId, out var state);
        return state;
    }

    private bool IsOwn(StoryListingDto story) =>
        CurrentUserId is not null && story.AuthorId == CurrentUserId;
}
