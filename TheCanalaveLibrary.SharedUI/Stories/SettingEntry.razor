@namespace TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Core

@* Presentational sub-component for a Setting tag that allows custom detail. No @inject. *@

<div class="flex flex-col gap-2 rounded-md border border-(--color-border) bg-(--color-surface) p-3">
    <span class="text-sm font-medium text-(--color-text)">@Chip.TagName — Custom Details</span>
    <input type="text" value="@Detail.Name" @onchange="HandleNameChange"
           placeholder="Custom setting name (optional)"
           class="rounded-md border border-(--color-border) bg-(--color-surface) px-3 py-1.5 text-sm text-(--color-text) focus:outline-none focus:ring-2 focus:ring-(--color-primary)" />
    <textarea value="@Detail.Description" @onchange="HandleDescriptionChange" rows="2"
              placeholder="Custom setting description (optional)"
              class="rounded-md border border-(--color-border) bg-(--color-surface) px-3 py-1.5 text-sm text-(--color-text) focus:outline-none focus:ring-2 focus:ring-(--color-primary)"></textarea>
</div>

@code {
    [Parameter, EditorRequired] public TagChipDto Chip { get; set; } = null!;
    [Parameter, EditorRequired] public SettingDetailDto Detail { get; set; } = null!;
    [Parameter] public EventCallback<SettingDetailDto> OnChanged { get; set; }

    private async Task HandleNameChange(ChangeEventArgs e) =>
        await OnChanged.InvokeAsync(new SettingDetailDto
        {
            BaseTagId = Detail.BaseTagId, Name = (string?)e.Value, Description = Detail.Description
        });

    private async Task HandleDescriptionChange(ChangeEventArgs e) =>
        await OnChanged.InvokeAsync(new SettingDetailDto
        {
            BaseTagId = Detail.BaseTagId, Name = Detail.Name, Description = (string?)e.Value
        });
}
