@page "/story/new"
@page "/story/{StoryId:int}/edit"
@namespace TheCanalaveLibrary.SharedUI
@attribute [Authorize]
@inject IStoryReadService StoryReadService
@inject IStoryWriteService StoryWriteService
@inject ITagReadService TagReadService
@inject IImageStorageService ImageStorageService
@inject NavigationManager NavigationManager
@inject ILogger<StoryEditorPage> Logger
@using TheCanalaveLibrary.Core
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Logging

@* Story create/edit page — Pattern 1 edit side (cross-cutting.md "Two content-editing patterns").
   View side is StoryPage / WU25. This page owns routing, auth, data-load, cover-upload ordering,
   and DTO-mapping. StoryPropertiesForm is a presentational child (no inject, bUnit-testable). *@

<PageTitle>@(StoryId.HasValue ? "Edit Story" : "New Story")</PageTitle>

@if (_isLoading)
{
    <p class="text-(--color-text-muted)"><em>Loading…</em></p>
}
else if (_forbidden)
{
    <p class="text-(--color-danger)">You don't have permission to edit this story.</p>
}
else
{
    <div class="mx-auto max-w-2xl px-4 py-8">
        <h1 class="mb-6 inline-block rounded-md border border-(--color-border) bg-(--color-surface-raised) px-4 py-1.5 font-display text-xl font-semibold text-(--color-text)">
            @(StoryId.HasValue ? "Edit Story" : "New Story")
        </h1>

        @* ── Draft safety (cross-cutting.md §"Error Handling Strategy") ─────────── *@
        <div class="mb-4">
            <DraftAutosave @ref="_autosave" @key="@DraftKey"
                           DraftKey="@DraftKey"
                           Capture="CaptureDraftAsync"
                           OnRestore="RestoreDraftAsync" />
        </div>

        <StoryPropertiesForm @ref="_form"
                             ViewModel="_viewModel"
                             InitialTagsByType="_initialTagsByType"
                             InitialCharacters="_initialCharacters"
                             InitialSettingDetails="_initialSettingDetails"
                             InitialPairings="_initialPairings"
                             InitialGenrePriorities="_initialGenrePriorities"
                             ExternalPlatforms="_externalPlatforms"
                             SubmitLabel="@(StoryId.HasValue ? "Save Changes" : "Create Story")"
                             OnValidSubmit="HandleValidSubmit" />

        @* ── Bulk chapter import (Feature 63, WU38d) — edit mode only (needs a story id) ── *@
        @if (StoryId.HasValue)
        {
            @* Chapter reorder/delete + arc management (WU45) — edit-mode-only panels; the write
               services author-gate every mutation (server authority, WU24 principle). *@
            <div class="mt-8">
                <ChapterManagerPanel StoryId="@StoryId.Value" />
            </div>
            <div class="mt-8">
                <StoryArcManagerPanel StoryId="@StoryId.Value" />
            </div>

            <div class="mt-8">
                <StoryChapterImport StoryId="@StoryId.Value" />
            </div>

            @* Story Lineage management lives on its own owner-wide page (Feature 10, WU42 settled
               decision) — this is just a discoverable redirect from the editing context. *@
            <div class="mt-4">
                <a href="/story-lineages" class="text-sm text-(--color-action-ink) hover:underline">
                    Manage story lineage →
                </a>
            </div>
        }
    </div>
}

@code {
    [Parameter] public int? StoryId { get; set; }

    private StoryPropertiesForm? _form;
    private DraftAutosave? _autosave;
    private StoryPropertiesViewModel _viewModel = new();
    private IReadOnlyDictionary<TagTypeEnum, IReadOnlyList<TagChipDto>>? _initialTagsByType;
    private IReadOnlyList<StoryCharacterDto>? _initialCharacters;
    private IReadOnlyList<SettingDetailDto>? _initialSettingDetails;
    private IReadOnlyList<StoryCharacterPairingDto>? _initialPairings;
    private IReadOnlyDictionary<int, TagPriority>? _initialGenrePriorities;
    private IReadOnlyList<ExternalPlatformDto> _externalPlatforms = [];
    private bool _isLoading = true;
    private bool _forbidden;

    protected override async Task OnInitializedAsync()
    {
        // Seeded platform lookup for the "Also posted on" section (WU38d) — needed in both modes.
        _externalPlatforms = await StoryReadService.GetExternalPlatformsAsync();

        if (StoryId.HasValue)
        {
            StoryUpdateDTO? editData = await StoryReadService.GetStoryForEditAsync(StoryId.Value);

            if (editData is null)
            {
                NavigationManager.NavigateTo("/not-found");
                return;
            }

            // StoryUpdateDTO doesn't carry AuthorId, so no client-side UX pre-check here — the real
            // gate lives in ServerStoryWriteService (throws UnauthorizedAccessException on mismatch).
            // A future enriched GetStoryForEditAsync that includes AuthorId could do the redirect here.

            PopulateViewModelFromEdit(editData);

            // Load chip data for all tags (flat tags + character tags; TagSelector needs display data).
            List<int> charTagIds = editData.StoryCharacters.Select(c => c.CharacterTagId).ToList();
            List<int> flatTagIds = editData.StoryTags.Select(t => t.TagId).ToList();
            List<int> allTagIds = [..charTagIds, ..flatTagIds];
            if (allTagIds.Count > 0)
            {
                List<TagChipDto> chips = await TagReadService.GetTagChipsByIdsAsync(allTagIds);
                _initialTagsByType = chips
                    .GroupBy(c => c.TagTypeId)
                    .ToDictionary(g => g.Key, g => (IReadOnlyList<TagChipDto>)[.. g]);
            }
            _initialCharacters     = editData.StoryCharacters;
            _initialSettingDetails = editData.SettingDetails;
            _initialPairings       = editData.StoryCharacterPairings;
            _initialGenrePriorities = editData.StoryTags
                .Where(t => t.TagTypeEnum == TagTypeEnum.Genre)
                .ToDictionary(t => t.TagId, t => t.Priority);
        }

        _isLoading = false;
    }

    private void PopulateViewModelFromEdit(StoryUpdateDTO dto)
    {
        _viewModel.Title = dto.Title;
        _viewModel.ShortDescription = dto.ShortDescription;
        _viewModel.Rating = dto.Rating;
        _viewModel.StoryStatusId = dto.StoryStatusId;
        _viewModel.CoverArtRelativeUrl = dto.CoverArtRelativeUrl;
        _viewModel.LongDescription = dto.LongDescription;
        _viewModel.PostApprovalStatus = dto.PostApprovalStatus;
        _viewModel.ExternalLinks = dto.ExternalLinks;
        _viewModel.OriginalPublishedDate = dto.OriginalPublishedDate;
        _viewModel.OriginalLastUpdatedDate = dto.OriginalLastUpdatedDate;
    }

    private async Task HandleValidSubmit()
    {
        _viewModel.IsLoading = true;
        _viewModel.ServerValidationErrors.Clear();

        try
        {
            // Pull long description from the EditorView (pull-on-submit — Blazored.TextEditor pattern).
            string longDescription = _form is not null
                ? await _form.GetLongDescriptionAsync()
                : string.Empty;
            _viewModel.LongDescription = longDescription;

            // Structured collections — built by the form on every selection change.
            List<IStoryTag> flatTags = _viewModel.SelectedFlatTags.Cast<IStoryTag>().ToList();
            List<StoryCharacterDto> characters   = _viewModel.SelectedCharacters;
            List<SettingDetailDto> settingDetails = _viewModel.SelectedSettingDetails;
            List<StoryCharacterPairingDto> pairings = _viewModel.SelectedPairings;

            if (StoryId.HasValue)
            {
                // Edit path.
                var updateDto = new StoryUpdateDTO
                {
                    StoryId = StoryId.Value,
                    Title = _viewModel.Title,
                    ShortDescription = _viewModel.ShortDescription,
                    Rating = _viewModel.Rating,
                    StoryStatusId = _viewModel.StoryStatusId,
                    CoverArtRelativeUrl = _viewModel.CoverArtRelativeUrl,
                    LongDescription = _viewModel.LongDescription,
                    PostApprovalStatus = _viewModel.PostApprovalStatus,
                    StoryTags = flatTags,
                    StoryCharacters = characters,
                    SettingDetails = settingDetails,
                    StoryCharacterPairings = pairings,
                    ExternalLinks = _viewModel.ExternalLinks,
                    OriginalPublishedDate = _viewModel.OriginalPublishedDate,
                    OriginalLastUpdatedDate = _viewModel.OriginalLastUpdatedDate
                };

                // Upload new cover if selected (id already exists on edit).
                if (_form?.SelectedCoverFile is { } coverFile)
                {
                    const long maxBytes = 10 * 1024 * 1024;
                    await using Stream stream = coverFile.OpenReadStream(maxBytes);
                    updateDto.CoverArtRelativeUrl = await ImageStorageService.SaveAsync(
                        stream, coverFile.ContentType, ImageKind.Cover, StoryId.Value);
                    _viewModel.CoverArtRelativeUrl = updateDto.CoverArtRelativeUrl;
                }

                await StoryWriteService.UpdateStoryAsync(updateDto);
                if (_autosave is not null) await _autosave.ClearAsync(); // persisted save supersedes the local backup
                NavigationManager.NavigateTo($"/story/{StoryId.Value}/edit");
            }
            else
            {
                // Create path — AuthorId is server-stamped in CreateStoryAsync.
                var createDto = new CreateStoryDTO
                {
                    Title = _viewModel.Title,
                    ShortDescription = _viewModel.ShortDescription,
                    Rating = _viewModel.Rating,
                    StoryStatusId = _viewModel.StoryStatusId,
                    CoverArtRelativeUrl = null, // set after create if a file was selected
                    LongDescription = _viewModel.LongDescription,
                    PostApprovalStatus = _viewModel.PostApprovalStatus,
                    StoryTags = flatTags,
                    StoryCharacters = characters,
                    SettingDetails = settingDetails,
                    StoryCharacterPairings = pairings,
                    ExternalLinks = _viewModel.ExternalLinks,
                    OriginalPublishedDate = _viewModel.OriginalPublishedDate,
                    OriginalLastUpdatedDate = _viewModel.OriginalLastUpdatedDate
                };

                int newStoryId = await StoryWriteService.CreateStoryAsync(createDto);

                // Upload cover now that we have the story id.
                if (_form?.SelectedCoverFile is { } coverFile)
                {
                    const long maxBytes = 10 * 1024 * 1024;
                    await using Stream stream = coverFile.OpenReadStream(maxBytes);
                    string coverUrl = await ImageStorageService.SaveAsync(
                        stream, coverFile.ContentType, ImageKind.Cover, newStoryId);

                    // Patch the cover URL onto the just-created story.
                    await StoryWriteService.UpdateStoryAsync(new StoryUpdateDTO
                    {
                        StoryId = newStoryId,
                        Title = _viewModel.Title,
                        ShortDescription = _viewModel.ShortDescription,
                        Rating = _viewModel.Rating,
                        StoryStatusId = _viewModel.StoryStatusId,
                        CoverArtRelativeUrl = coverUrl,
                        LongDescription = _viewModel.LongDescription,
                        PostApprovalStatus = _viewModel.PostApprovalStatus,
                        StoryTags = flatTags,
                        StoryCharacters = characters,
                        SettingDetails = settingDetails,
                        StoryCharacterPairings = pairings,
                        ExternalLinks = _viewModel.ExternalLinks,
                        OriginalPublishedDate = _viewModel.OriginalPublishedDate,
                        OriginalLastUpdatedDate = _viewModel.OriginalLastUpdatedDate
                    });
                }

                if (_autosave is not null) await _autosave.ClearAsync(); // persisted save supersedes the local backup
                NavigationManager.NavigateTo($"/story/{newStoryId}/edit");
            }
        }
        catch (UnauthorizedAccessException)
        {
            _forbidden = true;
        }
        catch (Exception ex)
        {
            if (!ExceptionPresenter.IsUserFacing(ex))
                Logger.LogError(ex, "Saving story {StoryId} failed unexpectedly", StoryId);
            _viewModel.ServerValidationErrors.AddRange(ExceptionPresenter.GetUserMessages(ex));
        }
        finally
        {
            _viewModel.IsLoading = false;
        }
    }

    // ── Draft safety (DraftAutosave contract). Prose fields only — structured tag/character
    // selections are picker state, not typed work; re-selecting them is cheap, re-typing a
    // description is not. ─────────────────────────────────────────────────────────
    private string DraftKey => StoryId.HasValue ? $"draft:story:{StoryId.Value}" : "draft:story:new";

    private async Task<Dictionary<string, string?>?> CaptureDraftAsync()
    {
        if (_form is null || _isLoading) return null;
        return new Dictionary<string, string?>
        {
            ["Title"] = _viewModel.Title,
            ["ShortDescription"] = _viewModel.ShortDescription,
            ["LongDescription"] = await _form.GetLongDescriptionAsync(),
        };
    }

    private async Task RestoreDraftAsync(IReadOnlyDictionary<string, string?> fields)
    {
        if (_form is null) return;
        _viewModel.Title = fields.GetValueOrDefault("Title") ?? _viewModel.Title;
        _viewModel.ShortDescription = fields.GetValueOrDefault("ShortDescription") ?? _viewModel.ShortDescription;
        await _form.SetLongDescriptionAsync(fields.GetValueOrDefault("LongDescription") ?? string.Empty);
        StateHasChanged();
    }
}
