@page "/story/{StoryId:int}/{*StorySlug}"
@namespace TheCanalaveLibrary.SharedUI
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using TheCanalaveLibrary.Core
@inject IStoryReadService StoryReadService
@inject IChapterReadService ChapterReadService
@inject IUserStoryInteractionReadService UsiReadService
@inject ISeriesReadService SeriesReadService
@inject IStoryLineageReadService StoryLineageReadService
@inject IStoryArcReadService StoryArcReadService
@inject IViewCountWriteService ViewCountWriteService
@inject IDeviceDetectionService DeviceService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IPublicUrlProvider PublicUrlProvider
@implements IAsyncDisposable

@* Read-only story landing page (spec §5.28, content-editing Pattern 1 — view side).
   StorySlug is cosmetic — only StoryId (int) is the authoritative key.
   No @attribute [Authorize] — stories are publicly visible; the global "ContentRating" query
   filter handles maturity gating. Anonymous auth state is handled via nullable CascadingParameter.
   [PersistentState] on Story and Chapters eliminates the prerender→interactive double-fetch flicker.
   Author-only affordances (Edit Story link, draft chapters) are controlled by _isAuthor;
   the server gate in UpdateStoryAsync is the real authority (layer3.5-structure.md §"Author-Conditional Rendering"). *@

@if (_isLoading)
{
    <PageTitle>Loading…</PageTitle>
    <p class="text-(--color-text-muted)"><em>Loading…</em></p>
}
else if (_notFound || Story is null)
{
    <PageTitle>Story not found</PageTitle>
    <p class="text-(--color-danger)">Story not found.</p>
}
else
{
    <PageTitle>@Story.StoryTitle</PageTitle>
    <SocialMetaTags Title="@OgTitle" Description="@OgDescription" ImageUrl="@OgImageUrl" Url="@OgUrl" OgType="article"/>

    @if (DeviceService.IsMobile())
    {
        <StoryMobile Story="Story"
                     Chapters="@(Chapters ?? [])"
                     CurrentUserId="_currentUserId"
                     IsAuthor="_isAuthor"
                     UsiState="_usiState"
                     SeriesMemberships="_seriesMemberships"
                     LineageLinks="_lineageLinks"
                     Arcs="_arcs"
                     ViewerWatermarkUtc="_viewerWatermarkUtc" />
    }
    else
    {
        <StoryDesktop Story="Story"
                      Chapters="@(Chapters ?? [])"
                      CurrentUserId="_currentUserId"
                      IsAuthor="_isAuthor"
                      UsiState="_usiState"
                      SeriesMemberships="_seriesMemberships"
                      LineageLinks="_lineageLinks"
                      Arcs="_arcs"
                      ViewerWatermarkUtc="_viewerWatermarkUtc" />
    }
}

@code {
    [Parameter] public int StoryId { get; set; }

    /// <summary>Cosmetic catch-all — ignored on load; only StoryId is the key.</summary>
    [Parameter] public string? StorySlug { get; set; }

    /// <summary>Provided by the router/layout auth cascade. Null on anonymous render.</summary>
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    // Persisted across the prerender→interactive handoff — the ??= guard in OnInitializedAsync
    // ensures the DB is only hit once (server-side render), not again when WASM activates.
    [PersistentState] public StoryDetailsDTO? Story { get; set; }
    [PersistentState] public ChapterListEntryDto[]? Chapters { get; set; }

    private bool _isLoading = true;
    private bool _notFound;
    private int? _currentUserId;
    private bool _isAuthor;
    // Per-viewer interaction state for the Detail-context panel (N+1 rule: the panel receives
    // state from this dispatcher, never loads its own). Added in the L4.5 browser pass
    // (2026-07-01): the Detail panel existed and was bUnit-tested but was mounted nowhere, so
    // Favorite/Follow/Complete were unreachable anywhere in the UI.
    private UserStoryInteractionStateDto? _usiState;

    // Series membership box(es) — WU41. A story may be in more than one series; not persisted
    // (same treatment as _usiState — ephemeral supplementary data, reloaded fresh every time).
    private IReadOnlyList<StorySeriesMembershipDto> _seriesMemberships = [];

    // Approved outgoing lineage links — WU42. Same ephemeral treatment as _seriesMemberships.
    private IReadOnlyList<StoryLineageDto> _lineageLinks = [];

    // Story arcs + the viewer's New-badge watermark — WU45. Ephemeral like _seriesMemberships:
    // both are deterministic per viewer, so the prerender→interactive re-fetch is flicker-free.
    private IReadOnlyList<StoryArcDto> _arcs = [];
    private DateTime? _viewerWatermarkUtc;

    private bool _initialized;
    private int _loadedStoryId = int.MinValue; // sentinel; no real StoryId equals this

    // Open Graph/Twitter meta (WU-Seo) — computed from Story rather than cached at load time, so
    // there is no second place to keep in sync across OnInitializedAsync/OnParametersSetAsync.
    // Only rendered in the `else` branch below, where Story is guaranteed non-null.
    private string OgTitle => Story?.StoryTitle ?? "Untitled Story";
    private string? OgDescription => Story is null
        ? null
        : SocialDescriptionHelper.Clean(Story.ShortDescription) ?? SocialDescriptionHelper.Clean(Story.LongDescription);
    private string OgImageUrl => PublicUrlProvider.AbsoluteImageUrl(Story?.CoverArtRelativeUrl, "/img/default-cover.svg");
    private string OgUrl => PublicUrlProvider.AbsolutePageUrl(Story is null
        ? $"/story/{StoryId}"
        : string.IsNullOrEmpty(Story.Slug) ? $"/story/{Story.StoryId}" : $"/story/{Story.StoryId}/{Story.Slug}");

    protected override async Task OnInitializedAsync()
    {
        // One-time: resolve the viewer's identity (auth doesn't change mid-session).
        if (AuthState is not null)
        {
            AuthenticationState state = await AuthState;
            string? idStr = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            _currentUserId = int.TryParse(idStr, out int parsed) ? parsed : null;
        }

        // ??= guard: skip the DB call when [PersistentState] has already restored these from the
        // prerender payload (the "no flicker" invariant — layer3-logic.md §"State Persistence").
        _loadedStoryId = StoryId;
        Story  ??= await StoryReadService.GetStoryByIdAsync(StoryId);
        if (Story is null)
        {
            _notFound = true;
            _isLoading = false;
            _initialized = true;
            NavigationManager.NotFound();
            return;
        }

        await LoadSupplementaryAsync();

        _isAuthor  = _currentUserId.HasValue && Story.AuthorId == _currentUserId;
        _isLoading = false;
        _initialized = true;
    }

    // The six supplementary loads are mutually independent, so they run under Task.WhenAll
    // (layer2-services.md §"Read-Context Concurrency" — server reads are factory-per-method, so
    // concurrent calls are safe; under WASM this collapses six serial HTTP round-trips on the
    // heaviest page in the app). Shared by both lifecycle methods (MA-203). Chapters only
    // participates when not already restored by [PersistentState] (init) or nulled for a reload
    // (OnParametersSetAsync); _usiState only for an authenticated viewer.
    private async Task LoadSupplementaryAsync()
    {
        Task<IReadOnlyList<ChapterListEntryDto>>? chaptersTask =
            Chapters is null ? ChapterReadService.GetChapterListAsync(StoryId) : null;
        Task<UserStoryInteractionStateDto>? usiTask =
            _currentUserId is not null ? UsiReadService.GetStateAsync(StoryId) : null;
        Task<IReadOnlyList<StorySeriesMembershipDto>> membershipsTask =
            SeriesReadService.GetMembershipsForStoryAsync(StoryId);
        Task<IReadOnlyList<StoryLineageDto>> lineageTask =
            StoryLineageReadService.GetLineageForStoryAsync(StoryId);
        Task<IReadOnlyList<StoryArcDto>> arcsTask = StoryArcReadService.GetArcsForStoryAsync(StoryId);
        Task<DateTime?> watermarkTask = ChapterReadService.GetViewerLastInteractionUtcAsync(StoryId);

        List<Task> pending = [membershipsTask, lineageTask, arcsTask, watermarkTask];
        if (chaptersTask is not null) pending.Add(chaptersTask);
        if (usiTask is not null) pending.Add(usiTask);
        await Task.WhenAll(pending);

        if (chaptersTask is not null) Chapters = (await chaptersTask).ToArray();
        _usiState = usiTask is not null ? await usiTask : null;
        _seriesMemberships = await membershipsTask;
        _lineageLinks = await lineageTask;
        _arcs = await arcsTask;
        _viewerWatermarkUtc = await watermarkTask;
    }

    protected override async Task OnParametersSetAsync()
    {
        // Fires when the same StoryPage instance is reused for a different StoryId.
        if (!_initialized) return;
        if (StoryId == _loadedStoryId) return;

        _isLoading = true;
        _notFound = false;
        _loadedStoryId = StoryId;

        // Plain assignment (not ??=) — the [PersistentState] fields from the previous story must
        // not short-circuit the reload for a new StoryId (layer3-logic.md §"Route-Parameter Dispatchers").
        Story = await StoryReadService.GetStoryByIdAsync(StoryId);
        if (Story is null)
        {
            _notFound = true;
            _isLoading = false;
            NavigationManager.NotFound();
            return;
        }

        // Plain reload: null the persisted chapter list so LoadSupplementaryAsync refetches it for
        // the new StoryId (the [PersistentState] value belongs to the previous story).
        Chapters = null;
        await LoadSupplementaryAsync();
        _isAuthor = _currentUserId.HasValue && Story.AuthorId == _currentUserId;
        _isLoading = false;

        // In-place story change: re-arm the view ping so the new story gets its own view.
        await DisposeViewPingAsync();
    }

    // ── View ping (Feature 45) ────────────────────────────────────────────────────────────
    // First scroll or 5s dwell — never raw page load (filters bots/bounces). Anonymous counts.

    private DotNetObjectReference<StoryPage>? _dotnetRef;
    private bool _pingRegistered;

    // _pingRegistered is the sole gate (no firstRender check) so re-registration works after an
    // in-place story change where firstRender is always false (same idiom as ChapterReadingPage).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pingRegistered || Story is null || _notFound) return;
        _pingRegistered = true;
        _dotnetRef ??= DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeVoidAsync("viewPing.register", _dotnetRef);
        }
        catch (JSException)
        {
            // JS not available (SSR prerender or test host). View ping silently skipped.
        }
    }

    [JSInvokable]
    public async Task OnViewPing()
    {
        if (Story is null) return;
        await ViewCountWriteService.RecordViewAsync(Story.StoryId);
    }

    private async Task DisposeViewPingAsync()
    {
        if (_pingRegistered)
        {
            // Typed teardown states only (circuit gone / JS gone / teardown cancellation) —
            // anything else propagates and surfaces (logging.md §"No silent catches").
            try { await JS.InvokeVoidAsync("viewPing.dispose"); }
            catch (Exception ex) when (ex is JSDisconnectedException or JSException or TaskCanceledException or ObjectDisposedException)
            {
                // Expected during page teardown — the JS side is already gone.
            }
            _pingRegistered = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        await DisposeViewPingAsync();
        _dotnetRef?.Dispose();
        _dotnetRef = null;
    }
}
