@namespace TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Core
@inject ISpriteReadService Sprites

@* Presentational sub-component. No @inject for I/O services — all I/O via parameters and callbacks. *@

<div class="flex flex-col gap-2 rounded-md border border-[--color-border] bg-[--color-surface] p-3">
    <div class="flex items-center justify-between gap-2">
        <div class="flex items-center gap-2">
            @if (Chip.SpriteIdentifier is not null && _themeCtx is not null)
            {
                var staticSrc = Sprites.GetSpriteUrl(_themeCtx.Slug, Chip.SpriteIdentifier, prefersAnimated: false);
                var unknownSrc = $"/sprites/themes/{_themeCtx.Slug}/unknown.png";
                <img src="@Sprites.GetSpriteUrl(_themeCtx.Slug, Chip.SpriteIdentifier, _themeCtx.PrefersAnimated)"
                     data-static="@staticSrc"
                     data-unknown="@unknownSrc"
                     alt="" class="h-6 w-6 object-contain"
                     onerror="spriteFallback(this)" />
            }
            <span class="font-medium text-[--color-text]">@Chip.TagName</span>
        </div>
        <div class="flex items-center gap-3">
            <label class="text-xs text-[--color-text-muted]">Priority</label>
            <select value="@Dto.Priority" @onchange="HandlePriorityChange"
                    class="rounded border border-[--color-border] bg-[--color-surface] px-2 py-1 text-xs text-[--color-text]">
                <option value="@TagPriority.Primary">Primary</option>
                <option value="@TagPriority.Supporting">Supporting</option>
            </select>
            <button type="button" @onclick="HandleRemove"
                    class="text-xs text-[--color-danger] hover:underline">Remove</button>
        </div>
    </div>

    @if (Chip.AllowOCDetails)
    {
        <label class="flex cursor-pointer items-center gap-2 text-sm text-[--color-text]">
            <input type="checkbox" checked="@Dto.IsOc" @onchange="HandleOcToggle"
                   class="rounded border-[--color-border]" />
            OC (Original Character)
        </label>

        @if (Dto.IsOc)
        {
            <input type="text" value="@Dto.OcName" @onchange="HandleOcNameChange"
                   placeholder="OC name (optional)"
                   class="rounded-md border border-[--color-border] bg-[--color-surface] px-3 py-1.5 text-sm text-[--color-text] focus:outline-none focus:ring-2 focus:ring-[--color-primary]" />
            <textarea value="@Dto.OcBio" @onchange="HandleOcBioChange" rows="2"
                      placeholder="OC bio / description (optional)"
                      class="rounded-md border border-[--color-border] bg-[--color-surface] px-3 py-1.5 text-sm text-[--color-text] focus:outline-none focus:ring-2 focus:ring-[--color-primary]"></textarea>
        }
    }
</div>

@code {
    [CascadingParameter] private ThemeContext? _themeCtx { get; set; }

    [Parameter, EditorRequired] public TagChipDto Chip { get; set; } = null!;
    [Parameter, EditorRequired] public StoryCharacterDto Dto { get; set; } = null!;
    [Parameter] public EventCallback<StoryCharacterDto> OnChanged { get; set; }
    [Parameter] public EventCallback OnRemoved { get; set; }

    private async Task HandlePriorityChange(ChangeEventArgs e)
    {
        TagPriority priority = Enum.Parse<TagPriority>((string)e.Value!);
        await OnChanged.InvokeAsync(new StoryCharacterDto
        {
            CharacterTagId = Dto.CharacterTagId, Priority = priority,
            IsOc = Dto.IsOc, OcName = Dto.OcName, OcBio = Dto.OcBio
        });
    }

    private async Task HandleOcToggle(ChangeEventArgs e)
    {
        bool isOc = (bool)e.Value!;
        await OnChanged.InvokeAsync(new StoryCharacterDto
        {
            CharacterTagId = Dto.CharacterTagId, Priority = Dto.Priority,
            IsOc = isOc, OcName = isOc ? Dto.OcName : null, OcBio = isOc ? Dto.OcBio : null
        });
    }

    private async Task HandleOcNameChange(ChangeEventArgs e) =>
        await OnChanged.InvokeAsync(new StoryCharacterDto
        {
            CharacterTagId = Dto.CharacterTagId, Priority = Dto.Priority,
            IsOc = Dto.IsOc, OcName = (string?)e.Value, OcBio = Dto.OcBio
        });

    private async Task HandleOcBioChange(ChangeEventArgs e) =>
        await OnChanged.InvokeAsync(new StoryCharacterDto
        {
            CharacterTagId = Dto.CharacterTagId, Priority = Dto.Priority,
            IsOc = Dto.IsOc, OcName = Dto.OcName, OcBio = (string?)e.Value
        });

    private async Task HandleRemove() => await OnRemoved.InvokeAsync();
}
