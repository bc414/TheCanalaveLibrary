@namespace TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Core
@using Microsoft.AspNetCore.Components.Forms

@* Presentational form for story create/edit. No @inject — all I/O lives in StoryEditorPage.
   Contract:
     - ViewModel carries field values + structured tag state + validation errors (set by the page).
     - OnValidSubmit fires when EditForm validation passes; the page then calls GetLongDescriptionAsync()
       and reads SelectedCoverFile before mapping to the write DTO.
     - InitialTagsByType seeds TagSelectors on first render (edit mode). Null = create mode (empty).
     - InitialCharacters/SettingDetails/Pairings/GenrePriorities seed structured data in edit mode. *@

<InlineAlert Messages="@ViewModel.ServerValidationErrors" />

<EditForm Model="@ViewModel" OnValidSubmit="HandleValidSubmit" FormName="story-properties-form"
          class="flex flex-col gap-6">
    <DataAnnotationsValidator />

    @* ── Title ───────────────────────────────────────────────────────────────── *@
    <div class="flex flex-col gap-1">
        <label class="text-sm font-semibold text-(--color-text)">Title</label>
        <InputText @bind-Value="ViewModel.Title"
                   class="rounded-md border border-(--color-border) bg-(--color-surface) px-3 py-2 text-(--color-text) focus:outline-none focus:ring-2 focus:ring-(--color-action-ink)"
                   placeholder="Story title" />
        <ValidationMessage For="@(() => ViewModel.Title)" class="text-sm text-(--color-danger)" />
    </div>

    @* ── Short description ────────────────────────────────────────────────────── *@
    <div class="flex flex-col gap-1">
        <label class="text-sm font-semibold text-(--color-text)">Short Description</label>
        <InputTextArea @bind-Value="ViewModel.ShortDescription" rows="2"
                       class="rounded-md border border-(--color-border) bg-(--color-surface) px-3 py-2 text-(--color-text) focus:outline-none focus:ring-2 focus:ring-(--color-action-ink)"
                       placeholder="One-line hook shown in story listings (max 500 chars)" />
        <ValidationMessage For="@(() => ViewModel.ShortDescription)" class="text-sm text-(--color-danger)" />
    </div>

    @* ── Rating + Status (side by side on wider screens) ─────────────────────── *@
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <div class="flex flex-col gap-1">
            <label class="text-sm font-semibold text-(--color-text)">Rating</label>
            <InputSelect @bind-Value="ViewModel.Rating"
                         class="rounded-md border border-(--color-border) bg-(--color-surface) px-3 py-2 text-(--color-text) focus:outline-none focus:ring-2 focus:ring-(--color-action-ink)">
                @foreach (Rating r in Enum.GetValues<Rating>())
                {
                    <option value="@r">@r.ToString()</option>
                }
            </InputSelect>
        </div>
        <div class="flex flex-col gap-1">
            <label class="text-sm font-semibold text-(--color-text)">Status</label>
            <InputSelect @bind-Value="ViewModel.StoryStatusId"
                         class="rounded-md border border-(--color-border) bg-(--color-surface) px-3 py-2 text-(--color-text) focus:outline-none focus:ring-2 focus:ring-(--color-action-ink)">
                @foreach (StoryStatusEnum s in Enum.GetValues<StoryStatusEnum>())
                {
                    <option value="@s">@s.ToString()</option>
                }
            </InputSelect>
        </div>
    </div>

    @* ── Cover art ───────────────────────────────────────────────────────────── *@
    <div class="flex flex-col gap-2">
        <label class="text-sm font-semibold text-(--color-text)">Cover Art</label>
        @if (!string.IsNullOrEmpty(ViewModel.CoverArtRelativeUrl))
        {
            <img src="@ViewModel.CoverArtRelativeUrl"
                 alt="Current cover"
                 class="h-32 w-24 rounded-md object-cover shadow-subtle" />
        }
        <InputFile OnChange="HandleCoverSelected" accept="image/jpeg,image/png,image/webp"
                   class="text-sm text-(--color-text-muted) file:mr-3 file:rounded-md file:border-0 file:bg-(--color-action) file:px-3 file:py-1.5 file:text-sm file:font-medium file:text-(--color-text) file:transition-colors hover:file:bg-(--color-action-hover)" />
        <p class="text-xs text-(--color-text-muted)">JPEG, PNG, or WebP · max 10 MB</p>
    </div>

    @* ── Long description (rich text) ─────────────────────────────────────────── *@
    <div class="flex flex-col gap-1">
        <label class="text-sm font-semibold text-(--color-text)">Summary / Long Description</label>
        <ContentSurface Variant="ContentSurfaceVariant.Input">
            <EditorView @ref="_editor" Html="@ViewModel.LongDescription" Placeholder="Full story summary…" />
        </ContentSurface>
    </div>

    @* ── Tags ────────────────────────────────────────────────────────────────── *@
    <div class="flex flex-col gap-6">
        <p class="text-sm font-semibold text-(--color-text)">Tags</p>

        @* Characters + per-entry detail + pairings *@
        <div class="flex flex-col gap-2">
            <TagSelector @key="@string.Join(",", _characterChips.Select(c => c.TagId))"
                         TagType="TagTypeEnum.Character"
                         Label="Characters"
                         SelectedTags="@_characterChips"
                         OnSelectionChanged="HandleCharacterChange" />
            @for (int i = 0; i < _characterDtos.Count; i++)
            {
                int idx = i;
                TagChipDto? chip = _characterChips.FirstOrDefault(c => c.TagId == _characterDtos[idx].CharacterTagId);
                if (chip is not null)
                {
                    <CharacterEntry Chip="@chip" Dto="@_characterDtos[idx]"
                                    OnChanged="@(dto => OnCharacterDtoChanged(idx, dto))"
                                    OnRemoved="@(() => RemoveCharacter(_characterDtos[idx].CharacterTagId))" />
                }
            }
        </div>

        @if (_characterChips.Count >= 2)
        {
            <div class="flex flex-col gap-1">
                <p class="text-sm font-medium text-(--color-text)">Character Pairings</p>
                <PairingBuilder CharacterChips="@_characterChips"
                                Pairings="@_pairings"
                                OnPairingsChanged="HandlePairingsChanged" />
            </div>
        }

        @* Settings + optional detail overlays *@
        <div class="flex flex-col gap-2">
            <TagSelector @key="@string.Join(",", _settingChips.Select(c => c.TagId))"
                         TagType="TagTypeEnum.Setting"
                         Label="Settings"
                         SelectedTags="@_settingChips"
                         OnSelectionChanged="HandleSettingChange" />
            @foreach (TagChipDto chip in _settingChips.Where(c => c.AllowSettingDetails))
            {
                SettingDetailDto detail = _settingDetailMap.GetValueOrDefault(chip.TagId,
                    new SettingDetailDto { BaseTagId = chip.TagId });
                <SettingEntry Chip="@chip" Detail="@detail"
                              OnChanged="@(d => OnSettingDetailChanged(chip.TagId, d))" />
            }
        </div>

        @* Genres with per-tag priority *@
        <div class="flex flex-col gap-2">
            <TagSelector TagType="TagTypeEnum.Genre"
                         Label="Genres"
                         SelectedTags="@_genreChips"
                         OnSelectionChanged="HandleGenreChange" />
            @foreach (TagChipDto chip in _genreChips)
            {
                TagPriority priority = _genrePriorityMap.GetValueOrDefault(chip.TagId, TagPriority.Primary);
                <div class="flex items-center gap-3 rounded-md border border-(--color-border) bg-(--color-surface) px-3 py-2">
                    <span class="flex-1 text-sm text-(--color-text)">@chip.TagName</span>
                    <label class="text-xs text-(--color-text-muted)">Priority</label>
                    <select value="@priority"
                            @onchange="@(e => HandleGenrePriorityChange(chip.TagId, Enum.Parse<TagPriority>((string)e.Value!)))"
                            class="rounded border border-(--color-border) bg-(--color-surface) px-2 py-1 text-xs text-(--color-text)">
                        <option value="@TagPriority.Primary">Primary</option>
                        <option value="@TagPriority.Supporting">Supporting</option>
                    </select>
                </div>
            }
        </div>

        @* Content Warnings + Crossover Fandoms — flat, no priority UI *@
        <TagSelector TagType="TagTypeEnum.ContentWarning"
                     Label="Content Warnings"
                     SelectedTags="@_cwChips"
                     OnSelectionChanged="HandleCwChange" />
        <TagSelector TagType="TagTypeEnum.CrossoverFandom"
                     Label="Crossover Fandoms"
                     SelectedTags="@_crossoverChips"
                     OnSelectionChanged="HandleCrossoverChange" />
    </div>

    @* ── "Also posted on" external links + original dates (Feature 53 reframe, WU38d) ── *@
    <div class="flex flex-col gap-2">
        <p class="text-sm font-semibold text-(--color-text)">Also posted on</p>
        <p class="text-xs text-(--color-text-muted)">
            If this story is also live on other sites, list the links — they'll show on your story
            page, and a moderator can verify you as the author (✓). Paste the URL; the site is
            detected automatically.
        </p>
        @for (int i = 0; i < ViewModel.ExternalLinks.Count; i++)
        {
            int idx = i;
            StoryExternalLinkEditDto link = ViewModel.ExternalLinks[idx];
            <div class="flex items-center gap-2">
                <input value="@link.Url"
                       @onchange="@(e => HandleLinkUrlChanged(idx, e.Value as string))"
                       placeholder="https://…"
                       class="min-w-0 flex-1 rounded-md border border-(--color-border) bg-(--color-surface) px-3 py-1.5 text-sm text-(--color-text) focus:outline-none focus:ring-2 focus:ring-(--color-action-ink)" />
                <select value="@link.ExternalPlatformId"
                        @onchange="@(e => link.ExternalPlatformId = short.Parse((string)e.Value!))"
                        aria-label="Platform"
                        class="rounded-md border border-(--color-border) bg-(--color-surface) px-2 py-1.5 text-sm text-(--color-text)">
                    @foreach (ExternalPlatformDto platform in ExternalPlatforms)
                    {
                        <option value="@platform.ExternalPlatformId">@platform.Name</option>
                    }
                </select>
                <button type="button" @onclick="() => RemoveExternalLink(idx)" aria-label="Remove link"
                        class="shrink-0 text-(--color-text-muted) hover:text-(--color-danger)">✕</button>
            </div>
        }
        <button type="button" @onclick="AddExternalLink" aria-label="Add external link"
                class="self-start text-sm text-(--color-action-ink) hover:underline">+ Add link</button>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div class="flex flex-col gap-1">
                <label class="text-xs text-(--color-text-muted)">Originally published (elsewhere)</label>
                <InputDate @bind-Value="ViewModel.OriginalPublishedDate"
                           class="rounded-md border border-(--color-border) bg-(--color-surface) px-3 py-1.5 text-sm text-(--color-text)" />
            </div>
            <div class="flex flex-col gap-1">
                <label class="text-xs text-(--color-text-muted)">Original last update</label>
                <InputDate @bind-Value="ViewModel.OriginalLastUpdatedDate"
                           class="rounded-md border border-(--color-border) bg-(--color-surface) px-3 py-1.5 text-sm text-(--color-text)" />
            </div>
        </div>
    </div>

    @* ── Submit ──────────────────────────────────────────────────────────────── *@
    <button type="submit"
            disabled="@ViewModel.IsLoading"
            aria-label="Save story properties"
            class="self-start rounded-md bg-(--color-action) px-5 py-2 font-medium text-(--color-text) transition-colors hover:bg-(--color-action-hover) disabled:opacity-50">
        @(ViewModel.IsLoading ? "Saving…" : SubmitLabel)
    </button>
</EditForm>

@code {
    [Parameter, EditorRequired] public StoryPropertiesViewModel ViewModel { get; set; } = null!;
    [Parameter] public EventCallback OnValidSubmit { get; set; }

    /// <summary>
    /// Pre-populated tag chips per type for edit mode (seeded from GetTagChipsByIdsAsync).
    /// Null = create mode (all selectors start empty). Passed in before first render — not reactive.
    /// </summary>
    [Parameter] public IReadOnlyDictionary<TagTypeEnum, IReadOnlyList<TagChipDto>>? InitialTagsByType { get; set; }

    /// <summary>Structured edit-mode seeds; all null in create mode.</summary>
    [Parameter] public IReadOnlyList<StoryCharacterDto>? InitialCharacters { get; set; }
    [Parameter] public IReadOnlyList<SettingDetailDto>? InitialSettingDetails { get; set; }
    [Parameter] public IReadOnlyList<StoryCharacterPairingDto>? InitialPairings { get; set; }
    [Parameter] public IReadOnlyDictionary<int, TagPriority>? InitialGenrePriorities { get; set; }

    [Parameter] public string SubmitLabel { get; set; } = "Save";

    /// <summary>
    /// Seeded platform lookup for the "Also posted on" section (WU38d) — loaded by the page
    /// (this form stays injection-free). Empty list hides nothing; rows just default to the
    /// first option.
    /// </summary>
    [Parameter] public IReadOnlyList<ExternalPlatformDto> ExternalPlatforms { get; set; } = [];

    private EditorView? _editor;

    // Per-type chip lists (kept in sync with TagSelector OnSelectionChanged)
    private List<TagChipDto> _characterChips = new();
    private List<TagChipDto> _settingChips = new();
    private List<TagChipDto> _genreChips = new();
    private List<TagChipDto> _cwChips = new();
    private List<TagChipDto> _crossoverChips = new();

    // Structured state
    private List<StoryCharacterDto> _characterDtos = new();
    private Dictionary<int, SettingDetailDto> _settingDetailMap = new();
    private Dictionary<int, TagPriority> _genrePriorityMap = new();
    private List<StoryCharacterPairingDto> _pairings = new();

    /// <summary>The most recently selected cover file, or null if none was picked this session.</summary>
    public IBrowserFile? SelectedCoverFile { get; private set; }

    /// <summary>Pull the current editor HTML. Called by the page on submit before building the DTO.</summary>
    public async Task<string> GetLongDescriptionAsync() =>
        _editor is not null ? await _editor.GetHtmlAsync() : string.Empty;

    // Push counterpart for draft restore (DraftAutosave) — Quill ignores later Html parameter
    // changes, so restored content must go through EditorView.SetHtmlAsync.
    public async Task SetLongDescriptionAsync(string html)
    {
        if (_editor is not null) await _editor.SetHtmlAsync(html);
    }

    protected override void OnInitialized()
    {
        if (InitialTagsByType is not null)
        {
            foreach ((TagTypeEnum type, IReadOnlyList<TagChipDto> chips) in InitialTagsByType)
            {
                switch (type)
                {
                    case TagTypeEnum.Character: _characterChips = chips.ToList(); break;
                    case TagTypeEnum.Setting:   _settingChips   = chips.ToList(); break;
                    case TagTypeEnum.Genre:     _genreChips     = chips.ToList(); break;
                    case TagTypeEnum.ContentWarning:  _cwChips       = chips.ToList(); break;
                    case TagTypeEnum.CrossoverFandom: _crossoverChips = chips.ToList(); break;
                }
            }
        }

        if (InitialCharacters is not null)
            _characterDtos = InitialCharacters.ToList();

        if (InitialSettingDetails is not null)
            foreach (SettingDetailDto d in InitialSettingDetails)
                _settingDetailMap[d.BaseTagId] = d;

        // Seed detail map stubs for setting chips that allow details but have no existing detail
        foreach (TagChipDto chip in _settingChips.Where(c => c.AllowSettingDetails))
            _settingDetailMap.TryAdd(chip.TagId, new SettingDetailDto { BaseTagId = chip.TagId });

        if (InitialPairings is not null)
            _pairings = InitialPairings.ToList();

        if (InitialGenrePriorities is not null)
            foreach ((int tagId, TagPriority priority) in InitialGenrePriorities)
                _genrePriorityMap[tagId] = priority;

        RebuildViewModel();
    }

    // ── Character handlers ────────────────────────────────────────────────────

    private void HandleCharacterChange(IReadOnlyList<TagChipDto> chips)
    {
        HashSet<int> newIds = chips.Select(c => c.TagId).ToHashSet();
        _characterChips = chips.ToList();
        _characterDtos.RemoveAll(d => !newIds.Contains(d.CharacterTagId));
        foreach (TagChipDto chip in chips.Where(c => _characterDtos.All(d => d.CharacterTagId != c.TagId)))
            _characterDtos.Add(new StoryCharacterDto { CharacterTagId = chip.TagId });
        // Drop pairings whose member set shrinks below 2 after removal
        _pairings = _pairings
            .Select(p => new StoryCharacterPairingDto
            {
                PairingType = p.PairingType, Priority = p.Priority,
                MemberCharacterTagIds = p.MemberCharacterTagIds.Where(id => newIds.Contains(id)).ToList()
            })
            .Where(p => p.MemberCharacterTagIds.Count >= 2)
            .ToList();
        RebuildViewModel();
    }

    private void OnCharacterDtoChanged(int index, StoryCharacterDto dto)
    {
        _characterDtos[index] = dto;
        RebuildViewModel();
    }

    private void RemoveCharacter(int charTagId)
    {
        _characterDtos.RemoveAll(d => d.CharacterTagId == charTagId);
        _characterChips.RemoveAll(c => c.TagId == charTagId);
        HashSet<int> remaining = _characterChips.Select(c => c.TagId).ToHashSet();
        _pairings = _pairings
            .Select(p => new StoryCharacterPairingDto
            {
                PairingType = p.PairingType, Priority = p.Priority,
                MemberCharacterTagIds = p.MemberCharacterTagIds.Where(id => remaining.Contains(id)).ToList()
            })
            .Where(p => p.MemberCharacterTagIds.Count >= 2)
            .ToList();
        RebuildViewModel();
    }

    // ── Setting handlers ──────────────────────────────────────────────────────

    private void HandleSettingChange(IReadOnlyList<TagChipDto> chips)
    {
        HashSet<int> newIds = chips.Select(c => c.TagId).ToHashSet();
        _settingChips = chips.ToList();
        foreach (int id in _settingDetailMap.Keys.Where(k => !newIds.Contains(k)).ToList())
            _settingDetailMap.Remove(id);
        foreach (TagChipDto chip in chips.Where(c => c.AllowSettingDetails))
            _settingDetailMap.TryAdd(chip.TagId, new SettingDetailDto { BaseTagId = chip.TagId });
        RebuildViewModel();
    }

    private void OnSettingDetailChanged(int tagId, SettingDetailDto detail)
    {
        _settingDetailMap[tagId] = detail;
        RebuildViewModel();
    }

    // ── Genre handlers ────────────────────────────────────────────────────────

    private void HandleGenreChange(IReadOnlyList<TagChipDto> chips)
    {
        HashSet<int> newIds = chips.Select(c => c.TagId).ToHashSet();
        foreach (int id in _genrePriorityMap.Keys.Where(k => !newIds.Contains(k)).ToList())
            _genrePriorityMap.Remove(id);
        _genreChips = chips.ToList();
        RebuildViewModel();
    }

    private void HandleGenrePriorityChange(int tagId, TagPriority priority)
    {
        _genrePriorityMap[tagId] = priority;
        RebuildViewModel();
    }

    // ── CW / Crossover handlers ───────────────────────────────────────────────

    private void HandleCwChange(IReadOnlyList<TagChipDto> chips)       { _cwChips = chips.ToList(); RebuildViewModel(); }
    private void HandleCrossoverChange(IReadOnlyList<TagChipDto> chips) { _crossoverChips = chips.ToList(); RebuildViewModel(); }

    // ── Pairing handler ───────────────────────────────────────────────────────

    private void HandlePairingsChanged(List<StoryCharacterPairingDto> pairings)
    {
        _pairings = pairings;
        RebuildViewModel();
    }

    // ── ViewModel rebuild ─────────────────────────────────────────────────────

    private void RebuildViewModel()
    {
        ViewModel.SelectedCharacters = new List<StoryCharacterDto>(_characterDtos);
        ViewModel.SelectedPairings   = new List<StoryCharacterPairingDto>(_pairings);
        // Only include SettingDetail entries that carry at least one non-null field
        ViewModel.SelectedSettingDetails = _settingDetailMap.Values
            .Where(d => d.Name != null || d.Description != null)
            .ToList();
        ViewModel.SelectedFlatTags =
        [
            .._settingChips.Select(c  => new StoryTagDTO { TagId = c.TagId, TagTypeEnum = TagTypeEnum.Setting, Priority = TagPriority.Primary }),
            .._genreChips.Select(c    => new StoryTagDTO { TagId = c.TagId, TagTypeEnum = TagTypeEnum.Genre, Priority = _genrePriorityMap.GetValueOrDefault(c.TagId, TagPriority.Primary) }),
            .._cwChips.Select(c       => new StoryTagDTO { TagId = c.TagId, TagTypeEnum = TagTypeEnum.ContentWarning, Priority = TagPriority.Primary }),
            .._crossoverChips.Select(c => new StoryTagDTO { TagId = c.TagId, TagTypeEnum = TagTypeEnum.CrossoverFandom, Priority = TagPriority.Primary }),
        ];
    }

    private void HandleCoverSelected(InputFileChangeEventArgs e) =>
        SelectedCoverFile = e.File;

    // ── "Also posted on" link rows (WU38d) ───────────────────────────────────────

    private void AddExternalLink() =>
        ViewModel.ExternalLinks.Add(new StoryExternalLinkEditDto
        {
            // Default to the "Other" row (no DomainPattern) until a URL is pasted and detected.
            ExternalPlatformId = FallbackPlatformId()
        });

    private void RemoveExternalLink(int index) =>
        ViewModel.ExternalLinks.RemoveAt(index);

    /// <summary>
    /// Paste-a-URL auto-detect: match the URL's host against each platform's DomainPattern and
    /// stamp the row's platform. Runs on every URL change (a changed host re-detects); the
    /// dropdown remains manually overridable afterwards.
    /// </summary>
    private void HandleLinkUrlChanged(int index, string? url)
    {
        StoryExternalLinkEditDto link = ViewModel.ExternalLinks[index];
        link.Url = url?.Trim() ?? string.Empty;

        if (Uri.TryCreate(link.Url, UriKind.Absolute, out Uri? uri))
        {
            ExternalPlatformDto? detected = ExternalPlatforms.FirstOrDefault(p =>
                p.DomainPattern is not null &&
                uri.Host.Contains(p.DomainPattern, StringComparison.OrdinalIgnoreCase));
            link.ExternalPlatformId = detected?.ExternalPlatformId ?? FallbackPlatformId();
        }
    }

    /// <summary>The "Other" row (null DomainPattern), or the first platform as a last resort.</summary>
    private short FallbackPlatformId() =>
        ExternalPlatforms.FirstOrDefault(p => p.DomainPattern is null)?.ExternalPlatformId
        ?? ExternalPlatforms.FirstOrDefault()?.ExternalPlatformId
        ?? (short)0;

    private async Task HandleValidSubmit() => await OnValidSubmit.InvokeAsync();
}
