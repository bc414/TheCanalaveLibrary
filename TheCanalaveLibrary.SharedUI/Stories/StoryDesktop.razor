@namespace TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Core

@* Desktop layout for the story landing page (spec §5.28, WU25). Presentational — no @inject.
   Composes: TagChip (tags), RichTextView (long description), ChapterList (chapter selection),
   RecommendationSection (recommendations). Outer Margin Rule: no outer margin on root.
   Author-conditional affordances (Edit Story link, ShowDrafts) gated by IsAuthor;
   server gate in UpdateStoryAsync is the real authority. *@

<article class="mx-auto max-w-3xl px-4 py-8 flex flex-col gap-8">

    @* ── Title + author-only Edit link ───────────────────────────────────────── *@
    <div class="flex items-start justify-between gap-4">
        <h1 class="text-3xl font-bold text-(--color-text) leading-snug">@Story.StoryTitle</h1>
        @if (IsAuthor)
        {
            <a href="/story/@Story.StoryId/edit"
               class="shrink-0 text-sm text-(--color-action-ink) hover:underline">Edit Story</a>
        }
    </div>

    @* ── Metadata row ─────────────────────────────────────────────────────────── *@
    <div class="flex flex-col gap-3">
        @* Author + dates *@
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-(--color-text-muted)">
            @if (Story.AuthorId is not null)
            {
                <a href="/user/@Story.AuthorId"
                   class="text-(--color-action-ink) hover:underline font-medium">@(Story.AuthorName ?? "Unknown")</a>
            }
            else
            {
                <span class="font-medium">@(Story.AuthorName ?? "Unknown")</span>
            }
            <span>·</span>
            <span>Published @Story.PublishDate.ToString("MMM d, yyyy")</span>
            <span>·</span>
            <span>Updated @Story.LastUpdatedDate.ToString("MMM d, yyyy")</span>
        </div>

        @* Status, rating, word count badges *@
        <div class="flex flex-wrap items-center gap-2">
            <span class="@StatusBadgeClass px-2 py-0.5 rounded-full text-xs font-medium">@StatusLabel</span>
            <span class="@RatingBadgeClass px-2 py-0.5 rounded-full text-xs font-medium">@RatingLabel</span>
            <span class="text-xs text-(--color-text-muted)">@WordCountDisplay</span>
        </div>

        @* Per-format download links (Feature 54, WU38c) — plain anchors, bypass the circuit *@
        <StoryDownloadLinks StoryId="@Story.StoryId" />

        @* Interaction panel — Detail context (all six buttons; own-story renders Edit link).
           Mounted in the L4.5 browser pass (2026-07-01): the Detail context existed and was
           bUnit-tested but no page consumed it, leaving Favorite/Follow/Complete unreachable.
           Auth-gated: anonymous viewers get no buttons (the write service would throw). *@
        @if (CurrentUserId is not null)
        {
            <UserStoryInteractionPanel StoryId="@Story.StoryId"
                                       State="@UsiState"
                                       Context="UserStoryInteractionDisplayContext.Detail"
                                       IsOwnStory="@IsAuthor" />
        }

        @* Tag chips — sprite-resolved, read-only (no OnRemove); includes character chips *@
        @if (Story.Tags.Count > 0)
        {
            <div class="flex flex-wrap gap-1.5">
                @foreach (var tag in Story.Tags)
                {
                    <TagChip Tag="@tag" />
                }
            </div>
        }

        @* OC character names — only for characters with authored OC details *@
        @{ var ocChars = Story.Characters.Where(c => c.IsOc && c.OcName != null).ToList(); }
        @if (ocChars.Count > 0)
        {
            <div class="text-sm text-(--color-text-muted)">
                @foreach (var oc in ocChars)
                {
                    <span class="mr-3">
                        <span class="font-medium text-(--color-text)">@oc.OcName</span>
                        <span class="text-xs"> (@oc.Chip.TagName OC)</span>
                    </span>
                }
            </div>
        }

        @* Ships *@
        @if (Story.Pairings.Count > 0)
        {
            <div class="flex flex-wrap gap-2 text-sm">
                @foreach (var pairing in Story.Pairings)
                {
                    <span class="px-2 py-0.5 rounded-full bg-(--color-text-muted)/15 text-(--color-text-muted) ring-1 ring-(--color-text-muted)/30">
                        @pairing.DisplayNames
                    </span>
                }
            </div>
        }

        @* Series membership box(es) — a story may be in more than one series (WU41) *@
        @if (SeriesMemberships.Count > 0)
        {
            <div class="flex flex-col gap-2">
                @foreach (var membership in SeriesMemberships)
                {
                    <SeriesMembershipBox Membership="membership" />
                }
            </div>
        }

        @* Story lineage — Approved outgoing links only (Feature 10, WU42) *@
        <StoryLineageBox Links="LineageLinks" />
    </div>

    @* ── Cover art ────────────────────────────────────────────────────────────── *@
    @if (Story.CoverArtRelativeUrl is not null && !_coverArtFailed)
    {
        <img src="@Story.CoverArtRelativeUrl" alt=""
             class="w-full max-h-80 rounded-xl object-cover object-top"
             loading="lazy" @onerror="HandleCoverArtError" />
    }
    else if (Story.CoverArtRelativeUrl is not null && _coverArtFailed)
    {
        <div class="w-full h-40 rounded-xl bg-(--color-surface-raised) ring-1 ring-(--color-border) flex items-center justify-center">
            <span class="text-5xl text-(--color-text-muted) select-none">
                @(Story.StoryTitle?.Length > 0 ? Story.StoryTitle[0] : '?')
            </span>
        </div>
    }

    @* ── Long description ─────────────────────────────────────────────────────── *@
    @if (!string.IsNullOrWhiteSpace(Story.LongDescription))
    {
        <ContentSurface Variant="ContentSurfaceVariant.Inline">
            <RichTextView HtmlContent="@Story.LongDescription" />
        </ContentSurface>
    }

    @* ── Chapter selection ────────────────────────────────────────────────────── *@
    @if (Chapters.Count > 0 || IsAuthor)
    {
        <section>
            <h2 class="text-lg font-semibold text-(--color-text) mb-2">Chapters</h2>
            <div class="rounded-xl border border-(--color-border) bg-(--color-surface) overflow-hidden">
                <ChapterList Chapters="Chapters" StoryId="Story.StoryId" ShowDrafts="IsAuthor"
                             Arcs="Arcs" ViewerWatermarkUtc="ViewerWatermarkUtc"
                             CanMarkRead="CurrentUserId is not null" />
            </div>
        </section>
    }

    @* ── "Also posted on" (Feature 53/WU38d) — settled placement: after chapters, before recs *@
    <StoryExternalLinksRow Links="@Story.ExternalLinks" />

    @* ── Recommendations ──────────────────────────────────────────────────────── *@
    <section>
        <RecommendationSection StoryId="Story.StoryId"
                               StoryAuthorId="Story.AuthorId"
                               CurrentUserId="CurrentUserId" />
    </section>

</article>

@code {
    [Parameter, EditorRequired] public StoryDetailsDTO Story { get; set; } = null!;
    [Parameter, EditorRequired] public IReadOnlyList<ChapterListEntryDto> Chapters { get; set; } = [];
    [Parameter] public int? CurrentUserId { get; set; }
    [Parameter] public bool IsAuthor { get; set; }

    /// <summary>The story's arcs in reading order (WU45; empty for the ~95% no-arc case).</summary>
    [Parameter] public IReadOnlyList<StoryArcDto> Arcs { get; set; } = [];

    /// <summary>Viewer's New-badge watermark (WU45; null = anonymous/first visit).</summary>
    [Parameter] public DateTime? ViewerWatermarkUtc { get; set; }

    /// <summary>Viewer's interaction state, loaded by StoryPage (null = anonymous/all-false).</summary>
    [Parameter] public UserStoryInteractionStateDto? UsiState { get; set; }

    /// <summary>Series this story belongs to (WU41) — a story may be in more than one.</summary>
    [Parameter] public IReadOnlyList<StorySeriesMembershipDto> SeriesMemberships { get; set; } = [];

    /// <summary>Approved outgoing lineage links (Feature 10, WU42).</summary>
    [Parameter] public IReadOnlyList<StoryLineageDto> LineageLinks { get; set; } = [];

    private bool _coverArtFailed;

    private void HandleCoverArtError() => _coverArtFailed = true;

    // ── Computed display properties (mirrors StoryCard pattern) ─────────────────

    private string WordCountDisplay => Story.WordCount switch
    {
        < 1_000     => $"{Story.WordCount} words",
        < 1_000_000 => $"{Story.WordCount / 1000.0:F0}K words",
        _           => $"{Story.WordCount / 1_000_000.0:F1}M words"
    };

    private string StatusLabel => Story.Status switch
    {
        StoryStatusEnum.Draft           => "Draft",
        StoryStatusEnum.PendingApproval => "Pending Approval",
        StoryStatusEnum.InProgress      => "In Progress",
        StoryStatusEnum.Completed       => "Complete",
        StoryStatusEnum.OnHiatus        => "On Hiatus",
        StoryStatusEnum.Cancelled       => "Cancelled",
        StoryStatusEnum.Rewriting       => "Rewriting",
        StoryStatusEnum.OpenBeta        => "Open Beta",
        StoryStatusEnum.Rejected        => "Rejected",
        _                               => "Unknown"
    };

    private string StatusBadgeClass => StatusBadges.ForStatus(Story.Status);

    private string RatingLabel => Story.Rating switch
    {
        Rating.E => "Everyone",
        Rating.T => "Teen",
        Rating.M => "Mature",
        _        => "Unknown"
    };

    private string RatingBadgeClass => StatusBadges.ForRating(Story.Rating);
}
