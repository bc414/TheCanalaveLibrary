@namespace TheCanalaveLibrary.SharedUI

@* Leaf — one message in a conversation thread.
   NO chat bubbles (ratified 2026-07-10, layer4-style.md "Element Roles"): the body is Content
   Surface like all UGC. Authorship is signaled by layout only — own messages right-aligned,
   the other party left-aligned, each side carrying its avatar + name (Container metadata).
   MessageText is stored sanitized HTML (sanitize-once-on-save) — rendered via RichTextView.
   No service injection. *@

<div class="flex @(Message.IsOwnMessage ? "flex-row-reverse" : "flex-row") items-start gap-2">
    <img src="@Message.SenderAvatarUrl"
         alt="@Message.SenderUsername"
         class="h-8 w-8 flex-none rounded-full object-cover"
         data-fallback-src="/img/default-avatar.svg" />

    <div class="max-w-[75%] @(Message.IsOwnMessage ? "items-end" : "items-start") flex flex-col gap-0.5">
        <span class="text-xs font-medium text-(--color-text-muted)">
            @Message.SenderUsername
        </span>

        <ContentSurface Variant="ContentSurfaceVariant.Inline">
            <RichTextView HtmlContent="@Message.MessageText" />
        </ContentSurface>

        <time class="text-xs text-(--color-text-muted)"
              datetime="@Message.DateSent.ToString("O")">
            @Message.DateSent.ToString("MMM d, yyyy h:mm tt")
        </time>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public MessageDto Message { get; set; } = null!;
}
