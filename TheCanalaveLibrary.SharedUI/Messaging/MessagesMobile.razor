@namespace TheCanalaveLibrary.SharedUI

@* Injection-free layout for the messages page on mobile.
   Single-pane: conversation list when no thread is active; thread view (with back button)
   when a conversation is selected. Same parameter contract as MessagesDesktop. *@

@if (Thread is null)
{
    @* ── List view ── *@
    <div class="flex flex-col">
        <div class="flex items-center justify-between border-b border-(--color-border) px-4 py-3">
            <h1 class="inline-block rounded-md border border-(--color-border) bg-(--color-surface-raised) px-4 py-1.5 font-display text-xl font-semibold text-(--color-text)">Messages</h1>
            <button type="button"
                    class="rounded-md bg-(--color-mission) px-2.5 py-1 text-xs font-medium text-white hover:bg-(--color-mission-hover)"
                    @onclick="() => OnNewConversation.InvokeAsync()">
                New
            </button>
        </div>

        <div class="flex flex-col gap-2 p-2">
            @if (Conversations.Count == 0)
            {
                <p class="mt-4 text-center text-sm text-(--color-text-muted)">
                    No conversations yet.
                </p>
            }
            else
            {
                @foreach (var conv in Conversations)
                {
                    <ConversationListItem Conversation="@conv"
                                         IsSelected="@(conv.ConversationId == SelectedConversationId)" />
                }
            }
        </div>
    </div>
}
else
{
    @* ── Thread view ── *@
    <div class="flex h-[calc(100dvh-4rem)] flex-col overflow-hidden">
        <div class="flex items-center gap-3 border-b border-(--color-border) px-4 py-3">
            <a href="/messages"
               class="flex items-center gap-1 text-sm font-medium text-(--color-action-ink) hover:underline">
                <svg viewBox="0 0 24 24" class="size-4" aria-hidden="true"
                     fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                </svg>
                Back
            </a>
        </div>
        <div class="flex flex-1 flex-col overflow-hidden">
            <MessageThread Thread="Thread"
                           OnSendReply="OnSendReply"
                           OnLoadOlderMessages="OnLoadOlderMessages"
                           BusySending="BusySendReply"
                           BusyLoading="BusyLoadOlder"
                           ErrorMessage="@ReplyError" />
        </div>
    </div>
}

@* Compose modal renders as a fixed overlay. *@
<ComposeConversationModal IsOpen="ComposeIsOpen"
                          RecipientPreset="ComposePreset"
                          OnSubmit="OnSubmitCompose"
                          OnCancel="OnCancelCompose"
                          Busy="ComposeBusy"
                          ErrorMessage="@ComposeError" />

@code {
    // ── Data ──────────────────────────────────────────────────────────────────

    [Parameter] public IReadOnlyList<ConversationSummaryDto> Conversations { get; set; } = [];
    [Parameter] public int? SelectedConversationId { get; set; }

    /// <summary>
    /// Current thread — null shows the list view; non-null shows the thread view.
    /// Messages must be newest-first so flex-col-reverse renders newest at bottom.
    /// </summary>
    [Parameter] public ConversationThreadDto? Thread { get; set; }

    // ── Busy / error state ────────────────────────────────────────────────────

    [Parameter] public bool BusySendReply { get; set; }
    [Parameter] public bool BusyLoadOlder { get; set; }
    [Parameter] public string? ReplyError { get; set; }

    // ── Compose modal ─────────────────────────────────────────────────────────

    [Parameter] public bool ComposeIsOpen { get; set; }
    [Parameter] public MessagingParticipantDto? ComposePreset { get; set; }
    [Parameter] public bool ComposeBusy { get; set; }
    [Parameter] public string? ComposeError { get; set; }

    // ── Callbacks ─────────────────────────────────────────────────────────────

    [Parameter] public EventCallback<string> OnSendReply { get; set; }
    [Parameter] public EventCallback OnLoadOlderMessages { get; set; }
    [Parameter] public EventCallback OnNewConversation { get; set; }
    [Parameter] public EventCallback OnCancelCompose { get; set; }
    [Parameter] public EventCallback<(string RecipientUsername, string Subject, string MessageHtml)> OnSubmitCompose { get; set; }
}
