@namespace TheCanalaveLibrary.SharedUI

@* Coordination composite — the right-hand pane: conversation header, paged message list,
   and the reply composer. Injection-free; the owning page holds the write service and
   handles OnSendReply and OnLoadOlderMessages.

   Message ordering: Thread.Messages is expected newest-first ([newest,...,oldest]).
   Combined with flex-col-reverse on the scroll container, the browser renders newest
   at the bottom — the natural chat convention. The owning page stores _allMessages
   in newest-first order and prepends sent messages at index 0 (they appear at bottom). *@

@if (Thread is null)
{
    <div class="flex h-full items-center justify-center text-(--color-text-muted)">
        <p>Select a conversation to read it.</p>
    </div>
}
else
{
    <div class="flex h-full flex-col">
        @* Header *@
        <div class="flex items-center gap-3 border-b border-(--color-border) px-4 py-3">
            <img src="@Thread.OtherParticipant.AvatarUrl"
                 alt="@Thread.OtherParticipant.Username"
                 class="h-9 w-9 rounded-full object-cover"
                 onerror="this.src='/img/default-avatar.svg'" />
            <div class="min-w-0">
                <p class="truncate text-sm font-semibold text-(--color-text)">
                    @Thread.OtherParticipant.Username
                </p>
                <p class="truncate text-xs text-(--color-text-muted)">
                    @Thread.Subject
                </p>
            </div>
        </div>

        @* "Load older" sits above the scroll container so it isn't caught by flex-col-reverse *@
        @if (Thread.TotalMessageCount > Thread.Messages.Count)
        {
            <div class="flex justify-center border-b border-(--color-border) py-2">
                <button type="button"
                        class="text-sm text-(--color-primary) hover:underline disabled:opacity-50"
                        disabled="@BusyLoading"
                        @onclick="() => OnLoadOlderMessages.InvokeAsync()">
                    @if (BusyLoading)
                    {
                        <span>Loading…</span>
                    }
                    else
                    {
                        <span>Load older messages (@(Thread.TotalMessageCount - Thread.Messages.Count) more)</span>
                    }
                </button>
            </div>
        }

        @* Messages — flex-col-reverse renders first child at bottom, so newest-first list
           appears with newest at bottom and oldest at top. *@
        <div class="flex flex-1 flex-col-reverse overflow-y-auto px-4 py-3 gap-4">
            @foreach (var msg in Thread.Messages)
            {
                <MessageItem Message="@msg" />
            }
        </div>

        @* Reply composer *@
        <div class="border-t border-(--color-border) px-4 py-3">
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <p class="mb-2 text-sm text-red-600" role="alert">@ErrorMessage</p>
            }
            <MessageComposer OnSend="OnSendReply"
                             SendLabel="Send Reply"
                             Busy="@BusySending" />
        </div>
    </div>
}

@code {
    /// <summary>
    /// The current thread data. Messages should be newest-first for correct flex-col-reverse
    /// rendering. When null, a "no conversation selected" placeholder is shown.
    /// </summary>
    [Parameter] public ConversationThreadDto? Thread { get; set; }

    /// <summary>Raised when the user submits a reply. Raw HTML from EditorView.</summary>
    [Parameter] public EventCallback<string> OnSendReply { get; set; }

    /// <summary>Raised when the user clicks "Load older messages".</summary>
    [Parameter] public EventCallback OnLoadOlderMessages { get; set; }

    /// <summary>Shows a spinner on the Send button while a reply is being posted.</summary>
    [Parameter] public bool BusySending { get; set; }

    /// <summary>Shows a spinner on the "Load older" button while fetching.</summary>
    [Parameter] public bool BusyLoading { get; set; }

    /// <summary>Shown above the composer when a send or load fails.</summary>
    [Parameter] public string? ErrorMessage { get; set; }
}
