@namespace TheCanalaveLibrary.SharedUI

@* Leaf — message compose box wrapping EditorView (pull-on-submit via @ref + GetHtmlAsync()).
   No service injection; the owning page/composite sanitizes and persists via the write service.
   The Send button carries a distinct aria-label because this component wraps EditorView (whose
   own toolbar also renders buttons in the same subtree) — required for bUnit selector collision-
   free tests (testing.md "EditorView wrapping" rule). *@

<div class="flex flex-col gap-3">
    <EditorView @ref="_editor" Html="@Html" Placeholder="@Placeholder" />

    <div class="flex items-center gap-2">
        <button type="button"
                class="rounded-md bg-[--color-primary] px-3 py-1.5 text-sm font-medium text-white transition-colors hover:bg-[--color-primary-strong] disabled:opacity-50"
                disabled="@Busy"
                aria-label="@SendLabel"
                @onclick="HandleSendAsync">
            @SendLabel
        </button>

        @if (OnCancel.HasDelegate)
        {
            <button type="button"
                    class="rounded-md border border-[--color-border] bg-[--color-surface] px-3 py-1.5 text-sm text-[--color-text] transition-colors hover:bg-[--color-primary]/20 disabled:opacity-50"
                    disabled="@Busy"
                    aria-label="Cancel"
                    @onclick="() => OnCancel.InvokeAsync()">
                Cancel
            </button>
        }
    </div>
</div>

@code {
    /// <summary>Seed HTML for editing or replying to a draft. Null/empty for a fresh compose.</summary>
    [Parameter] public string? Html { get; set; }

    /// <summary>Placeholder text shown in the empty editor.</summary>
    [Parameter] public string Placeholder { get; set; } = "Write your message…";

    /// <summary>Primary button label. Defaults to "Send".</summary>
    [Parameter] public string SendLabel { get; set; } = "Send";

    /// <summary>
    /// Raised with the raw editor HTML when the user clicks Send.
    /// The owning page/composite passes this to the write service, which sanitizes before persisting.
    /// </summary>
    [Parameter] public EventCallback<string> OnSend { get; set; }

    /// <summary>When wired, a Cancel button appears beside Send.</summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    /// <summary>Disables both buttons while the owning composite is performing a write.</summary>
    [Parameter] public bool Busy { get; set; }

    private EditorView? _editor;

    private async Task HandleSendAsync()
    {
        if (_editor is null) return;
        string html = await _editor.GetHtmlAsync();
        await OnSend.InvokeAsync(html);
    }
}
