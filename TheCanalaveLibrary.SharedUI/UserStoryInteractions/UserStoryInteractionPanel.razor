@namespace TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Core
@using Microsoft.Extensions.Logging
@inject IUserStoryInteractionWriteService WriteService
@inject ILogger<UserStoryInteractionPanel> Logger
@implements IAsyncDisposable

@* Coordination composite (layer3-logic.md "Self-contained writes"; layer3.5-structure.md example).
   Owns the 2-second debounce across the six UserStoryInteractionButton leaves. State flows in from
   the parent (batch-loaded via GetStatesByStoryIdsAsync or single GetStateAsync) — this component
   does NOT inject the read service (N+1 rule). Null State is treated as all-false.
   IsOwnStory true renders an Edit link instead of buttons per spec §5.30.5.
   Button order = UserStoryInteractionTypeEnum declaration order (Favorite → PrivateFavorite → Follow →
   Complete → ReadLater → Ignore) per the locked audit table (2026-06-22). *@

<div class="flex items-center gap-2">
    @if (IsOwnStory)
    {
        <a href="/story/@StoryId/edit">Edit Story</a>
    }
    else
    {
        @foreach (var loopType in Enum.GetValues<UserStoryInteractionTypeEnum>())
        {
            var type = loopType;
            var visuals = UserStoryInteractionVisuals.For(type);
            bool isActive = GetIsActive(type);

            if (Context == UserStoryInteractionDisplayContext.Detail || ListingShouldShow(type, isActive))
            {
                <UserStoryInteractionButton IsActive="@isActive"
                    OnToggle="@(IsClickable(type) ? MakeToggleCallback(type) : default)"
                    IconPath="@visuals.IconPath"
                    AccentColor="@visuals.AccentColor"
                    Label="@visuals.Label" />
            }
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public int StoryId { get; set; }
    [Parameter] public UserStoryInteractionStateDto? State { get; set; }
    [Parameter] public UserStoryInteractionDisplayContext Context { get; set; }
    [Parameter] public bool IsOwnStory { get; set; }

    private UserStoryInteractionStateDto? _localState;
    private CancellationTokenSource? _debounce;
    private bool _flushPending;

    protected override void OnParametersSet()
    {
        if (_localState is null)
            _localState = State;
    }

    private bool GetIsActive(UserStoryInteractionTypeEnum type) => type switch
    {
        UserStoryInteractionTypeEnum.Favorite => _localState?.IsFavorite ?? false,
        UserStoryInteractionTypeEnum.PrivateFavorite => _localState?.IsHiddenFavorite ?? false,
        UserStoryInteractionTypeEnum.Follow => _localState?.IsFollowed ?? false,
        UserStoryInteractionTypeEnum.Complete => _localState?.IsCompleted ?? false,
        UserStoryInteractionTypeEnum.ReadLater => _localState?.IsReadItLater ?? false,
        UserStoryInteractionTypeEnum.Ignore => _localState?.IsIgnored ?? false,
        _ => false
    };

    private bool IsClickable(UserStoryInteractionTypeEnum type) =>
        Context == UserStoryInteractionDisplayContext.Detail ||
        type is UserStoryInteractionTypeEnum.ReadLater or UserStoryInteractionTypeEnum.Ignore;

    private bool IsBlankSlate
    {
        get
        {
            bool activelyReading = (_localState?.HasStarted ?? false)
                && !(_localState?.IsCompleted ?? false)
                && !(_localState?.IsIgnored ?? false);
            return !(_localState?.IsFavorite ?? false)
                && !(_localState?.IsHiddenFavorite ?? false)
                && !(_localState?.IsFollowed ?? false)
                && !(_localState?.IsCompleted ?? false)
                && !activelyReading;
        }
    }

    private bool ListingShouldShow(UserStoryInteractionTypeEnum type, bool isActive)
    {
        if (type is UserStoryInteractionTypeEnum.ReadLater or UserStoryInteractionTypeEnum.Ignore)
            return IsBlankSlate || isActive;
        return true; // leaf renders as read-only and only when active; no extra gate needed here
    }

    private EventCallback<bool> MakeToggleCallback(UserStoryInteractionTypeEnum type) =>
        EventCallback.Factory.Create<bool>(this, (bool v) => HandleToggleAsync(type, v));

    private async Task HandleToggleAsync(UserStoryInteractionTypeEnum type, bool newValue)
    {
        var current = _localState ?? UserStoryInteractionStateDto.AllFalse(StoryId);
        _localState = ApplyToggle(current, type, newValue);
        StateHasChanged();

        _flushPending = true;
        _debounce?.Cancel();
        _debounce?.Dispose();
        _debounce = new CancellationTokenSource();
        var token = _debounce.Token;

        try
        {
            await Task.Delay(UserStoryInteractionConstants.UserStoryInteractionDebounceMs, token);
            await FlushAsync();
            _flushPending = false;
        }
        catch (OperationCanceledException)
        {
            // Debounce reset by a subsequent toggle (next HandleToggleAsync fires the flush) or
            // by disposal (DisposeAsync fires it — _flushPending stays true until a flush lands).
        }
    }

    private async Task FlushAsync()
    {
        var state = _localState ?? UserStoryInteractionStateDto.AllFalse(StoryId);
        await WriteService.SetUserStoryInteractionStateAsync(StoryId, new UserStoryInteractionStateUpdate(
            IsFavorite: state.IsFavorite,
            IsHiddenFavorite: state.IsHiddenFavorite,
            IsFollowed: state.IsFollowed,
            IsCompleted: state.IsCompleted,
            IsReadItLater: state.IsReadItLater,
            IsIgnored: state.IsIgnored));
    }

    private static UserStoryInteractionStateDto ApplyToggle(
        UserStoryInteractionStateDto current, UserStoryInteractionTypeEnum type, bool value) =>
        type switch
        {
            UserStoryInteractionTypeEnum.Favorite => current with { IsFavorite = value },
            UserStoryInteractionTypeEnum.PrivateFavorite => current with { IsHiddenFavorite = value },
            UserStoryInteractionTypeEnum.Follow => current with { IsFollowed = value },
            UserStoryInteractionTypeEnum.Complete => current with { IsCompleted = value },
            UserStoryInteractionTypeEnum.ReadLater => current with { IsReadItLater = value },
            UserStoryInteractionTypeEnum.Ignore => current with { IsIgnored = value },
            _ => current
        };

    public async ValueTask DisposeAsync()
    {
        _debounce?.Cancel();
        _debounce?.Dispose();

        // Flush-on-dispose: a toggle inside the debounce window is durable user intent (axiom 7 —
        // "durable-direct for intent"); toggle-then-navigate-away must not silently drop the write
        // (MA-401). The write is an absolute-state set, so racing an in-flight flush is idempotent.
        if (_flushPending)
        {
            _flushPending = false;
            try
            {
                await FlushAsync();
            }
            catch (Exception ex)
            {
                // Disposal must never throw (circuit teardown); the loss is logged, not silent.
                Logger.LogWarning(ex,
                    "Flush-on-dispose of a pending interaction write failed for story {StoryId}", StoryId);
            }
        }
    }
}
