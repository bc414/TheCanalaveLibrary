@namespace TheCanalaveLibrary.SharedUI

@* Coordination composite — mobile Bookshelves layout (spec §5.15, layer3.5-structure.md).
   Mobile: <details> tab dropdown (ChapterNavigation idiom) + filter button below it;
   filter button opens ResultsFilterPanel as an inline backdrop overlay;
   StoryDeck fills full width. Injection-free — all data arrives as parameters.
   Outer Margin Rule: root has no m-*; parent/layout controls spacing. *@

<div class="flex flex-col gap-4 px-3 py-4">

    @* ── Tab dropdown + filter row ───────────────────────────────────────────────────── *@
    <div class="flex items-center gap-2">

        @* Tab selector — <details>/<summary> CSS disclosure (no JS state, all links in DOM) *@
        <details class="relative flex-1">
            @{
                var activeInfo = BookshelfTabVisuals.For(Tab);
            }
            <summary class="flex cursor-pointer list-none items-center gap-2 rounded-md border border-(--color-border) bg-(--color-surface-raised) px-3 py-2 text-sm transition-colors hover:bg-(--color-surface-hover)"
                     style="color:@activeInfo.AccentColor">
                <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24"
                     style="fill:@activeInfo.AccentColor" aria-hidden="true">
                    <path d="@activeInfo.IconPath" />
                </svg>
                <span class="flex-1 font-medium">@activeInfo.Label</span>
                <span aria-hidden="true" class="text-(--color-text-muted)">&#9662;</span>
            </summary>
            <div class="absolute left-0 top-full z-20 mt-1 w-full overflow-hidden rounded-md border border-(--color-border) bg-(--color-surface) shadow-md">
                @foreach (BookshelfTab tab in BookshelfTabVisuals.AllTabs)
                {
                    var info = BookshelfTabVisuals.For(tab);
                    bool isActive = tab == Tab;
                    <a href="/bookshelves/@info.Slug"
                       class="@DropdownEntryClasses(isActive)"
                       style="@(isActive ? $"color:{info.AccentColor};" : "")"
                       aria-current="@(isActive ? "page" : null)">
                        <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24"
                             style="fill:@(isActive ? info.AccentColor : "currentColor")" aria-hidden="true">
                            <path d="@info.IconPath" />
                        </svg>
                        <span>@info.Label</span>
                    </a>
                }
            </div>
        </details>

        @* Filter toggle button *@
        <button type="button"
                class="flex items-center gap-1.5 rounded-md border border-(--color-border) bg-(--color-surface-raised) px-3 py-2 text-sm transition-colors hover:bg-(--color-surface-hover)"
                @onclick="ToggleFilter"
                aria-expanded="@_filterOpen"
                aria-controls="mobile-filter-overlay">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M4 6h16v2H4zm3 5h10v2H7zm3 5h4v2h-4z" />
            </svg>
            Filters
        </button>
    </div>

    @* ── Full-width StoryDeck ─────────────────────────────────────────────────────────── *@
    <StoryDeck Stories="@Items"
               UserStoryInteractionStates="@InteractionStates"
               CurrentUserId="@CurrentUserId"
               EmptyMessage="@EmptyMessage"
               CurrentPage="@Filter.Page"
               PageSize="@Filter.PageSize"
               TotalCount="@TotalCount"
               OnPageChanged="@OnPageChanged"
               OnReport="@(id => _reportDialog.OpenAsync(ReportedEntityType.Story, id))" />
    <ReportDialog @ref="_reportDialog" />

</div>

@* ── Filter overlay — renders nothing when closed ───────────────────────────────────── *@
@if (_filterOpen)
{
    @* Backdrop — click closes the panel *@
    <div class="fixed inset-0 z-50 bg-black/50" @onclick="CloseFilter" id="mobile-filter-overlay"></div>

    @* Slide-in panel — stopPropagation prevents backdrop from receiving the click *@
    <div class="fixed inset-y-0 right-0 z-50 flex w-full max-w-sm flex-col bg-(--color-surface) shadow-xl"
         @onclick:stopPropagation="true">
        <div class="flex items-center justify-between border-b border-(--color-border) px-4 py-3">
            <h2 class="text-sm font-bold">Filters</h2>
            <button type="button"
                    class="rounded p-1 text-(--color-text-muted) hover:bg-(--color-surface-hover)"
                    @onclick="CloseFilter"
                    aria-label="Close filters">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                </svg>
            </button>
        </div>
        <div class="overflow-y-auto p-4">
            <ResultsFilterPanel OnSearch="@HandleFilterAndClose"
                                InitialFilter="@Filter"
                                AvailableSorts="@_availableSorts"
                                ShowTextSearch="true"
                                ShowTagFilter="true"
                                ShowInteractionFilters="false" />
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public BookshelfTab Tab { get; set; }
    [Parameter] public int? CurrentUserId { get; set; }
    [Parameter, EditorRequired] public StoryListingDto[] Items { get; set; } = [];
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public IReadOnlyDictionary<int, UserStoryInteractionStateDto>? InteractionStates { get; set; }
    [Parameter, EditorRequired] public StoryFilterDto Filter { get; set; } = new();
    [Parameter] public EventCallback<StoryFilterDto> OnFilterChanged { get; set; }
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }

    private ReportDialog _reportDialog = default!;
    private bool _filterOpen;

    // Actively Reading additionally offers the viewer-relative "Recently read" sort (its default).
    private IReadOnlyList<DefaultSortOrder> _availableSorts => Tab == BookshelfTab.ActivelyReading
        ? [DefaultSortOrder.RecentlyRead, DefaultSortOrder.DatePublished, DefaultSortOrder.Random, DefaultSortOrder.Relevance]
        : [DefaultSortOrder.DatePublished, DefaultSortOrder.Random, DefaultSortOrder.Relevance];

    private string EmptyMessage => $"No stories in {BookshelfTabVisuals.For(Tab).Label}.";

    private void ToggleFilter() => _filterOpen = !_filterOpen;
    private void CloseFilter() => _filterOpen = false;

    private async Task HandleFilterAndClose(StoryFilterDto filter)
    {
        _filterOpen = false;
        await OnFilterChanged.InvokeAsync(filter);
    }

    private static string DropdownEntryClasses(bool isActive) =>
        "flex items-center gap-2 px-3 py-2 text-sm " +
        (isActive
            ? "bg-(--color-surface-hover) font-semibold"
            : "text-(--color-text) hover:bg-(--color-surface-hover)");
}
