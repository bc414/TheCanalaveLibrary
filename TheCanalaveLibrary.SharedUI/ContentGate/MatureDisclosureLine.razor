@namespace TheCanalaveLibrary.SharedUI

@* The mature count-line disclosure (Feature 66, WU-AccessGate; content-safety.md §"Person/
   collection-scoped listings"). Rendered on listings scoped to a person or collection (profile
   tabs, public custom lists, group story sections, series pages) when the viewer's ceiling hid K
   mature stories: "K mature stories aren't shown · show them". Expanding swaps in MINIMAL gated
   cards — title/author/[M] only, no cover, no description — each linking to the story page,
   where the full interstitial handles consent (two-step, settled 2026-07-19). Renders nothing at
   K = 0. Global Discovery surfaces never use this component. *@

@if (Items.Count > 0)
{
    <div class="flex flex-col gap-2 rounded-md border border-(--color-border) bg-(--color-surface-raised) px-3 py-2">
        <div class="flex flex-wrap items-center gap-2 text-sm text-(--color-text-muted)">
            <span>@Items.Count mature @(Items.Count == 1 ? "story isn't" : "stories aren't") shown</span>
            <span aria-hidden="true">·</span>
            <button type="button"
                    class="text-(--color-action-ink) hover:underline"
                    @onclick="() => _expanded = !_expanded">
                @(_expanded ? "hide them" : "show them")
            </button>
        </div>
        @if (_expanded)
        {
            <ul class="flex flex-col gap-1.5">
                @foreach (GatedMetadataDto item in Items)
                {
                    <li class="flex flex-wrap items-center gap-2 text-sm">
                        <span class="rounded bg-(--color-surface) px-1.5 py-0.5 text-xs font-semibold text-(--color-text-muted) ring-1 ring-(--color-border)">M</span>
                        <a href="@($"/story/{item.RevealTargetId}")" class="text-(--color-action-ink) hover:underline">@item.Title</a>
                        @if (!string.IsNullOrEmpty(item.AuthorName))
                        {
                            <span class="text-(--color-text-muted)">by @item.AuthorName</span>
                        }
                    </li>
                }
            </ul>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public IReadOnlyList<GatedMetadataDto> Items { get; set; } = [];

    private bool _expanded;
}
