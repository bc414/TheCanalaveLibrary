@namespace TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Core

@* Mobile composite for the group detail page — stacked, single-column layout.
   No @inject — all data and callbacks from GroupPage (the dispatcher).
   WU32. *@

<div class="flex flex-col gap-6 px-4 py-6">

    @* ── Group header ─────────────────────────────────────────────────────────── *@
    <div class="flex flex-col gap-2">
        <div class="flex flex-wrap items-center gap-2">
            <h1 class="text-2xl font-bold text-(--color-text)">@Group.GroupName</h1>
            <span class="@AudienceBadgeClasses(Group.AudienceType) rounded px-1.5 py-0.5 text-xs font-medium ring-1">
                @AudienceBadgeLabel(Group.AudienceType)
            </span>
        </div>
        <div class="flex flex-wrap items-center gap-x-2 gap-y-0.5 text-xs text-(--color-text-muted)">
            <span>@Group.MemberCount @(Group.MemberCount == 1 ? "member" : "members")</span>
            <span>·</span>
            <span>@Group.DateCreated.ToString("MMM d, yyyy")</span>
        </div>
        @if (!string.IsNullOrWhiteSpace(Group.Description))
        {
            <p class="text-sm text-(--color-text) leading-relaxed">@Group.Description</p>
        }
    </div>

    @* ── Membership controls ──────────────────────────────────────────────────── *@
    @if (CurrentUserId is not null)
    {
        <div class="flex items-center gap-3">
            @if (CurrentUserRole is null)
            {
                <button type="button" @onclick="OnJoin"
                        class="rounded-md bg-(--color-action) px-4 py-2 text-sm font-medium text-(--color-text) transition-colors hover:bg-(--color-action-hover)">
                    Join Group
                </button>
            }
            else
            {
                <span class="text-sm text-(--color-text-muted)">
                    @(CurrentUserRole == GroupRole.Admin ? "Admin" : "Member")
                </span>
                <button type="button" @onclick="OnLeave"
                        class="rounded-md border border-(--color-border) bg-(--color-surface) px-4 py-2 text-sm font-medium text-(--color-text)">
                    Leave
                </button>
                @if (CurrentUserRole == GroupRole.Admin)
                {
                    <a href="/group/@Group.GroupId/edit"
                       class="text-sm text-(--color-action-ink) hover:underline">Edit</a>
                }
            }
        </div>
    }

    @* ── Stories ──────────────────────────────────────────────────────────────── *@
    <section class="flex flex-col gap-3">
        <div class="flex items-center justify-between">
            <h2 class="text-base font-semibold text-(--color-text)">Stories</h2>
            @if (CurrentUserRole is not null)
            {
                <button type="button" @onclick="ToggleAddStory"
                        class="text-sm text-(--color-action-ink) hover:underline">
                    @(_showAddStory ? "Cancel" : "+ Add")
                </button>
            }
        </div>

        @if (_showAddStory)
        {
            <div class="rounded-lg border border-(--color-border) bg-(--color-surface) p-3 flex flex-col gap-2">
                <input type="number" @bind="_addStoryId" placeholder="Story ID"
                       class="rounded-md border border-(--color-border) bg-(--color-surface) px-3 py-2 text-sm text-(--color-text) focus:outline-none focus:ring-2 focus:ring-(--color-action-ink)" />
                @if (_addStoryError is not null)
                {
                    <p class="text-xs text-(--color-danger)">@_addStoryError</p>
                }
                <button type="button" @onclick="HandleAddStoryAsync"
                        disabled="@(_addStoryId is null)"
                        class="rounded-md bg-(--color-action) px-3 py-1.5 text-sm font-medium text-(--color-text) transition-colors hover:bg-(--color-action-hover) disabled:opacity-50">
                    Add Story
                </button>
            </div>
        }

        <StoryDeck Stories="Stories"
                   UserStoryInteractionStates="InteractionStates"
                   CurrentUserId="CurrentUserId"
                   EmptyMessage="No stories in this group yet."
                   OnReport="@(id => _reportDialog.OpenAsync(ReportedEntityType.Story, id))" />
        <ReportDialog @ref="_reportDialog" />
    </section>

    @* ── Folder tree (collapsed by default on mobile) ────────────────────────── *@
    @if (Group.FolderTree.Count > 0)
    {
        <section class="flex flex-col gap-2">
            <button type="button" @onclick="() => _showFolders = !_showFolders"
                    class="flex items-center justify-between w-full text-base font-semibold text-(--color-text)">
                <span>Folders</span>
                <span class="text-xs text-(--color-text-muted)">@(_showFolders ? "▲" : "▼")</span>
            </button>
            @if (_showFolders)
            {
                <div class="rounded-lg border border-(--color-border) bg-(--color-surface) p-3">
                    @RenderFolders(Group.FolderTree)
                </div>
            }
        </section>
    }

    @* ── Blog posts ───────────────────────────────────────────────────────────── *@
    <section class="flex flex-col gap-3">
        <div class="flex items-center justify-between">
            <h2 class="text-base font-semibold text-(--color-text)">Blog Posts</h2>
            @if (CurrentUserRole is not null)
            {
                <a href="/group/@Group.GroupId/blog/new"
                   class="text-sm text-(--color-action-ink) hover:underline">+ New Post</a>
            }
        </div>
        @if (BlogPosts.Length == 0)
        {
            <p class="text-sm text-(--color-text-muted)">No blog posts yet.</p>
        }
        else
        {
            <div class="flex flex-col gap-3">
                @foreach (BlogPostListingDto post in BlogPosts)
                {
                    <BlogPostCard Post="post" />
                }
            </div>
        }
    </section>

    @* ── Comments ─────────────────────────────────────────────────────────────── *@
    <section class="flex flex-col gap-3">
        <h2 class="text-base font-semibold text-(--color-text)">Comments</h2>
        <CanalaveErrorBoundary Label="comments" Compact="true">
            <CommentSection GroupId="@((int?)Group.GroupId)" CurrentUserId="CurrentUserId" />
        </CanalaveErrorBoundary>
    </section>

</div>

@code {
    [Parameter, EditorRequired] public GroupDetailDto Group { get; set; } = null!;
    [Parameter] public int? CurrentUserId { get; set; }
    [Parameter] public GroupRole? CurrentUserRole { get; set; }
    [Parameter, EditorRequired] public StoryListingDto[] Stories { get; set; } = [];
    [Parameter] public IReadOnlyDictionary<int, UserStoryInteractionStateDto>? InteractionStates { get; set; }
    [Parameter, EditorRequired] public BlogPostListingDto[] BlogPosts { get; set; } = [];
    [Parameter] public int TotalBlogPosts { get; set; }
    [Parameter] public EventCallback OnJoin { get; set; }
    [Parameter] public EventCallback OnLeave { get; set; }
    [Parameter] public EventCallback<AddGroupStoryDto> OnStoryAdded { get; set; }
    [Parameter] public EventCallback<int> OnStoryRemoved { get; set; }

    private ReportDialog _reportDialog = default!;
    private bool _showAddStory;
    private bool _showFolders;
    private int? _addStoryId;
    private string? _addStoryError;

    private void ToggleAddStory()
    {
        _showAddStory  = !_showAddStory;
        _addStoryId    = null;
        _addStoryError = null;
    }

    private async Task HandleAddStoryAsync()
    {
        if (_addStoryId is null) return;
        _addStoryError = null;
        await OnStoryAdded.InvokeAsync(new AddGroupStoryDto
        {
            GroupId = Group.GroupId,
            StoryId = _addStoryId.Value
        });
        _showAddStory = false;
        _addStoryId   = null;
    }

    private RenderFragment RenderFolders(IReadOnlyList<GroupFolderDto> folders) => builder =>
    {
        builder.OpenElement(0, "ul");
        builder.AddAttribute(1, "class", "flex flex-col gap-1 text-sm");
        foreach (GroupFolderDto folder in folders)
        {
            builder.OpenElement(2, "li");
            builder.OpenElement(3, "div");
            builder.AddAttribute(4, "class", "text-(--color-text)");
            builder.AddContent(5, "📁 " + folder.Name);
            builder.CloseElement(); // div
            if (folder.Children.Count > 0)
            {
                builder.OpenElement(6, "div");
                builder.AddAttribute(7, "class", "ml-4");
                builder.AddContent(8, RenderFolders(folder.Children));
                builder.CloseElement(); // div
            }
            builder.CloseElement(); // li
        }
        builder.CloseElement(); // ul
    };

    private static string AudienceBadgeLabel(GroupAudienceType type) => type switch
    {
        GroupAudienceType.SfwOnly => "SFW Only",
        GroupAudienceType.Mature  => "Mature",
        _                         => "Standard"
    };

    private static string AudienceBadgeClasses(GroupAudienceType type) => type switch
    {
        GroupAudienceType.Mature  => "bg-(--color-danger)/10 text-(--color-danger) ring-(--color-danger)/30",
        GroupAudienceType.SfwOnly => "bg-(--color-warning)/10 text-(--color-warning) ring-(--color-warning)/30",
        _                         => "bg-(--color-surface-raised) text-(--color-text-muted) ring-(--color-border)"
    };
}
