@page "/group/{GroupId:int}/{*GroupSlug}"
@namespace TheCanalaveLibrary.SharedUI
@inject IGroupWriteService GroupService
@inject IStoryReadService StoryService
@inject IUserStoryInteractionReadService InteractionService
@inject IBlogPostReadService BlogPostService
@inject IToastService Toasts
@inject NavigationManager Nav
@inject IPublicUrlProvider PublicUrlProvider
@using TheCanalaveLibrary.Core
@using Microsoft.AspNetCore.Components.Authorization

@* Group detail page — /group/{id}/{slug} (WU32; former GroupDesktop composite folded in
   2026-07-18, WU-ResponsiveMerge — single responsive tree, page owns its markup).
   Slug is cosmetic; only GroupId is the key (audience filter may return null for hidden Mature groups).
   Resolves CurrentUserId from the auth cascade (never injects IActiveUserContext — SharedUI rule).
   Batch-loads: group detail, story listings, interaction states, blog posts in parallel.
   [PersistentState] on Group/Stories/BlogPosts/TotalBlogPosts eliminates the prerender→interactive
   double-fetch; per-viewer state (_currentUserRole, _interactionStates) stays ephemeral — same
   judgment as StoryPage's _usiState (deterministic per viewer, re-fetch is flicker-free).
   WU32. *@

@if (_isLoading)
{
    <PageTitle>Group</PageTitle>
    <p class="p-4 text-(--color-text-muted)"><em>Loading…</em></p>
}
else if (_gate is not null && Group is null)
{
    @* Mature interstitial (WU-AccessGate): M-audience group, not consented. *@
    <ContentGateInterstitial Metadata="@_gate" />
}
else if (Group is null)
{
    <PageTitle>Group not found</PageTitle>
    <p class="p-4 text-(--color-danger)">Group not found.</p>
}
else
{
    <PageTitle>@Group.GroupName</PageTitle>
    <SocialMetaTags Title="@Group.GroupName" Description="@OgDescription" ImageUrl="@OgImageUrl" Url="@OgUrl" OgType="website"/>
    @if (Group.AudienceType == GroupAudienceType.Mature)
    {
        @* Adult labels on the revealed branch too — the URL is adult regardless of consent. *@
        <AdultContentMetaTags />
    }

    <div class="mx-auto max-w-6xl px-3 py-4 md:px-4 md:py-8 flex flex-col gap-6 md:gap-8">

        @* ── Group header ─────────────────────────────────────────────────────────── *@
        <div class="flex flex-col gap-3">
            <div class="flex flex-wrap items-start justify-between gap-4">
                <div class="flex flex-col gap-1">
                    <div class="flex flex-wrap items-center gap-3">
                        <h1 class="text-3xl font-bold text-(--color-text)">@Group.GroupName</h1>
                        <span class="@GroupDisplayFormat.AudienceBadgeClasses(Group.AudienceType) rounded px-2 py-0.5 text-xs font-medium ring-1">
                            @GroupDisplayFormat.AudienceBadgeLabel(Group.AudienceType)
                        </span>
                    </div>
                    <div class="flex flex-wrap items-center gap-x-3 gap-y-0.5 text-sm text-(--color-text-muted)">
                        <span>@Group.MemberCount @(Group.MemberCount == 1 ? "member" : "members")</span>
                        @if (Group.CreatorDisplayName is not null)
                        {
                            <span>·</span>
                            <span>Created by
                                <a href="/profile/@Group.CreatorId"
                                   class="text-(--color-action-ink) hover:underline">@Group.CreatorDisplayName</a>
                            </span>
                        }
                        <span>·</span>
                        <span>@Group.DateCreated.ToString("MMM d, yyyy")</span>
                    </div>
                </div>

                @* ── Membership controls ──────────────────────────────────────────── *@
                <div class="flex items-center gap-3">
                    @if (_currentUserId is not null)
                    {
                        @if (_currentUserRole is null)
                        {
                            <button type="button" @onclick="HandleJoinAsync"
                                    class="rounded-md bg-(--color-action) px-4 py-2 text-sm font-medium text-(--color-text) transition-colors hover:bg-(--color-action-hover)">
                                Join Group
                            </button>
                        }
                        else
                        {
                            <span class="text-sm text-(--color-text-muted)">
                                @(_currentUserRole == GroupRole.Admin ? "Admin" : "Member")
                            </span>
                            <button type="button" @onclick="HandleLeaveAsync"
                                    class="rounded-md border border-(--color-border) bg-(--color-surface) px-4 py-2 text-sm font-medium text-(--color-text) transition-colors hover:bg-(--color-surface-hover)">
                                Leave
                            </button>
                        }
                        @if (_currentUserRole == GroupRole.Admin)
                        {
                            <a href="/group/@Group.GroupId/edit"
                               class="rounded-md border border-(--color-border) bg-(--color-surface) px-4 py-2 text-sm font-medium text-(--color-text) transition-colors hover:bg-(--color-surface-hover)">
                                Edit Group
                            </a>
                        }
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Group.Description))
            {
                <p class="text-sm text-(--color-text) leading-relaxed max-w-2xl">@Group.Description</p>
            }
        </div>

        @* ── Two-column layout: main | sidebar ────────────────────────────────────── *@
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-[1fr_280px]">

            @* ── Left column: stories + blog posts + comments ─────────────────────── *@
            <div class="flex flex-col gap-8">

                @* Stories ─────────────────────────────────────────────────────────── *@
                <section class="flex flex-col gap-4">
                    <div class="flex items-center justify-between">
                        <h2 class="text-lg font-semibold text-(--color-text)">Stories</h2>
                        @if (_currentUserRole is not null)
                        {
                            <button type="button" @onclick="ToggleAddStory"
                                    class="text-sm text-(--color-action-ink) hover:underline">
                                @(_showAddStory ? "Cancel" : "+ Add Story")
                            </button>
                        }
                    </div>

                    @* ── Inline add-story form (members only) — WU42: title typeahead replaces the
                       old raw numeric Story ID input. *@
                    @if (_showAddStory)
                    {
                        <div class="rounded-lg border border-(--color-border) bg-(--color-surface) p-4 flex flex-col gap-3">
                            <label class="text-sm font-semibold text-(--color-text)">Add a story to this group</label>
                            <StoryTitlePicker OnStorySelected="HandleAddStoryAsync"
                                              Placeholder="Type to search for a story..." />
                            <div class="flex gap-2">
                                <button type="button" @onclick="() => _showAddStory = false"
                                        class="rounded-md border border-(--color-border) px-3 py-1.5 text-sm text-(--color-text) hover:bg-(--color-surface-hover)">
                                    Cancel
                                </button>
                            </div>
                        </div>
                    }

                    <MatureDisclosureLine Items="@_gatedItems" />
                    <StoryDeck Stories="@(Stories ?? [])"
                               UserStoryInteractionStates="_interactionStates"
                               CurrentUserId="_currentUserId"
                               EmptyMessage="No stories in this group yet."
                               OnReport="@(id => _reportDialog.OpenAsync(ReportedEntityType.Story, id))" />
                    <ReportDialog @ref="_reportDialog" />
                </section>

                @* Blog posts ─────────────────────────────────────────────────────── *@
                <section class="flex flex-col gap-4">
                    <div class="flex items-center justify-between">
                        <h2 class="text-lg font-semibold text-(--color-text)">Blog Posts</h2>
                        @if (_currentUserRole is not null)
                        {
                            <a href="/group/@Group.GroupId/blog/new"
                               class="text-sm text-(--color-action-ink) hover:underline">+ New Post</a>
                        }
                    </div>
                    @if (BlogPosts is null || BlogPosts.Length == 0)
                    {
                        <p class="text-sm text-(--color-text-muted)">No blog posts yet.</p>
                    }
                    else
                    {
                        <div class="flex flex-col gap-3">
                            @foreach (BlogPostListingDto post in BlogPosts)
                            {
                                <BlogPostCard Post="post" />
                            }
                        </div>
                        @if (TotalBlogPosts > BlogPosts.Length)
                        {
                            <p class="text-sm text-(--color-text-muted)">Showing @BlogPosts.Length of @TotalBlogPosts posts.</p>
                        }
                    }
                </section>

                @* Comments ──────────────────────────────────────────────────────────── *@
                <section class="flex flex-col gap-3">
                    <h2 class="text-lg font-semibold text-(--color-text)">Comments</h2>
                    <CanalaveErrorBoundary Label="comments" Compact="true">
                        <CommentSection GroupId="@((int?)Group.GroupId)" CurrentUserId="_currentUserId" />
                    </CanalaveErrorBoundary>
                </section>

            </div>

            @* ── Right column: folder tree ────────────────────────────────────────── *@
            <aside class="flex flex-col gap-4">
                @if (Group.FolderTree.Count > 0 || _currentUserRole == GroupRole.Admin)
                {
                    <div class="rounded-lg border border-(--color-border) bg-(--color-surface) p-4 flex flex-col gap-3">
                        <div class="flex items-center justify-between">
                            <h2 class="text-base font-semibold text-(--color-text)">Folders</h2>
                            @if (_currentUserRole == GroupRole.Admin)
                            {
                                <a href="/group/@Group.GroupId/folders"
                                   class="text-xs text-(--color-action-ink) hover:underline">Manage</a>
                            }
                        </div>
                        @if (Group.FolderTree.Count == 0)
                        {
                            <p class="text-xs text-(--color-text-muted)">No folders yet.</p>
                        }
                        else
                        {
                            @RenderFolders(Group.FolderTree)
                        }
                    </div>
                }
            </aside>

        </div>

    </div>
}

@* Inline error strip (join/leave/story errors surface here) *@
@code {
    [Parameter] public int GroupId { get; set; }

    /// <summary>Cosmetic catch-all segment — ignored on load; only GroupId is the key.</summary>
    [Parameter] public string? GroupSlug { get; set; }

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    // Persisted across the prerender→interactive handoff — the primary batch (group detail,
    // member stories, first page of blog posts). Public properties: [PersistentState] requires
    // them. TotalBlogPosts rides alongside BlogPosts because the service returns a ValueTuple,
    // which does not survive System.Text.Json — split into separate persisted properties
    // (layer5-wasm.md §"Avoiding the double fetch").
    [PersistentState] public GroupDetailDto? Group { get; set; }
    [PersistentState] public StoryListingDto[]? Stories { get; set; }
    [PersistentState] public BlogPostListingDto[]? BlogPosts { get; set; }
    [PersistentState] public int TotalBlogPosts { get; set; }

    // Per-viewer supplementary state — NOT persisted (StoryPage's _usiState judgment):
    // deterministic per viewer, so the interactive re-fetch is flicker-free, and it must stay
    // fresh rather than ride a stale prerender payload.
    private GroupRole? _currentUserRole;
    private int? _currentUserId;
    private IReadOnlyDictionary<int, UserStoryInteractionStateDto> _interactionStates =
        new Dictionary<int, UserStoryInteractionStateDto>();

    private bool _isLoading = true;

    // Interstitial metadata when the group exists but the viewer hasn't consented
    // (WU-AccessGate). Deterministic per viewer — not persisted; consent forces a
    // full-document navigation.
    private GatedMetadataDto? _gate;

    // Mature count-line disclosure items for the member-story section (WU-AccessGate) —
    // per-viewer deterministic, not persisted.
    private IReadOnlyList<GatedMetadataDto> _gatedItems = [];

    private bool _initialized;
    private int _loadedGroupId = int.MinValue; // sentinel; no real GroupId equals this

    // ── Add-story state (from the former GroupDesktop composite) ─────────────────
    private ReportDialog _reportDialog = default!;
    private bool _showAddStory;

    // Open Graph/Twitter meta (WU-Seo). No cover field on GroupDetailDto — falls back to the
    // site-default image (see audit/Seo.md "Open" re: SVG re-use).
    private string? OgDescription => Group is null ? null : SocialDescriptionHelper.Clean(Group.Description);
    private string OgImageUrl => PublicUrlProvider.AbsoluteImageUrl(null, "/img/default-cover.svg");
    private string OgUrl => PublicUrlProvider.AbsolutePageUrl($"/group/{GroupId}");

    protected override async Task OnInitializedAsync()
    {
        // One-time: resolve the authenticated user id (auth doesn't change mid-session).
        if (AuthState is not null)
        {
            AuthenticationState state = await AuthState;
            string? idStr = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            _currentUserId = int.TryParse(idStr, out int id) ? id : null;
        }

        if (Group is null)
        {
            // No persisted prerender value to restore (first pass) — full fresh batch. This is
            // the restore-or-fetch (??=) idiom in branch form: the page's primary content is one
            // parallel batch, so the whole batch is skipped or run together, not per-property.
            await LoadGroupAsync();
        }
        else
        {
            // [PersistentState] restored the primary batch from the prerender payload — skip the
            // DB calls it covers and refresh only the per-viewer supplementary state, which is
            // deliberately ephemeral (flicker-free re-fetch; see field comments).
            _loadedGroupId = GroupId;
            Stories ??= [];
            BlogPosts ??= [];

            _currentUserRole = await GroupService.GetCurrentUserRoleAsync(GroupId);
            if (Stories.Length > 0 && _currentUserId is not null)
            {
                IReadOnlyList<int> storyIds = Stories.Select(s => s.StoryId).ToArray();
                _interactionStates = await InteractionService.GetStatesByStoryIdsAsync(storyIds);
            }

            _isLoading = false;
        }

        _initialized = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        // Fires when the same GroupPage instance is reused for a different GroupId.
        if (!_initialized) return;
        if (GroupId == _loadedGroupId) return;
        await LoadGroupAsync();
    }

    // Fresh load — plain assignments (not ??=): param-change reloads and post-write refreshes
    // must never be short-circuited by [PersistentState] values from a previous group
    // (layer3-logic.md §"Route-Parameter Dispatchers"; internal SPA navs don't prerender, so
    // there is no persisted state to restore on this path anyway).
    private async Task LoadGroupAsync()
    {
        _isLoading = true;
        _loadedGroupId = GroupId;
        _gate = null;

        Group = await GroupService.GetByIdAsync(GroupId);

        // Gated-existence read (WU-AccessGate): an M-audience group the viewer hasn't consented
        // to → interstitial (one group consent covers all group-owned content); truly absent →
        // real 404. Child loads below are skipped either way (Group is null).
        if (Group is null)
        {
            _gate = await GroupService.GetGroupGateAsync(GroupId);
            if (_gate is null)
                Nav.NotFound();
        }

        if (Group is not null)
        {
            // Role and stories batch-loaded in parallel.
            Task<GroupRole?> roleTask      = GroupService.GetCurrentUserRoleAsync(GroupId);
            Task<StoryListingDto[]> storyTask =
                Group.StoryIds.Count > 0
                    ? StoryService.GetListingsByIdsAsync(Group.StoryIds)
                    : Task.FromResult(Array.Empty<StoryListingDto>());
            // Mature count-line disclosure (WU-AccessGate): the M member stories the viewer's
            // ceiling hid — a group reveal covers group-OWNED content, member stories still gate
            // individually, so the disclosure keeps the bridge visible inside the group too.
            Task<IReadOnlyList<GatedMetadataDto>> gatedTask =
                Group.StoryIds.Count > 0
                    ? StoryService.GetGatedCardsAsync(Group.StoryIds)
                    : Task.FromResult<IReadOnlyList<GatedMetadataDto>>([]);
            Task<(BlogPostListingDto[], int)> blogTask =
                BlogPostService.GetByGroupAsync(GroupId, page: 1, pageSize: 10);

            await Task.WhenAll(roleTask, storyTask, gatedTask, blogTask);

            _currentUserRole = await roleTask;
            Stories          = await storyTask;
            _gatedItems      = await gatedTask;

            (BlogPostListingDto[] blogItems, int blogTotal) = await blogTask;
            BlogPosts      = blogItems;
            TotalBlogPosts = blogTotal;

            // Interaction states (no-tracking, per-viewer, nullable).
            if (Stories.Length > 0 && _currentUserId is not null)
            {
                IReadOnlyList<int> storyIds = Stories.Select(s => s.StoryId).ToArray();
                _interactionStates = await InteractionService.GetStatesByStoryIdsAsync(storyIds);
            }
        }

        _isLoading = false;
    }

    // ── Membership callbacks ──────────────────────────────────────────────────────

    private async Task HandleJoinAsync()
    {
        try
        {
            await GroupService.JoinAsync(GroupId);
            await LoadGroupAsync();
        }
        catch (Exception ex)
        {
            Toasts.Show(ExceptionPresenter.GetUserMessage(ex), ToastLevel.Danger);
        }
    }

    private async Task HandleLeaveAsync()
    {
        try
        {
            await GroupService.LeaveAsync(GroupId);
            await LoadGroupAsync();
        }
        catch (Exception ex)
        {
            Toasts.Show(ExceptionPresenter.GetUserMessage(ex), ToastLevel.Danger);
        }
    }

    // ── Add-story UI (from the former GroupDesktop composite) ─────────────────────

    private void ToggleAddStory() => _showAddStory = !_showAddStory;

    private async Task HandleAddStoryAsync(StoryTitleSearchDto story)
    {
        await HandleStoryAddedAsync(new AddGroupStoryDto
        {
            GroupId = Group!.GroupId,
            StoryId = story.StoryId
        });
        _showAddStory = false;
    }

    // ── Folder tree (inline recursive render fragment) ────────────────────────────

    private RenderFragment RenderFolders(IReadOnlyList<GroupFolderDto> folders) => builder =>
    {
        builder.OpenElement(0, "ul");
        builder.AddAttribute(1, "class", "flex flex-col gap-1 text-sm");
        foreach (GroupFolderDto folder in folders)
        {
            builder.OpenElement(2, "li");
            builder.OpenElement(3, "div");
            builder.AddAttribute(4, "class", "flex items-center gap-1 text-(--color-text)");
            builder.OpenElement(5, "span");
            builder.AddContent(6, "📁 " + folder.Name);
            builder.CloseElement(); // span
            // Deliberate zero-trace: an M-capped folder inside an E-audience (Standard) group
            // renders as an unlabeled folder to mature-off viewers — suppressing the "(M)" badge
            // rather than advertising a mature shelf. Documented 2026-07-19 (was uncommented).
            if (folder.MaxRating != Rating.M)
            {
                builder.OpenElement(7, "span");
                builder.AddAttribute(8, "class", "text-xs text-(--color-text-muted)");
                builder.AddContent(9, $"({folder.MaxRating})");
                builder.CloseElement(); // span
            }
            builder.CloseElement(); // div
            if (folder.Children.Count > 0)
            {
                builder.OpenElement(10, "div");
                builder.AddAttribute(11, "class", "ml-4");
                builder.AddContent(12, RenderFolders(folder.Children));
                builder.CloseElement(); // div
            }
            builder.CloseElement(); // li
        }
        builder.CloseElement(); // ul
    };

    // ── Story management callbacks ────────────────────────────────────────────────

    private async Task HandleStoryAddedAsync(AddGroupStoryDto dto)
    {
        try
        {
            await GroupService.AddStoryAsync(dto);
            await LoadGroupAsync();
        }
        catch (ContentRatingExceededException ex)
        {
            Toasts.Show(ExceptionPresenter.GetUserMessage(ex), ToastLevel.Danger);
        }
        catch (Exception ex)
        {
            Toasts.Show(ExceptionPresenter.GetUserMessage(ex), ToastLevel.Danger);
        }
    }

    private async Task HandleStoryRemovedAsync(int groupStoryId)
    {
        try
        {
            await GroupService.RemoveStoryAsync(groupStoryId);
            await LoadGroupAsync();
        }
        catch (Exception ex)
        {
            Toasts.Show(ExceptionPresenter.GetUserMessage(ex), ToastLevel.Danger);
        }
    }
}
