@page "/groups"
@namespace TheCanalaveLibrary.SharedUI
@inject IGroupWriteService GroupService
@inject NavigationManager Nav
@using TheCanalaveLibrary.Core
@using Microsoft.AspNetCore.Components.Authorization

@* Groups listing page. No @attribute [Authorize] — anonymous visitors may browse public groups.
   IGroupWriteService (: IGroupReadService) injected so the Join button on GroupPage can reuse
   the same service scope (page itself only calls the read path here).
   Server-side GroupAudience named filter hides Mature groups from mature-disabled users automatically.
   [PersistentState] on Groups/TotalCount eliminates the prerender→interactive double-fetch for the
   initially-loaded page; page-change fetches are user-driven interactive actions (plain assignment).
   WU32. *@

<PageTitle>Groups</PageTitle>

<div class="mx-auto max-w-4xl px-4 py-8 flex flex-col gap-6">

    @* ── Page header ─────────────────────────────────────────────────────────── *@
    <div class="flex items-center justify-between">
        <h1 class="inline-block rounded-md border border-(--color-border) bg-(--color-surface-raised) px-4 py-1.5 font-display text-xl font-semibold text-(--color-text)">Groups</h1>
        @if (_currentUserId is not null)
        {
            <a href="/group/new"
               class="rounded-md bg-(--color-mission) px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-(--color-mission-hover)">
                + New Group
            </a>
        }
    </div>

    @* ── Listing ──────────────────────────────────────────────────────────────── *@
    @if (_isLoading)
    {
        <p class="text-(--color-text-muted)"><em>Loading groups…</em></p>
    }
    else if (Groups is null || Groups.Length == 0)
    {
        <p class="text-(--color-text-muted)">No groups yet. Be the first to create one!</p>
    }
    else
    {
        <div class="flex flex-col gap-3">
            @foreach (GroupCardDto group in Groups)
            {
                <GroupCard Group="group" />
            }
        </div>

        <PaginationControls CurrentPage="_currentPage"
                            PageSize="_pageSize"
                            TotalCount="TotalCount"
                            OnPageChanged="HandlePageChanged" />
    }

</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    // Persisted across the prerender→interactive handoff. The service returns a
    // (Items, TotalCount) ValueTuple, which does not survive System.Text.Json — split into two
    // persisted properties (layer5-wasm.md §"Avoiding the double fetch").
    [PersistentState] public GroupCardDto[]? Groups { get; set; }
    [PersistentState] public int TotalCount { get; set; }

    private int _currentPage = 1;
    private const int _pageSize = 20;
    private bool _isLoading = true;
    private int? _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            AuthenticationState state = await AuthState;
            string? idStr = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            _currentUserId = int.TryParse(idStr, out int id) ? id : null;
        }

        if (Groups is null)
        {
            // No persisted prerender value to restore — fetch. (Restore-or-fetch ??= idiom in
            // branch form: the tuple deconstruction in LoadAsync can't be a single ??=.)
            await LoadAsync();
        }
        else
        {
            // [PersistentState] restored the initially-loaded page (Groups + TotalCount).
            _isLoading = false;
        }
    }

    // Plain assignments — page-change fetches are user-driven interactive actions, never
    // short-circuited by persisted state.
    private async Task LoadAsync()
    {
        _isLoading = true;
        (GroupCardDto[] items, int total) = await GroupService.GetListingsAsync(_currentPage, _pageSize);
        Groups     = items;
        TotalCount = total;
        _isLoading = false;
    }

    private async Task HandlePageChanged(int page)
    {
        _currentPage = page;
        await LoadAsync();
    }
}
