@page "/group/{GroupId:int}/blog/new"
@namespace TheCanalaveLibrary.SharedUI
@attribute [Authorize]
@inject IBlogPostWriteService BlogPostService
@inject IStoryReadService StoryService
@inject IGroupWriteService GroupService
@inject NavigationManager Nav
@inject ILogger<GroupBlogPostEditorPage> Logger
@using TheCanalaveLibrary.Core
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Logging

@* Group blog post create page — member-only.
   Reuses BlogPostPropertiesForm (no publish toggle, group posts publish immediately).
   Pattern 1 edit side (cross-cutting.md "Two content-editing patterns"); view is BlogPostPage.
   [PersistentState] on GroupName (the page's only non-per-viewer fetched content) skips the group
   re-fetch on hydration; the member-role gate and the viewer's story-picker options are per-viewer
   state and always load fresh. Live form/draft state is never persisted.
   WU32. *@

<PageTitle>New Group Post</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (_isLoading)
        {
            <p class="p-4 text-(--color-text-muted)"><em>Loading…</em></p>
        }
        else if (_forbidden)
        {
            <p class="p-4 text-(--color-danger)">You must be a member of this group to post.</p>
        }
        else if (GroupName is null)
        {
            <p class="p-4 text-(--color-danger)">Group not found.</p>
        }
        else
        {
            <div class="mx-auto max-w-2xl px-4 py-8">
                <div class="mb-6 flex flex-col gap-1">
                    <h1 class="inline-block self-start rounded-md border border-(--color-border) bg-(--color-surface-raised) px-4 py-1.5 font-display text-xl font-semibold text-(--color-text)">New Blog Post</h1>
                    <p class="text-sm text-(--color-text-muted)">
                        Posting to
                        <a href="/group/@GroupId"
                           class="text-(--color-action-ink) hover:underline">@GroupName</a>
                    </p>
                </div>

                @* ── Draft safety (cross-cutting.md §"Error Handling Strategy") ── *@
                <div class="mb-4">
                    <DraftAutosave @ref="_autosave"
                                   DraftKey="@($"draft:groupblogpost:new:{GroupId}")"
                                   Capture="CaptureDraftAsync"
                                   OnRestore="RestoreDraftAsync" />
                </div>

                <div class="rounded-xl border border-(--color-border) bg-(--color-surface) p-6">
                    <BlogPostPropertiesForm @ref="_form"
                                            ViewModel="_viewModel"
                                            AuthorStories="_authorStories"
                                            SubmitLabel="Publish Post"
                                            OnValidSubmit="HandleValidSubmit" />
                </div>
            </div>
        }
    </Authorized>
    @* No <NotAuthorized> branch: page-level [Authorize] means the router renders the denial
       (SignInRequired via Routes.razor) — an inline branch here is unreachable dead code
       (WU-AccessGate Phase 1 cleanup). *@
</AuthorizeView>

@code {
    [Parameter] public int GroupId { get; set; }

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private BlogPostPropertiesForm? _form;
    private DraftAutosave? _autosave;
    private BlogPostPropertiesViewModel _viewModel = new();

    // Per-viewer picker options — NOT persisted: per-viewer supplementary state (the viewer's own
    // stories) that reloads flicker-free, and a list of ValueTuples besides (tuples don't survive
    // the [PersistentState] System.Text.Json round trip).
    private IReadOnlyList<(int Id, string Title)>? _authorStories;

    // Persisted across the prerender→interactive handoff — the only fetched content this page
    // renders that isn't per-viewer. Just the rendered name, not the whole GroupDetailDto
    // (persist only what the page renders — layer5-wasm.md §"Avoiding the double fetch").
    [PersistentState] public string? GroupName { get; set; }

    private bool _isLoading = true;
    private bool _forbidden;

    protected override async Task OnInitializedAsync()
    {
        int? currentUserId = await ResolveCurrentUserIdAsync();
        if (currentUserId is null)
        {
            _isLoading = false;
            return;
        }

        // Verify the group exists — skipped when [PersistentState] restored GroupName from the
        // prerender payload (restore-or-fetch idiom; branch form because the persisted value is
        // a projection of the fetched DTO, not the DTO itself).
        if (GroupName is null)
        {
            GroupDetailDto? group = await GroupService.GetByIdAsync(GroupId);
            if (group is null)
            {
                _isLoading = false;
                return;
            }

            GroupName = group.GroupName;
        }

        // Member gate (GetCurrentUserRoleAsync returns null for non-members) — per-viewer state,
        // always fetched fresh.
        GroupRole? role = await GroupService.GetCurrentUserRoleAsync(GroupId);
        if (role is null)
        {
            _forbidden = true;
            _isLoading = false;
            return;
        }

        // Populate the story picker — per-viewer, always fresh (see _authorStories comment).
        _authorStories = await LoadAuthorStoriesAsync(currentUserId.Value);

        _isLoading = false;
    }

    private async Task<IReadOnlyList<(int Id, string Title)>> LoadAuthorStoriesAsync(int authorId)
    {
        IReadOnlyList<int> ids = await StoryService.GetStoryIdsByAuthorAsync(authorId);
        if (ids.Count == 0) return [];
        StoryListingDto[] listings = await StoryService.GetListingsByIdsAsync(ids);
        return listings.Select(l => (l.StoryId, l.Title)).ToArray();
    }

    private async Task HandleValidSubmit()
    {
        _viewModel.IsLoading = true;
        _viewModel.ServerValidationErrors.Clear();

        try
        {
            string content = _form is not null ? await _form.GetContentAsync() : string.Empty;
            _viewModel.Content = content;

            int newId = await BlogPostService.CreateGroupBlogPostAsync(new CreateGroupBlogPostDto
            {
                GroupId     = GroupId,
                Title       = _viewModel.Title,
                Content     = _viewModel.Content,
                Rating      = _viewModel.Rating,
                HasSpoilers = _viewModel.HasSpoilers,
                StoryId     = _viewModel.StoryId
            });

            if (_autosave is not null) await _autosave.ClearAsync(); // persisted save supersedes the local backup
            Nav.NavigateTo($"/blog/{newId}");
        }
        catch (UnauthorizedAccessException)
        {
            _forbidden = true;
        }
        catch (Exception ex)
        {
            if (!ExceptionPresenter.IsUserFacing(ex))
                Logger.LogError(ex, "Creating a group blog post failed unexpectedly for group {GroupId}", GroupId);
            _viewModel.ServerValidationErrors.AddRange(ExceptionPresenter.GetUserMessages(ex));
        }
        finally
        {
            _viewModel.IsLoading = false;
        }
    }

    // ── Draft safety (DraftAutosave contract) ─────────────────────────────────────
    private async Task<Dictionary<string, string?>?> CaptureDraftAsync()
    {
        if (_form is null || _isLoading) return null;
        return new Dictionary<string, string?>
        {
            ["Title"] = _viewModel.Title,
            ["Content"] = await _form.GetContentAsync(),
        };
    }

    private async Task RestoreDraftAsync(IReadOnlyDictionary<string, string?> fields)
    {
        if (_form is null) return;
        _viewModel.Title = fields.GetValueOrDefault("Title") ?? _viewModel.Title;
        await _form.SetContentAsync(fields.GetValueOrDefault("Content") ?? string.Empty);
        StateHasChanged();
    }

    private async Task<int?> ResolveCurrentUserIdAsync()
    {
        if (AuthState is null) return null;
        AuthenticationState state = await AuthState;
        string? idStr = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        return int.TryParse(idStr, out int id) ? id : null;
    }
}
