@page "/user/{UserId:int}/{*Tab}"
@namespace TheCanalaveLibrary.SharedUI
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@attribute [AllowAnonymous]
@inject IUserProfileReadService ProfileReadService
@inject IFollowingReadService FollowingReadService
@inject IFollowingWriteService FollowingWriteService
@inject IStoryReadService StoryReadService
@inject IUserStoryInteractionReadService InteractionReadService
@inject IRecommendationReadService RecommendationReadService
@inject IBlogPostReadService BlogPostReadService
@inject ISeriesReadService SeriesReadService
@inject ISavedTagSelectionReadService TagSelectionReadService
@inject ISavedTagSelectionWriteService TagSelectionWriteService
@inject ICustomListReadService CustomListReadService
@inject IToastService Toasts
@inject NavigationManager Nav
@inject IPublicUrlProvider PublicUrlProvider

@* Dispatcher — Feature 21 (User Profile Display), WU30.
   Route: /user/{UserId:int}/{*Tab}  (default tab = "profile").
   [AllowAnonymous] — public page; ProfileVisibility is enforced by GetProfileHeaderAsync.

   Load model (mirrors BookshelvesPage dispatcher pattern):
   1. Resolve the current user from AuthState; compute includePrivate = (viewerId == UserId).
   2. Load GetProfileHeaderAsync once (banner is tab-independent); overlay RelationshipState
      via IFollowingReadService when authenticated and not the owner.
   3. Load the tab payload on init, then reload only the payload on tab switch.
   4. Render the ProfileDesktop composite (mobile variant deleted 2026-07-18,
      WU-ResponsiveMerge — single responsive tree).

   [PersistentState] on the header + initially-loaded tab payload eliminates the
   prerender→interactive double fetch on full document loads; tab clicks and UserId changes are
   internal SPA navigations (never prerendered) and reload plain via ClearTabPayload().

   ProfileBanner always receives RelationshipState = null for anonymous or owner — no Follow/Vouch
   controls. The owner receives IsOwner = true; no other viewer does. *@

@if (_isLoading)
{
    <PageTitle>Profile</PageTitle>
    <p class="text-(--color-text-muted)"><em>Loading profile…</em></p>
}
else if (Header is null)
{
    <PageTitle>Not Found</PageTitle>
    <p class="text-(--color-text-muted)">This profile doesn't exist or isn't visible to you.</p>
}
else
{
    <PageTitle>@Header.Username &mdash; Profile</PageTitle>
    <SocialMetaTags Title="@OgTitle" Description="@OgDescription" ImageUrl="@OgImageUrl" Url="@OgUrl" OgType="profile"/>

    <ProfileDesktop Header="@Header"
                    Tab="@_tab"
                    IsOwner="@_isOwner"
                    CurrentUserId="@_currentUserId"
                    RelationshipState="@_relationship"
                    OnRemoveVouch="HandleRemoveVouchAsync"
                    BioHtml="@BioHtml"
                    StoryItems="@(StoryItems ?? [])"
                    StoryTotalCount="@StoryTotalCount"
                    InteractionStates="@_interactionStates"
                    StoryFilter="@_storyFilter"
                    OnStoryFilterChanged="HandleStoryFilterChanged"
                    OnStoryPageChanged="HandleStoryPageChanged"
                    BlogPosts="@(BlogPosts ?? [])"
                    BlogTotalCount="@BlogTotalCount"
                    BlogPage="@_blogPage"
                    BlogPageSize="@BlogPageSize"
                    OnBlogPageChanged="HandleBlogPageChanged"
                    SeriesItems="@(SeriesItems ?? [])"
                    TagSelectionItems="@(TagSelectionItems ?? [])"
                    OnCopyTagSelection="HandleCopyTagSelectionAsync"
                    PublicListItems="@(PublicListItems ?? [])" />
}

@code {
    [Parameter] public int UserId { get; set; }
    [Parameter] public string? Tab { get; set; }

    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private const int BlogPageSize = 20;
    private const int StoryPageSize = 20;

    private ProfileTab _tab;
    private bool _isLoading = true;

    // Persisted across the prerender→interactive handoff (layer5-wasm.md §"Avoiding the double
    // fetch"): the banner header plus the initially-loaded tab payload — exactly what the page
    // renders on a full document load, no superset. Only the initial load restores; tab clicks
    // and UserId changes are internal SPA navigations (never prerendered), so those paths clear
    // the persisted properties and fetch plain.
    [PersistentState] public ProfileHeaderDto? Header { get; set; }

    // Profile tab. Null is ambiguous here (a legitimately-empty bio is also null), so a restore
    // miss just refetches — harmless and flicker-free either way.
    [PersistentState] public string? BioHtml { get; set; }

    // Story tabs — split from the (Items, TotalCount) ValueTuple destructure (tuples don't
    // survive System.Text.Json persistence). StoryItems-null is the restore signal.
    [PersistentState] public StoryListingDto[]? StoryItems { get; set; }
    [PersistentState] public int StoryTotalCount { get; set; }

    // Blog tab — same tuple split as the story tabs.
    [PersistentState] public BlogPostListingDto[]? BlogPosts { get; set; }
    [PersistentState] public int BlogTotalCount { get; set; }

    // Series tab (WU41) — public to any viewer, always the full list (no pagination/filter).
    [PersistentState] public IReadOnlyList<SeriesListingDto>? SeriesItems { get; set; }

    // Tag Selections tab (WU43) — public (IsPublic) selections only, always the full list, same
    // shape as Series. No public browse/gallery surface exists — this tab is the sole discovery
    // path for a shared selection (audit/Tags.md Feature 15).
    [PersistentState] public IReadOnlyList<SavedTagSelectionDetailDto>? TagSelectionItems { get; set; }

    // Lists tab (WU-CustomLists, Feature 51) — public (IsPublic) custom lists only, always the
    // full list, same shape as Series/TagSelections. Each links to its own /lists/{id} page.
    [PersistentState] public IReadOnlyList<CustomListSummaryDto>? PublicListItems { get; set; }

    private int? _currentUserId;
    private bool _isOwner;

    // Per-viewer supplementary state — deterministic per viewer, so the prerender→interactive
    // re-fetch is flicker-free; not persisted (same treatment as StoryPage's _usiState).
    private UserRelationshipStateDto? _relationship; // null = anonymous or owner
    private IReadOnlyDictionary<int, UserStoryInteractionStateDto>? _interactionStates;

    // Candidate IDs — not rendered, so never persisted (browser-exposure rule: don't persist a
    // superset the UI pages down); the restore path refetches them so pagination keeps working.
    private IReadOnlyList<int> _candidateIds = [];
    private StoryFilterDto _storyFilter = new StoryFilterDto { PageSize = StoryPageSize };

    private int _blogPage = 1;

    private bool _initialized;
    private int _loadedUserId = int.MinValue;      // sentinel; no real UserId equals this
    private ProfileTab _loadedTab = (ProfileTab)(-1); // sentinel; outside valid enum range

    // Open Graph/Twitter meta (WU-Seo).
    private string OgTitle => Header is null ? "Profile" : $"{Header.Username} — Profile";
    private string? OgDescription => Header is null ? null : SocialDescriptionHelper.Clean(Header.Tagline);
    private string OgImageUrl => PublicUrlProvider.AbsoluteImageUrl(Header?.AvatarUrl, "/img/default-avatar.svg");
    private string OgUrl => PublicUrlProvider.AbsolutePageUrl($"/user/{UserId}");

    protected override async Task OnInitializedAsync()
    {
        // One-time: resolve the current viewer's identity (auth doesn't change mid-session).
        var authState = await AuthState;
        string? idClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(idClaim, out int id)) _currentUserId = id;
        _isOwner = _currentUserId.HasValue && _currentUserId.Value == UserId;

        // Parse tab; bad slug → 404.
        ProfileTab? parsed = ProfileTabSlug.Parse(Tab);
        if (parsed is null) { Nav.NotFound(); _initialized = true; return; }
        _tab = parsed.Value;

        await LoadHeaderAsync();
        if (Header is not null)
            await LoadTabPayloadAsync();

        _loadedUserId = UserId;
        _loadedTab = _tab;
        _isLoading = false;
        _initialized = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        // Fires on every same-component navigation (tab strip / UserId change).
        if (!_initialized) return;

        ProfileTab? parsed = ProfileTabSlug.Parse(Tab);
        if (parsed is null) { Nav.NotFound(); return; }
        ProfileTab newTab = parsed.Value;

        bool userChanged = UserId != _loadedUserId;
        bool tabChanged  = newTab != _loadedTab;
        if (!userChanged && !tabChanged) return;

        _tab = newTab;
        _isLoading = true;

        // Internal SPA navigations never prerender, so persisted values from the previous
        // user/tab must not short-circuit the reload — clear them and let the loaders fetch
        // plain (layer3-logic.md §"Route-Parameter Dispatchers").
        ClearTabPayload();

        if (userChanged)
        {
            // Banner + relationship are tied to UserId — reload both.
            Header = null;
            _isOwner = _currentUserId.HasValue && _currentUserId.Value == UserId;
            _loadedUserId = UserId;
            _storyFilter = new StoryFilterDto { PageSize = StoryPageSize };
            _blogPage = 1;
            await LoadHeaderAsync();
            if (Header is not null)
                await LoadTabPayloadAsync();
        }
        else
        {
            // Same user, different tab — keep banner, reload payload only.
            _storyFilter = new StoryFilterDto { PageSize = StoryPageSize };
            _blogPage = 1;
            await LoadTabPayloadAsync();
        }

        _loadedTab = _tab;
        _isLoading = false;
    }

    // Loads the tab-independent banner and relationship state. Restore-or-fetch on Header (??=):
    // the initial load may restore it from the prerender payload; the userChanged reload path
    // clears Header first, so it fetches plain there. The relationship overlay is per-viewer
    // ephemeral and always fetches.
    private async Task LoadHeaderAsync()
    {
        Header ??= await ProfileReadService.GetProfileHeaderAsync(UserId, includePrivate: _isOwner);
        _relationship = null;
        if (Header is not null && _currentUserId.HasValue && !_isOwner)
            _relationship = await FollowingReadService.GetRelationshipStateAsync(UserId);
    }

    // Clears every persisted tab payload — called before any non-initial reload so the loaders'
    // restore-or-fetch guards fetch plain (persisted state only ever applies to the initial
    // full-document load).
    private void ClearTabPayload()
    {
        BioHtml = null;
        StoryItems = null;
        BlogPosts = null;
        SeriesItems = null;
        TagSelectionItems = null;
        PublicListItems = null;
    }

    // ── Tab payload loading ───────────────────────────────────────────────────────

    private Task LoadTabPayloadAsync() => _tab switch
    {
        ProfileTab.Profile       => LoadBioAsync(),
        ProfileTab.Blog          => LoadBlogAsync(),
        ProfileTab.Series        => LoadSeriesAsync(),
        ProfileTab.TagSelections => LoadTagSelectionsAsync(),
        ProfileTab.Lists         => LoadPublicListsAsync(),
        _                        => LoadStoryTabAsync(),
    };

    private async Task LoadBioAsync()
    {
        // ??= restore-or-fetch. A legitimately-null bio refetches (null is ambiguous) — harmless.
        BioHtml ??= await ProfileReadService.GetProfileTextAsync(UserId);
    }

    private async Task LoadStoryTabAsync()
    {
        // Candidate IDs always fetch (not persisted) so filter/page changes keep working.
        _candidateIds = await GetCandidateIdsForTabAsync(_tab);
        if (StoryItems is null)
            await ReloadStoryListingsAsync();
        else
            await LoadInteractionStatesAsync(); // restored listings — only the per-viewer states need fetching
    }

    // Plain fetch — also the filter/page-change path, which must never be short-circuited by
    // persisted state.
    private async Task ReloadStoryListingsAsync()
    {
        (StoryItems, StoryTotalCount) = await StoryReadService.GetListingsAsync(_storyFilter, _candidateIds);
        await LoadInteractionStatesAsync();
    }

    private async Task LoadInteractionStatesAsync()
    {
        _interactionStates = StoryItems is { Length: > 0 } && _currentUserId.HasValue
            ? await InteractionReadService.GetStatesByStoryIdsAsync([.. StoryItems.Select(i => i.StoryId)])
            : new Dictionary<int, UserStoryInteractionStateDto>();
    }

    private async Task LoadBlogAsync()
    {
        // Restore-or-fetch: BlogPosts is cleared by every non-initial path (ClearTabPayload /
        // HandleBlogPageChanged), so non-null here means the initial load restored it.
        if (BlogPosts is null)
        {
            (BlogPosts, BlogTotalCount) = await BlogPostReadService.GetByAuthorAsync(
                UserId, _blogPage, BlogPageSize, includeUnpublished: _isOwner);
        }
    }

    private async Task LoadSeriesAsync()
    {
        SeriesItems ??= await SeriesReadService.GetSeriesByAuthorAsync(UserId);
    }

    private async Task LoadTagSelectionsAsync()
    {
        TagSelectionItems ??= await TagSelectionReadService.GetPublicSelectionsByUserAsync(UserId);
    }

    private async Task LoadPublicListsAsync()
    {
        PublicListItems ??= await CustomListReadService.GetPublicListsByUserAsync(UserId);
    }

    private Task<IReadOnlyList<int>> GetCandidateIdsForTabAsync(ProfileTab tab) => tab switch
    {
        ProfileTab.Favorites       => InteractionReadService.GetFavoriteStoryIdsAsync(UserId, includePrivate: _isOwner),
        ProfileTab.Recommendations => RecommendationReadService.GetRecommendedStoryIdsByUserAsync(UserId),
        ProfileTab.Authored        => StoryReadService.GetStoryIdsByAuthorAsync(UserId),
        _                          => Task.FromResult<IReadOnlyList<int>>([])
    };

    // ── Story tab event handlers ──────────────────────────────────────────────────

    private async Task HandleStoryFilterChanged(StoryFilterDto filter)
    {
        _storyFilter = filter with { Page = 1 };
        await ReloadStoryListingsAsync();
    }

    private async Task HandleStoryPageChanged(int page)
    {
        _storyFilter = _storyFilter with { Page = page };
        await ReloadStoryListingsAsync();
    }

    // ── Blog tab event handlers ───────────────────────────────────────────────────

    private async Task HandleBlogPageChanged(int page)
    {
        _blogPage = page;
        BlogPosts = null; // force a plain fetch — persisted state never applies to page turns
        await LoadBlogAsync();
    }

    // ── Remove vouch (owner action — bubbled from VouchList) ──────────────────────

    private async Task HandleRemoveVouchAsync(int vouchedUserId)
    {
        await FollowingWriteService.RemoveVouchAsync(vouchedUserId);
        // Reload the banner's vouch list — refresh the header (plain assignment: this is a
        // post-write refresh, never a restore site).
        Header = await ProfileReadService.GetProfileHeaderAsync(UserId, includePrivate: _isOwner);
    }

    // ── Tag Selections tab — copy-on-write share (WU43) ───────────────────────────

    /// <summary>
    /// "Add to my filters" on a public selection card. Copy-on-write — the new row lands only in the
    /// copier's own SavedTagSelectionLoadFlyout, never on this profile page, so no local reload is
    /// needed. Feedback is a toast (transient system event, no inline home on this page) rather than
    /// InlineAlert/ConfirmDialog — see error-handling.md feedback-channel rules.
    /// </summary>
    private async Task HandleCopyTagSelectionAsync(int sourceId)
    {
        try
        {
            await TagSelectionWriteService.CopyPublicSelectionAsync(sourceId);
            Toasts.Show("Added to your saved tag selections.", ToastLevel.Success);
        }
        catch (Exception ex) when (ex is SavedTagSelectionValidationException or UnauthorizedAccessException or InvalidOperationException)
        {
            Toasts.Show(ExceptionPresenter.GetUserMessage(ex), ToastLevel.Danger);
        }
    }
}
