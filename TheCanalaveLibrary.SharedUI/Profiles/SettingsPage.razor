@page "/settings"
@namespace TheCanalaveLibrary.SharedUI
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@inject IUserSettingsService SettingsService
@inject IUserProfileReadService ProfileReadService
@inject IThemeReadService ThemeReadService
@inject IActiveUserContext ActiveUser
@inject IBadgeWriteService BadgeService
@inject IStoryReadService StoryReadService

@* Feature 20 (profile editing) + Feature 3 (theme-selection UI), WU30.
   Self-referential settings page — the active user edits only their own data.
   Loads once; each sub-form calls the appropriate IUserSettingsService write method on save.
   Sub-forms are parameter-driven (no @inject) so they remain bUnit-testable in isolation. *@

<PageTitle>Settings</PageTitle>

@if (_isLoading)
{
    <p class="text-(--color-text-muted)"><em>Loading settings…</em></p>
}
else if (_settings is null)
{
    <p class="text-(--color-danger)">Could not load your settings. Please try refreshing the page.</p>
}
else
{
    <div class="flex flex-col gap-8">
        <h1 class="inline-block self-start rounded-md border border-(--color-border) bg-(--color-surface-raised) px-4 py-1.5 font-display text-xl font-semibold text-(--color-text)">Settings</h1>

        @* Success / error banner *@
        @if (_successMessage is not null)
        {
            <div class="rounded-lg bg-(--color-success)/10 px-4 py-3 text-sm text-(--color-success)" role="status">
                @_successMessage
            </div>
        }
        @if (_errorMessage is not null)
        {
            <div class="rounded-lg bg-(--color-danger)/10 px-4 py-3 text-sm text-(--color-danger)" role="alert">
                @_errorMessage
            </div>
        }

        @* Profile sub-form *@
        <ProfileSettingsForm
            InitialTagline="@_settings.Tagline"
            InitialBioHtml="@_bioHtml"
            InitialPictureUrl="@_pictureUrl"
            Busy="@_profileBusy"
            UploadBusy="@_uploadBusy"
            OnSaveProfile="HandleSaveProfileAsync"
            OnPictureSelected="HandlePictureSelectedAsync" />

        @* Reader sub-form *@
        <ReaderSettingsForm
            Initial="@_settings.Reader"
            Busy="@_readerBusy"
            OnSave="HandleSaveReaderAsync" />

        @* Privacy sub-form *@
        <PrivacySettingsForm
            Initial="@_settings.Privacy"
            Busy="@_privacyBusy"
            OnSave="HandleSavePrivacyAsync" />

        @* Author sub-form (Pinned Story options = the caller's own published stories, WU40) *@
        <AuthorSettingsForm
            Initial="@_settings.Author"
            PinnableStories="@_pinnableStories"
            Busy="@_authorBusy"
            OnSave="HandleSaveAuthorAsync" />

        @* Appearance sub-form (Feature 3 — theme selection) *@
        <AppearanceSettingsForm
            Themes="@_themes"
            InitialThemeId="@_settings.ThemeId"
            InitialPrefersAnimated="@_settings.PrefersAnimatedSprites"
            InitialPrefersDataSaver="@_settings.PrefersDataSaverMode"
            Busy="@_appearanceBusy"
            OnSave="HandleSaveAppearanceAsync" />

        @* Badges sub-form (Feature 50 — badge curation, WU36) *@
        <BadgeSettingsForm
            EarnedBadges="@_earnedBadges"
            Busy="@_badgesBusy"
            OnSave="HandleSaveBadgesAsync" />
    </div>
}

@code {
    private UserSettingsDto? _settings;
    private string? _bioHtml;
    private string? _pictureUrl;
    private IReadOnlyList<ThemeDto> _themes = [];
    private IReadOnlyList<EarnedBadgeDto> _earnedBadges = [];
    private IReadOnlyList<StoryTitleSearchDto> _pinnableStories = [];
    private bool _isLoading = true;

    // Per-section busy flags so saving one section doesn't disable the others.
    private bool _profileBusy;
    private bool _uploadBusy;
    private bool _readerBusy;
    private bool _privacyBusy;
    private bool _authorBusy;
    private bool _appearanceBusy;
    private bool _badgesBusy;

    private string? _successMessage;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        _settings = await SettingsService.GetMySettingsAsync();
        _pictureUrl = _settings.ProfilePictureRelativeUrl;

        // Bio text, theme list, badge list, and pinnable stories can be loaded concurrently.
        if (ActiveUser.UserId is int userId)
        {
            Task<string?> bioTask        = ProfileReadService.GetProfileTextAsync(userId);
            Task<IReadOnlyList<ThemeDto>> themesTask = ThemeReadService.GetThemesAsync();
            Task<IReadOnlyList<EarnedBadgeDto>> badgesTask = BadgeService.GetMyBadgesForCurationAsync(userId);
            Task<IReadOnlyList<StoryTitleSearchDto>> pinnableTask = LoadPinnableStoriesAsync(userId);
            await Task.WhenAll(bioTask, themesTask, badgesTask, pinnableTask);
            _bioHtml         = bioTask.Result;
            _themes          = themesTask.Result;
            _earnedBadges    = badgesTask.Result;
            _pinnableStories = pinnableTask.Result;
        }
        else
        {
            _themes = await ThemeReadService.GetThemesAsync();
        }

        _isLoading = false;
    }

    /// <summary>
    /// The caller's own published, pinnable stories (WU40 Pinned Story dropdown): all their
    /// story ids, hydrated to listings, filtered to publicly-visible statuses (the same
    /// InProgress..OpenBeta window the write service enforces), sorted by title. The service
    /// gate remains authoritative — this is affordance-shaping only.
    /// </summary>
    private async Task<IReadOnlyList<StoryTitleSearchDto>> LoadPinnableStoriesAsync(int userId)
    {
        IReadOnlyList<int> ids = await StoryReadService.GetStoryIdsByAuthorAsync(userId);
        if (ids.Count == 0) return [];

        StoryListingDto[] listings = await StoryReadService.GetListingsByIdsAsync(ids);
        return [.. listings
            .Where(s => s.StoryStatusId is >= StoryStatusEnum.InProgress and <= StoryStatusEnum.OpenBeta)
            .OrderBy(s => s.Title, StringComparer.OrdinalIgnoreCase)
            .Select(s => new StoryTitleSearchDto(s.StoryId, s.Title, null))];
    }

    // ── Save handlers ────────────────────────────────────────────────────────────

    private async Task HandleSaveProfileAsync(UpdateProfileDto dto)
    {
        await RunWithFeedbackAsync(
            () => SettingsService.UpdateProfileAsync(dto),
            v => _profileBusy = v,
            "Profile saved.");
    }

    private async Task HandlePictureSelectedAsync(IBrowserFile file)
    {
        await RunWithFeedbackAsync(async () =>
        {
            const long maxFileSize = 5 * 1024 * 1024; // 5 MB
            await using Stream stream = file.OpenReadStream(maxAllowedSize: maxFileSize);
            _pictureUrl = await SettingsService.UploadProfilePictureAsync(stream, file.ContentType);
        },
        v => _uploadBusy = v,
        "Profile picture updated.");
    }

    private async Task HandleSaveReaderAsync(ReaderSettingsDto dto) =>
        await RunWithFeedbackAsync(
            () => SettingsService.UpdateReaderSettingsAsync(dto),
            v => _readerBusy = v,
            "Reader preferences saved.");

    private async Task HandleSavePrivacyAsync(PrivacySettingsDto dto) =>
        await RunWithFeedbackAsync(
            () => SettingsService.UpdatePrivacySettingsAsync(dto),
            v => _privacyBusy = v,
            "Privacy settings saved.");

    private async Task HandleSaveAuthorAsync(AuthorSettingsDto dto) =>
        await RunWithFeedbackAsync(
            () => SettingsService.UpdateAuthorSettingsAsync(dto),
            v => _authorBusy = v,
            "Author preferences saved.");

    private async Task HandleSaveAppearanceAsync(AppearanceSettingsForm.AppearanceArgs args) =>
        await RunWithFeedbackAsync(
            () => SettingsService.UpdateAppearanceAsync(args.ThemeId, args.PrefersAnimated, args.PrefersDataSaver),
            v => _appearanceBusy = v,
            "Appearance saved.");

    private async Task HandleSaveBadgesAsync(IReadOnlyList<string> orderedVisibleKeys)
    {
        if (ActiveUser.UserId is not int userId) return;
        await RunWithFeedbackAsync(
            () => BadgeService.SetDisplayOrderAsync(userId, orderedVisibleKeys),
            v => _badgesBusy = v,
            "Badge display saved.");
    }

    // ── Helpers ──────────────────────────────────────────────────────────────────

    /// <summary>
    /// Runs <paramref name="action"/>, manages the <paramref name="setBusy"/> flag, and sets
    /// the success or error banner. Uses an Action&lt;bool&gt; setter instead of a ref bool
    /// because async methods cannot have ref parameters.
    /// </summary>
    private async Task RunWithFeedbackAsync(
        Func<Task> action, Action<bool> setBusy, string successMsg)
    {
        _successMessage = null;
        _errorMessage   = null;
        setBusy(true);
        try
        {
            await action();
            _successMessage = successMsg;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Save failed: {ex.Message}";
        }
        finally
        {
            setBusy(false);
        }
    }
}
