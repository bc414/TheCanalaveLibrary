@namespace TheCanalaveLibrary.SharedUI

@* Appearance settings sub-form — Feature 3 (WU30). Theme selection + sprite/data-saver prefs.
   No @inject: themes and the current values are passed in by the page dispatcher (SettingsPage).
   Raises OnSave(AppearanceArgs) when the user clicks Save; the page calls
   IUserSettingsService.UpdateAppearanceAsync. *@

<section class="flex flex-col gap-4">
    <div>
        <h2 class="text-base font-semibold text-(--color-text)">Appearance</h2>
        <p class="text-sm text-(--color-text-muted)">Choose your site theme and sprite preferences.</p>
    </div>

    <div class="flex flex-col gap-4 rounded-xl border border-(--color-border) bg-(--color-surface-raised) p-4">
        @* Theme select *@
        <div class="flex flex-col gap-1">
            <label for="theme-select" class="text-sm font-medium text-(--color-text)">Theme</label>
            <select id="theme-select"
                    class="rounded-md border border-(--color-border) bg-(--color-surface) px-3 py-2 text-(--color-text) focus:outline-none focus:ring-2 focus:ring-(--color-action-ink)"
                    value="@_themeId"
                    @onchange="e => _themeId = int.Parse((string)(e.Value ?? _themeId.ToString()))">
                @foreach (var theme in Themes)
                {
                    <option value="@theme.ThemeId">@theme.Name</option>
                }
            </select>
        </div>

        @* Sprite pref *@
        <label class="flex cursor-pointer items-center gap-2 text-sm text-(--color-text)">
            <input type="checkbox"
                   class="h-4 w-4 rounded border-(--color-border) accent-(--color-action-ink)"
                   checked="@_prefersAnimated"
                   @onchange="e => _prefersAnimated = (bool)(e.Value ?? false)" />
            Prefer animated Pokémon sprites
        </label>

        @* Data saver *@
        <label class="flex cursor-pointer items-center gap-2 text-sm text-(--color-text)">
            <input type="checkbox"
                   class="h-4 w-4 rounded border-(--color-border) accent-(--color-action-ink)"
                   checked="@_prefersDataSaver"
                   @onchange="e => _prefersDataSaver = (bool)(e.Value ?? false)" />
            Enable data saver mode
            <span class="text-xs text-(--color-text-muted)">(reduces image quality)</span>
        </label>

        <button type="button"
                class="self-start rounded-md bg-(--color-action) px-4 py-2 text-sm font-medium text-(--color-text) transition-colors hover:bg-(--color-action-hover) disabled:opacity-50"
                disabled="@Busy"
                @onclick="HandleSave">
            @(Busy ? "Saving…" : "Save Appearance")
        </button>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ThemeDto> Themes { get; set; } = [];
    [Parameter] public int InitialThemeId { get; set; }
    [Parameter] public bool InitialPrefersAnimated { get; set; }
    [Parameter] public bool InitialPrefersDataSaver { get; set; }
    [Parameter] public bool Busy { get; set; }

    /// <summary>Raised with the selected appearance values when the user clicks Save.</summary>
    [Parameter] public EventCallback<AppearanceArgs> OnSave { get; set; }

    private int _themeId;
    private bool _prefersAnimated;
    private bool _prefersDataSaver;

    protected override void OnParametersSet()
    {
        // Seed local state from parameters when the page first delivers them.
        // Guard against re-initialising on every re-render (keep user's in-progress edits).
        if (_themeId == 0)
        {
            _themeId = InitialThemeId == 0 && Themes.Count > 0
                ? Themes[0].ThemeId
                : InitialThemeId;
            _prefersAnimated = InitialPrefersAnimated;
            _prefersDataSaver = InitialPrefersDataSaver;
        }
    }

    private async Task HandleSave() =>
        await OnSave.InvokeAsync(new AppearanceArgs(_themeId, _prefersAnimated, _prefersDataSaver));

    public record AppearanceArgs(int ThemeId, bool PrefersAnimated, bool PrefersDataSaver);
}
