@namespace TheCanalaveLibrary.SharedUI

@* Badge curation sub-form (Feature 50, WU36). Parameter-driven leaf — no @inject, bUnit-testable
   in isolation following the existing *SettingsForm pattern. Emits the ordered list of visible
   badge keys when the user saves; the dispatcher calls IBadgeWriteService.SetDisplayOrderAsync.
   Empty-state when no badges earned. Visible badges support move-up/move-down; hidden badges
   can be made visible (appended to the end of the visible list). *@

<section class="flex flex-col gap-4">
    <div>
        <h2 class="text-base font-semibold text-(--color-text)">Badges</h2>
        <p class="text-sm text-(--color-text-muted)">Choose which badges appear on your profile and in what order.</p>
    </div>

    @if (EarnedBadges.Count == 0)
    {
        <div class="rounded-xl border border-(--color-border) bg-(--color-surface-raised) p-4">
            <p class="text-sm text-(--color-text-muted)">You haven't earned any badges yet.</p>
        </div>
    }
    else
    {
        <div class="flex flex-col gap-4 rounded-xl border border-(--color-border) bg-(--color-surface-raised) p-4">

            @* ── Visible badges ──────────────────────────────────────────────── *@
            @if (_visibleKeys.Count > 0)
            {
                <div class="flex flex-col gap-1">
                    <p class="text-xs font-semibold uppercase tracking-wide text-(--color-text-muted)">Visible</p>
                    @for (int i = 0; i < _visibleKeys.Count; i++)
                    {
                        string key = _visibleKeys[i];
                        EarnedBadgeDto? b = _badgeMap.GetValueOrDefault(key);
                        if (b is null) continue;
                        int idx = i; // capture by value, not loop variable, to avoid lambda closure issue
                        <div class="flex items-center gap-3 rounded-md px-2 py-1.5">
                            @* Badge icons are provisioned out-of-band; hide on miss (L4.5 pass). *@
                            <img src="@b.IconUrl" alt="" title="@b.DisplayName" class="size-6 shrink-0" loading="lazy"
                                 onerror="this.style.display='none'" />
                            <div class="flex min-w-0 flex-1 flex-col">
                                <span class="text-sm font-medium text-(--color-text)">@b.DisplayName</span>
                                @if (b.Description is not null)
                                {
                                    <span class="text-xs text-(--color-text-muted)">@b.Description</span>
                                }
                            </div>
                            <div class="flex shrink-0 items-center gap-1">
                                <button type="button" title="Move up" disabled="@(idx == 0)"
                                        @onclick="() => MoveUp(idx)"
                                        class="rounded px-1.5 py-0.5 text-sm text-(--color-text-muted) hover:bg-(--color-surface-hover) hover:text-(--color-text) disabled:opacity-30">↑</button>
                                <button type="button" title="Move down" disabled="@(idx == _visibleKeys.Count - 1)"
                                        @onclick="() => MoveDown(idx)"
                                        class="rounded px-1.5 py-0.5 text-sm text-(--color-text-muted) hover:bg-(--color-surface-hover) hover:text-(--color-text) disabled:opacity-30">↓</button>
                                <button type="button" title="Hide this badge"
                                        @onclick="() => Hide(key)"
                                        class="rounded px-1.5 py-0.5 text-xs text-(--color-text-muted) hover:bg-(--color-surface-hover) hover:text-(--color-danger)">Hide</button>
                            </div>
                        </div>
                    }
                </div>
            }

            @* ── Hidden badges ───────────────────────────────────────────────── *@
            @{
                List<EarnedBadgeDto> hiddenBadges = EarnedBadges
                    .Where(b => !_visibleKeys.Contains(b.BadgeKey))
                    .ToList();
            }
            @if (hiddenBadges.Count > 0)
            {
                <div class="flex flex-col gap-1">
                    <p class="text-xs font-semibold uppercase tracking-wide text-(--color-text-muted)">Hidden</p>
                    @foreach (EarnedBadgeDto b in hiddenBadges)
                    {
                        string key = b.BadgeKey;
                        <div class="flex items-center gap-3 rounded-md px-2 py-1.5 opacity-50">
                            @* Badge icons are provisioned out-of-band; hide on miss (L4.5 pass). *@
                            <img src="@b.IconUrl" alt="" title="@b.DisplayName" class="size-6 shrink-0 grayscale" loading="lazy"
                                 onerror="this.style.display='none'" />
                            <div class="flex min-w-0 flex-1 flex-col">
                                <span class="text-sm font-medium text-(--color-text)">@b.DisplayName</span>
                                @if (b.Description is not null)
                                {
                                    <span class="text-xs text-(--color-text-muted)">@b.Description</span>
                                }
                            </div>
                            <button type="button" title="Make visible"
                                    @onclick="() => Show(key)"
                                    class="shrink-0 rounded px-1.5 py-0.5 text-xs text-(--color-text-muted) opacity-100 hover:bg-(--color-surface-hover) hover:text-(--color-primary)">Show</button>
                        </div>
                    }
                </div>
            }

            <button type="button"
                    class="self-start rounded-md bg-(--color-primary) px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-(--color-primary-strong) disabled:opacity-50"
                    disabled="@Busy"
                    @onclick="HandleSave">
                @(Busy ? "Saving…" : "Save Badge Display")
            </button>
        </div>
    }
</section>

@code {
    /// <summary>All earned badges (visible and hidden). Seeded once from the dispatcher.</summary>
    [Parameter, EditorRequired] public IReadOnlyList<EarnedBadgeDto> EarnedBadges { get; set; } = null!;

    [Parameter] public bool Busy { get; set; }

    /// <summary>Raised with the ordered list of visible badge keys when the user clicks Save.</summary>
    [Parameter] public EventCallback<IReadOnlyList<string>> OnSave { get; set; }

    // Ordered list of badge keys the user has toggled visible (reflects desired DisplayOrder 1..n).
    private List<string> _visibleKeys = [];
    // Fast lookup: BadgeKey → EarnedBadgeDto for rendering visible-section rows.
    private Dictionary<string, EarnedBadgeDto> _badgeMap = [];
    private bool _seeded;

    protected override void OnParametersSet()
    {
        if (!_seeded)
        {
            _badgeMap   = EarnedBadges.ToDictionary(b => b.BadgeKey);
            _visibleKeys = EarnedBadges
                .Where(b => b.DisplayOrder > 0)
                .OrderBy(b => b.DisplayOrder)
                .Select(b => b.BadgeKey)
                .ToList();
            _seeded = true;
        }
    }

    private void MoveUp(int idx)
    {
        if (idx <= 0) return;
        (_visibleKeys[idx], _visibleKeys[idx - 1]) = (_visibleKeys[idx - 1], _visibleKeys[idx]);
    }

    private void MoveDown(int idx)
    {
        if (idx >= _visibleKeys.Count - 1) return;
        (_visibleKeys[idx], _visibleKeys[idx + 1]) = (_visibleKeys[idx + 1], _visibleKeys[idx]);
    }

    private void Hide(string key) => _visibleKeys.Remove(key);

    private void Show(string key)
    {
        if (!_visibleKeys.Contains(key))
            _visibleKeys.Add(key);
    }

    private async Task HandleSave() =>
        await OnSave.InvokeAsync(new List<string>(_visibleKeys));
}
