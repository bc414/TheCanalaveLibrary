@namespace TheCanalaveLibrary.SharedUI
@inherits LayoutComponentBase

@* Persistent desktop chrome — single full-width sticky top bar (no sidebar).
   Spec: cross-cutting.md "Device Detection & Layout Architecture" — "Desktop top bar (logo,
   nav links, notification bell, profile)." Mobile bottom bar lives in MobileLayout.razor;
   the two are intentionally separate compositions (layer3.5-structure.md). *@

<div class="flex min-h-screen flex-col">
    <header class="sticky top-0 z-(--z-sticky) flex items-center gap-6 border-b border-(--color-border) bg-(--color-surface-raised) px-6 py-3 shadow-subtle">
        <a href="/" class="font-display text-xl text-(--color-action-ink)">Canalave Library</a>

        <nav class="flex items-center gap-4 text-sm">
            <NavLink href="" Match="NavLinkMatch.All"
                     class="text-(--color-text) transition-colors hover:text-(--color-action-ink)"
                     ActiveClass="font-semibold text-(--color-action-ink)">
                Home
            </NavLink>
            <NavLink href="discover"
                     class="text-(--color-text) transition-colors hover:text-(--color-action-ink)"
                     ActiveClass="font-semibold text-(--color-action-ink)">
                Discover
            </NavLink>
            <NavLink href="tags"
                     class="text-(--color-text) transition-colors hover:text-(--color-action-ink)"
                     ActiveClass="font-semibold text-(--color-action-ink)">
                Tags
            </NavLink>
            <NavLink href="groups"
                     class="text-(--color-text) transition-colors hover:text-(--color-action-ink)"
                     ActiveClass="font-semibold text-(--color-action-ink)">
                Groups
            </NavLink>
        </nav>

        <div class="ml-auto flex items-center gap-3">
            @* Chrome island — a faulted bell/menu degrades to a one-liner; nav + page survive
               (cross-cutting.md §"Error Handling Strategy" placement map). *@
            <CanalaveErrorBoundary Label="chrome" Compact="true">
                <CreateMenu />
                <MessagesNavLink />
                <NotificationBell />
                <UserMenu />
            </CanalaveErrorBoundary>
        </div>
    </header>

    <main class="flex-1">
        <div class="px-4 pt-4">
            <CanalaveErrorBoundary Label="chrome" Compact="true">
                <AccountStatusBanner />
            </CanalaveErrorBoundary>
        </div>
        <article class="px-4 py-4">
            @* Page island — an unhandled page exception degrades this article, not the circuit;
               auto-recovers on navigation. *@
            <CanalaveErrorBoundary Label="page">
                @Body
            </CanalaveErrorBoundary>
        </article>
    </main>

    <ToastHost />
</div>