@namespace TheCanalaveLibrary.SharedUI
@implements IDisposable
@inject NavigationManager Nav

<AuthorizeView>
    <Authorized>
        <span>@context.User.Identity?.Name</span>
        <form action="Account/Logout" method="post">
            <AntiforgeryToken />
            <input type="hidden" name="ReturnUrl" value="@CurrentUrl" />
            <button type="submit">Log out</button>
        </form>
    </Authorized>
    <NotAuthorized>
        @* ReturnUrl round-trip (WU-AccessGate Phase 1): header sign-ins come back to the page
           the reader was on, same as the SignInRequired experience. *@
        <a href="@($"Account/Login?ReturnUrl={Uri.EscapeDataString("/" + CurrentUrl)}")">Log in</a>
    </NotAuthorized>
</AuthorizeView>

@code {
    // Computed at render time + LocationChanged re-render (MA-003): persistent layout chrome
    // initializes once per circuit, and unlike UserMenu this form is always rendered — without the
    // subscription its ReturnUrl would freeze on whatever page the circuit started on.
    private string CurrentUrl => Nav.ToBaseRelativePath(Nav.Uri);

    protected override void OnInitialized() => Nav.LocationChanged += OnLocationChanged;

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e) =>
        _ = InvokeAsync(StateHasChanged);

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
