@namespace TheCanalaveLibrary.SharedUI
@using Microsoft.Extensions.Hosting
@inject IHostEnvironment HostEnv

@* Plain anchors to the Development-only GET /dev/wu12/login-as/{username} endpoint (which signs
   in and redirects to "/"). Deliberately no JS interop and no @onclick: the previous
   fetch-POST-then-forceLoad pattern silently dropped the POST on an established interactive
   circuit, so switching users while already logged in never worked (browser pass 2026-07-01).
   A full-page anchor navigation is immune to circuit/render-mode state. *@

@if (HostEnv.IsDevelopment())
{
    <div class="flex items-center gap-3 px-3 py-1.5 bg-yellow-50 border-b border-yellow-300 text-sm">
        <span class="text-yellow-700 font-semibold">Dev</span>
        <a class="text-blue-600 hover:underline" href="/dev/wu12/login-as/TestUser">TestUser</a>
        <a class="text-blue-600 hover:underline" href="/dev/wu12/login-as/AdminUser">AdminUser</a>
    </div>
}
