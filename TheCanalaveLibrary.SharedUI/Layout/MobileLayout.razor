@namespace TheCanalaveLibrary.SharedUI
@inherits LayoutComponentBase

<div class="flex min-h-screen flex-col">
    <main class="flex-1">
        <article class="px-4 py-4">
            @* Page island — mirrors DesktopLayout (cross-cutting.md §"Error Handling Strategy"). *@
            <CanalaveErrorBoundary Label="page">
                @Body
            </CanalaveErrorBoundary>
        </article>
    </main>

    <div class="flex items-center justify-between gap-4 px-4 py-3">
        <!-- MOBILE BOTTOM BAR CONTENT / NAV MENU -->
        <span>Home</span> | <span>Search</span> | <span>Profile</span>
        <div class="flex items-center gap-3">
            <CanalaveErrorBoundary Label="chrome" Compact="true">
                <MessagesNavLink />
                <NotificationBell />
                <LoginDisplay />
            </CanalaveErrorBoundary>
        </div>
    </div>

    <ToastHost />
</div>