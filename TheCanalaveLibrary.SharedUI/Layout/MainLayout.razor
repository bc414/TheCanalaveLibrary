@namespace TheCanalaveLibrary.SharedUI
@inherits LayoutComponentBase

@* The single persistent layout — one responsive tree for every viewport (WU-ResponsiveMerge,
   render-and-layout.md §"Responsive Layout Architecture"). Sticky top bar; wraps at narrow
   widths via flex-wrap. A bottom nav bar is the canonical rung-3 cascade trigger and is
   deliberately NOT built — that's a future mobile-phase decision. *@

<div class="flex min-h-screen flex-col">
    <a href="#main-content"
       class="sr-only focus:not-sr-only focus:absolute focus:left-2 focus:top-2 focus:z-(--z-sticky) focus:rounded-md focus:bg-(--color-surface-raised) focus:px-3 focus:py-2 focus:text-sm focus:shadow-medium">
        Skip to content
    </a>

    <header class="sticky top-0 z-(--z-sticky) flex flex-wrap items-center gap-x-4 gap-y-2 border-b border-(--color-border) bg-(--color-surface-raised) px-3 py-3 shadow-subtle md:gap-6 md:px-6">
        <a href="/" class="font-display text-xl text-(--color-action-ink)">Canalave Library</a>

        <nav class="flex items-center gap-3 text-sm md:gap-4">
            <NavLink href="" Match="NavLinkMatch.All"
                     class="text-(--color-text) transition-colors hover:text-(--color-action-ink)"
                     ActiveClass="font-semibold text-(--color-action-ink)">
                Home
            </NavLink>
            <NavLink href="discover"
                     class="text-(--color-text) transition-colors hover:text-(--color-action-ink)"
                     ActiveClass="font-semibold text-(--color-action-ink)">
                Discover
            </NavLink>
            <NavLink href="tags"
                     class="text-(--color-text) transition-colors hover:text-(--color-action-ink)"
                     ActiveClass="font-semibold text-(--color-action-ink)">
                Tags
            </NavLink>
            <NavLink href="groups"
                     class="text-(--color-text) transition-colors hover:text-(--color-action-ink)"
                     ActiveClass="font-semibold text-(--color-action-ink)">
                Groups
            </NavLink>
        </nav>

        <div class="ml-auto flex items-center gap-3">
            @* Chrome island — a faulted bell/menu degrades to a one-liner; nav + page survive
               (cross-cutting.md §"Error Handling Strategy" placement map). *@
            <CanalaveErrorBoundary Label="chrome" Compact="true">
                <CreateMenu />
                <MessagesNavLink />
                <NotificationBell />
                <UserMenu />
            </CanalaveErrorBoundary>
        </div>
    </header>

    <main id="main-content" class="flex-1">
        <div class="px-4 pt-4">
            <CanalaveErrorBoundary Label="chrome" Compact="true">
                <AccountStatusBanner />
            </CanalaveErrorBoundary>
        </div>
        <article class="px-4 py-4">
            @* Page island — an unhandled page exception degrades this article, not the circuit;
               auto-recovers on navigation. *@
            <CanalaveErrorBoundary Label="page">
                @Body
            </CanalaveErrorBoundary>
        </article>
    </main>

    <ToastHost />
</div>
