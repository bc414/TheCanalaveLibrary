@namespace TheCanalaveLibrary.SharedUI
@inject ISpriteReadService SpriteService

<h1>Hello, Desktop User!</h1>
<p>This is the dedicated desktop view of the home page.</p>

@* You can add complex, desktop-only components and logic here *@

@* --- TagChip (WU4) test harness — throwaway demo, remove once a real consumer (WU11/WU13) lands ---
   No producing read service exists yet (lands in WU11/WU12-13), so this page stands in for one:
   it injects ISpriteReadService directly and resolves the demo SpriteUrl itself. Real TagChipDto
   producers resolve SpriteUrl server-side, in their read-service projection — never in the Razor
   tree (layer2-services.md "Sprite URLs Are Resolved Server-Side, At Projection Time"). *@
<div class="flex flex-wrap gap-2">
    @foreach (var tag in _demoTags)
    {
        @if (tag.TagId <= 2)
        {
            <TagChip Tag="tag" OnRemove="() => RemoveTag(tag)" />
        }
        else
        {
            <TagChip Tag="tag" />
        }
    }
</div>

@code {
    private List<TagChipDto> _demoTags = new();

    protected override void OnInitialized()
    {
        _demoTags = new List<TagChipDto>
        {
            new() { TagId = 1, TagName = "Bulbasaur", TagTypeId = TagTypeEnum.Character, Description = "A Grass/Poison-type Pokémon.", SpriteUrl = SpriteService.GetSpriteUrl("pokemon", "bulbasaur", false) },
            new() { TagId = 2, TagName = "Canalave City", TagTypeId = TagTypeEnum.Setting, Description = "A port town in Sinnoh." },
            new() { TagId = 3, TagName = "Adventure", TagTypeId = TagTypeEnum.Genre, Description = "Stories about journeys and discovery." },
            new() { TagId = 4, TagName = "Violence", TagTypeId = TagTypeEnum.ContentWarning, Description = "Depicts violent content." },
            new() { TagId = 5, TagName = "Pokémon Mystery Dungeon", TagTypeId = TagTypeEnum.CrossoverFandom, Description = "Crossover with the PMD series." },
            new() { TagId = 6, TagName = "Ash/Misty", TagTypeId = TagTypeEnum.Relationship, Description = "Romantic pairing." },
        };
    }

    private void RemoveTag(TagChipDto tag) => _demoTags.Remove(tag);
}
