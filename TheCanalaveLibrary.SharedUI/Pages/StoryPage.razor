@page "/story/{StoryId:int}/{Slug?}"
@using TheCanalaveLibrary.Core.ServiceInterfaces
@using TheCanalaveLibrary.Core.DTOs
@using TheCanalaveLibrary.SharedUI.Pages.Desktop
@using TheCanalaveLibrary.SharedUI.Pages.Mobile

@inject IDeviceDetectionService DeviceService
@inject IStoryOverviewService StoryOverviewService
@inject NavigationManager NavigationManager

@if (_isLoading)
{
    <PageTitle>Loading...</PageTitle>
    <p><em>Loading story...</em></p>
}
else if (_story is not null)
{
    <PageTitle>@_story.StoryTitle</PageTitle>

    @if (DeviceService.IsMobile())
    {
        <StoryMobile Story="_story" />
    }
    else
    {
        <StoryDesktop Story="_story" />
    }
}
else
{
    <PageTitle>Story Not Found</PageTitle>
    <p>Sorry, we couldn't find the story you were looking for.</p>
}

@code {
    [Parameter]
    public int StoryId { get; set; }

    [Parameter]
    public string? Slug { get; set; }

    private StoryDetailsDTO? _story;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        _story = await StoryOverviewService.GetStoryByIdAsync(StoryId);
        _isLoading = false;
    }
}