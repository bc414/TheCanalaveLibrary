@page "/series/{SeriesId:int}/{*Slug}"
@namespace TheCanalaveLibrary.SharedUI
@inject ISeriesReadService SeriesService
@inject IStoryReadService StoryService
@inject IUserStoryInteractionReadService InteractionService
@inject IPublicUrlProvider PublicUrlProvider
@using TheCanalaveLibrary.Core
@using Microsoft.AspNetCore.Components.Authorization

@* Series detail page — public, read-only (WU41, Feature 9). Slug is cosmetic — only SeriesId (int)
   is the key. Single layout (no Desktop/Mobile split, unlike GroupPage) — StoryDeck is already
   responsive on its own and this page has no complex multi-column chrome to branch on, same
   single-layout shape as BlogPostPage/GroupsPage.
   [SeriesDetailDto.OrderedStoryIds] is the raw membership set; hydrated here via
   IStoryReadService.GetListingsByIdsAsync, which reorders to match and silently drops ids the
   viewer can't see (content-rating/takedown filters) — see audit/Stories.md Feature 9 WU41 note.
   Author-only Edit link — the server gate in ServerSeriesWriteService is the real authority. *@

@if (_isLoading)
{
    <PageTitle>Loading…</PageTitle>
    <p class="mx-auto max-w-4xl px-4 py-8 text-(--color-text-muted)"><em>Loading…</em></p>
}
else if (Series is null)
{
    <PageTitle>Series not found</PageTitle>
    <p class="mx-auto max-w-4xl px-4 py-8 text-(--color-danger)">Series not found.</p>
}
else
{
    StoryListingDto[] stories = Stories ?? [];

    <PageTitle>@Series.Name</PageTitle>
    <SocialMetaTags Title="@Series.Name" Description="@OgDescription" ImageUrl="@OgImageUrl" Url="@OgUrl" OgType="website"/>

    <div class="mx-auto max-w-4xl px-4 py-8 flex flex-col gap-6">

        @* ── Header ───────────────────────────────────────────────────────────── *@
        <div class="flex items-start justify-between gap-4">
            <div class="flex flex-col gap-1">
                <h1 class="text-3xl font-bold text-(--color-text) leading-snug">@Series.Name</h1>
                <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-(--color-text-muted)">
                    @if (Series.AuthorId is not null)
                    {
                        <span>By
                            <a href="/user/@Series.AuthorId"
                               class="text-(--color-action-ink) hover:underline font-medium">@(Series.AuthorName ?? "Unknown")</a>
                        </span>
                    }
                    else
                    {
                        <span>By @(Series.AuthorName ?? "Unknown")</span>
                    }
                    <span>·</span>
                    <span>@stories.Length @(stories.Length == 1 ? "story" : "stories")</span>
                    <span>·</span>
                    <span>Started @Series.DateCreated.ToString("MMM d, yyyy")</span>
                </div>
            </div>
            @if (_isOwner)
            {
                <a href="/series/@Series.SeriesId/edit"
                   class="shrink-0 text-sm text-(--color-action-ink) hover:underline">Edit Series</a>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(Series.Description))
        {
            <ContentSurface Variant="ContentSurfaceVariant.Inline">
                <RichTextView HtmlContent="@Series.Description" />
            </ContentSurface>
        }

        @* ── Member stories, in reading order ────────────────────────────────── *@
        <StoryDeck Stories="stories"
                   UserStoryInteractionStates="_interactionStates"
                   CurrentUserId="_currentUserId"
                   EmptyMessage="No stories in this series yet." />
    </div>
}

@code {
    [Parameter] public int SeriesId { get; set; }

    /// <summary>Cosmetic catch-all segment — ignored on load; only SeriesId is the key.</summary>
    [Parameter] public string? Slug { get; set; }

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    // Persisted across the prerender→interactive handoff ([PersistentState]) — the primary fetched
    // content this page renders. ??= restore-or-fetch on the initial load; the OnParametersSetAsync
    // dispatcher reload plain-assigns so a new SeriesId never short-circuits on stale persisted state.
    [PersistentState] public SeriesDetailDto? Series { get; set; }
    [PersistentState] public StoryListingDto[]? Stories { get; set; }

    // Per-viewer supplementary state — deliberately NOT persisted (same judgment as StoryPage's
    // _usiState): deterministic per viewer and reloads without flicker, so it refetches every pass.
    private IReadOnlyDictionary<int, UserStoryInteractionStateDto>? _interactionStates;

    private bool _isLoading = true;
    private int? _currentUserId;
    private bool _isOwner;

    private bool _initialized;
    private int _loadedSeriesId = int.MinValue; // sentinel; no real SeriesId equals this

    // Open Graph/Twitter meta (WU-Seo). No cover field on SeriesDetailDto — falls back to the
    // site-default image (see audit/Seo.md "Open" re: SVG re-use).
    private string? OgDescription => Series is null ? null : SocialDescriptionHelper.Clean(Series.Description);
    private string OgImageUrl => PublicUrlProvider.AbsoluteImageUrl(null, "/img/default-cover.svg");
    private string OgUrl => PublicUrlProvider.AbsolutePageUrl(Series is null
        ? $"/series/{SeriesId}"
        : $"/series/{Series.SeriesId}");

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            AuthenticationState state = await AuthState;
            string? idStr = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            _currentUserId = int.TryParse(idStr, out int id) ? id : null;
        }

        // ??= guard: skip the fetch when [PersistentState] restored the prerender payload
        // (the "no flicker" invariant — layer3-logic.md §"State Persistence").
        _loadedSeriesId = SeriesId;
        Series ??= await SeriesService.GetSeriesByIdAsync(SeriesId);

        if (Series is not null)
        {
            Stories ??= Series.OrderedStoryIds.Count > 0
                ? await StoryService.GetListingsByIdsAsync(Series.OrderedStoryIds)
                : [];
            await LoadViewerStateAsync();
        }

        _isLoading = false;
        _initialized = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        // Fires when the same SeriesPage instance is reused for a different SeriesId.
        if (!_initialized) return;
        if (SeriesId == _loadedSeriesId) return;

        _isLoading = true;
        _loadedSeriesId = SeriesId;

        // Plain assignment (not ??=) — the [PersistentState] values from the previous series must
        // not short-circuit the reload for a new SeriesId (layer3-logic.md §"Route-Parameter Dispatchers").
        Series = await SeriesService.GetSeriesByIdAsync(SeriesId);

        if (Series is not null)
        {
            Stories = Series.OrderedStoryIds.Count > 0
                ? await StoryService.GetListingsByIdsAsync(Series.OrderedStoryIds)
                : [];
            await LoadViewerStateAsync();
        }
        else
        {
            Stories = [];
            _isOwner = false;
            _interactionStates = null;
        }

        _isLoading = false;
    }

    /// <summary>Per-viewer state derived from the loaded series — runs on every pass (ephemeral).</summary>
    private async Task LoadViewerStateAsync()
    {
        _isOwner = _currentUserId.HasValue && Series!.AuthorId == _currentUserId;

        _interactionStates = Stories is { Length: > 0 } && _currentUserId is not null
            ? await InteractionService.GetStatesByStoryIdsAsync([.. Stories.Select(s => s.StoryId)])
            : null;
    }
}
