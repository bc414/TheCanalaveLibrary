@page "/series"
@namespace TheCanalaveLibrary.SharedUI
@attribute [Authorize]
@inject ISeriesReadService SeriesService
@using TheCanalaveLibrary.Core
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@* "My Series" — the owner-only listing of the current user's series (WU41 settled decision: no
   global /series directory, this is scoped to the signed-in author). Entry point from UserMenu
   ("My Series"). Each SeriesCard gets an EditHref here (owner context) — the profile Series tab
   reuses the same SeriesCard without one (public, view-only). *@

<PageTitle>My Series</PageTitle>

<div class="mx-auto max-w-4xl px-4 py-8 flex flex-col gap-6">

    @* ── Page header ─────────────────────────────────────────────────────────── *@
    <div class="flex items-center justify-between">
        <h1 class="inline-block rounded-md border border-(--color-border) bg-(--color-surface-raised) px-4 py-1.5 font-display text-xl font-semibold text-(--color-text)">My Series</h1>
        <a href="/series/new"
           class="rounded-md bg-(--color-mission) px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-(--color-mission-hover)">
            + New Series
        </a>
    </div>

    @* ── Listing ──────────────────────────────────────────────────────────────── *@
    @if (_isLoading)
    {
        <p class="text-(--color-text-muted)"><em>Loading series…</em></p>
    }
    else if (_series.Count == 0)
    {
        <p class="text-(--color-text-muted)">You haven't created any series yet.</p>
    }
    else
    {
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            @foreach (SeriesListingDto series in _series)
            {
                <SeriesCard Series="series" EditHref="@($"/series/{series.SeriesId}/edit")" />
            }
        </div>
    }

</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private IReadOnlyList<SeriesListingDto> _series = [];
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        int? currentUserId = null;
        if (AuthState is not null)
        {
            AuthenticationState state = await AuthState;
            string? idStr = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            currentUserId = int.TryParse(idStr, out int id) ? id : null;
        }

        if (currentUserId is not null)
            _series = await SeriesService.GetSeriesByAuthorAsync(currentUserId.Value);

        _isLoading = false;
    }
}
