info: Microsoft.EntityFrameworkCore.Database.Command[20101]&#xD;
      Executed DbCommand (1ms) [Parameters=[@ef_filter__p='?' (DbType = Int16), @ratingCeiling='?' (DbType = Int16), @storyId='?' (DbType = Int32)], CommandType='Text', CommandTimeout='30']&#xD;
      SELECT c1.chapter_number, c1.chapter_content_id, c1.sort_order, c1.version_name, c1.rating, c1.word_count&#xD;
      FROM chapters AS c&#xD;
      INNER JOIN (&#xD;
          SELECT s.story_id, s.rating&#xD;
          FROM stories AS s&#xD;
          WHERE s.rating &lt;= @ef_filter__p&#xD;
      ) AS s0 ON c.story_id = s0.story_id&#xD;
      JOIN LATERAL (&#xD;
          SELECT c.chapter_number, c0.chapter_content_id, c0.sort_order, c0.version_name, c0.rating, c0.word_count&#xD;
          FROM chapter_contents AS c0&#xD;
          WHERE c.chapter_id = c0.chapter_id AND (c0.chapter_content_id &lt;&gt; c.primary_content_id OR c.primary_content_id IS NULL) AND COALESCE(c0.rating, s0.rating) &lt;= @ratingCeiling&#xD;
      ) AS c1 ON TRUE&#xD;
      WHERE c.story_id = @storyId&#xD;
