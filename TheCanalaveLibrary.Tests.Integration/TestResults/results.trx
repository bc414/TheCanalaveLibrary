      SELECT c.chapter_number, c.title, CASE&#xD;
          WHEN c0.chapter_content_id IS NOT NULL THEN c0.word_count&#xD;
          ELSE 0&#xD;
      END, c.is_published&#xD;
      FROM chapters AS c&#xD;
