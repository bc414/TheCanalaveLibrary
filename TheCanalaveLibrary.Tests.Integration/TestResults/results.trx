      SELECT c.chapter_id, c0.story_id, c0.chapter_number, c0.title, c.chapter_text, c.top_authors_note, c.bottom_authors_note, c.word_count, COALESCE(c.rating, s0.rating), c.author_id, CASE&#xD;
