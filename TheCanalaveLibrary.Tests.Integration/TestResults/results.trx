      SELECT s.comment_id, s.active_report_count, s.blog_post_comment_comment_id, s.chapter_comment_comment_id, s.comment_text, s.group_comment_comment_id, s.like_count, s.parent_comment_id, s.user_id, s.user_profile_comment_comment_id, s.blog_post_id, s.date_posted, s.chapter_id, s.date_posted0, s.is_spoiler, s.date_posted1, s.group_id, s.date_posted2, s.profile_user_id, s."Discriminator", c1.comment_id, c1.user_id&#xD;
      FROM (&#xD;
          SELECT b.comment_id, b.active_report_count, b.blog_post_comment_comment_id, b.chapter_comment_comment_id, b.comment_text, b.group_comment_comment_id, b.like_count, b.parent_comment_id, b.user_id, b.user_profile_comment_comment_id, b0.blog_post_id, b0.date_posted, c.chapter_id, c.date_posted AS date_posted0, c.is_spoiler, g.date_posted AS date_posted1, g.group_id, u.date_posted AS date_posted2, u.profile_user_id, CASE&#xD;
              WHEN u.comment_id IS NOT NULL THEN 'UserProfileComment'&#xD;
              WHEN g.comment_id IS NOT NULL THEN 'GroupComment'&#xD;
              WHEN c.comment_id IS NOT NULL THEN 'ChapterComment'&#xD;
              WHEN b0.comment_id IS NOT NULL THEN 'BlogPostComment'&#xD;
          END AS "Discriminator"&#xD;
          FROM base_comments AS b&#xD;
          LEFT JOIN blog_post_comments AS b0 ON b.comment_id = b0.comment_id&#xD;
          LEFT JOIN chapter_comments AS c ON b.comment_id = c.comment_id&#xD;
          LEFT JOIN group_comments AS g ON b.comment_id = g.comment_id&#xD;
          LEFT JOIN user_profile_comments AS u ON b.comment_id = u.comment_id&#xD;
          WHERE b.comment_id = @commentId&#xD;
          LIMIT 1&#xD;
      ) AS s&#xD;
      LEFT JOIN (&#xD;
          SELECT c0.comment_id, c0.user_id&#xD;
          FROM comment_likes AS c0&#xD;
          WHERE c0.user_id = @userId&#xD;
      ) AS c1 ON s.comment_id = c1.comment_id&#xD;
      ORDER BY s.comment_id, c1.comment_id&#xD;
