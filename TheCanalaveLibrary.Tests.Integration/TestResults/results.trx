      FROM (&#xD;
          SELECT s.story_id, CASE&#xD;
              WHEN s0.story_id IS NOT NULL THEN s0.story_title&#xD;
              ELSE ''&#xD;
          END AS c, CASE&#xD;
              WHEN s0.story_id IS NOT NULL THEN COALESCE(s0.short_description, '')&#xD;
              ELSE ''&#xD;
