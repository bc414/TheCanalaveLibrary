@namespace TheCanalaveLibrary.Server
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/"/>
    <ResourcePreloader/>
    <link rel="stylesheet" href="@Assets["app.css"]"/>
    @* Scoped-CSS bundle is named after the ASSEMBLY (TheCanalaveLibrary.Server), not the solution.
       The old "TheCanalaveLibrary.styles.css" href 404'd silently, killing every *.razor.css rule —
       most visibly MainLayout.razor.css's #blazor-error-ui display:none, which left the "unhandled
       error" banner permanently visible on Identity pages (browser pass 2026-07-01). *@
    <link rel="stylesheet" href="@Assets["TheCanalaveLibrary.Server.styles.css"]"/>
    <!-- Quill.js (via Blazored.TextEditor, SharedUI/RichText/EditorView) — CDN per the package's own
         setup instructions; it ships no bundled Quill copy of its own. Test against Tailwind's
         Preflight resets early (layer4-style.md "Quill.js Stylesheet Interaction").
         SRI required on every CDN asset (security.md); recompute the hash on any version bump. -->
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet"
          integrity="sha384-ecIckRi4QlKYya/FQUbBUjS4qp65jF/J87Guw5uzTbO1C1Jfa/6kYmd6dXUF6D7i"
          crossorigin="anonymous"/>
    <!-- Blazored.Typeahead (SharedUI/Tags/TagSelector) — package-provided positioning skeleton,
         see layer4-style.md "Blazored.Typeahead Stylesheet". No DI registration exists for this
         package (confirmed: no AddBlazoredTypeahead extension in the assembly). -->
    <link href="_content/Blazored.Typeahead/blazored-typeahead.css" rel="stylesheet"/>
    @* The nonce authorizes ImportMap's inline <script type="importmap"> under CSP — minted per
       request by SecurityHeadersMiddleware, which lists the same value in script-src. *@
    <ImportMap nonce="@CspNonce"/>
    <HeadOutlet @rendermode="PageRenderMode"/>
</head>

<body>
<Routes @rendermode="PageRenderMode"/>
<ReconnectModal/>

@* Last-resort circuit-teardown bar (cross-cutting.md §"Error Handling Strategy"). Lives HERE,
   not in a layout: the default layout is DeviceLayout, so a MainLayout-hosted bar (the template
   default) existed only on Identity Manage pages — interactive pages had NO teardown surface at
   all. blazor.web.js toggles it via inline style.display, which overrides the `hidden` class;
   the .reload/.dismiss classes are its required hooks. Faults the error boundaries catch never
   reach this; only a true circuit teardown shows it. *@
<div id="blazor-error-ui" data-nosnippet
     class="hidden fixed bottom-0 left-0 right-0 z-(--z-error) border-t border-(--color-danger)/40 bg-(--color-surface-raised) px-4 py-3 text-sm text-(--color-text) shadow-prominent">
    <span class="font-semibold text-(--color-danger)">Something went wrong with your connection.</span>
    Your last edits may not have been saved.
    <a href="." class="reload font-semibold text-(--color-action-ink) underline hover:no-underline">Reload the page</a>
    <span class="dismiss float-right cursor-pointer px-2 font-semibold" role="button" aria-label="Dismiss">✕</span>
</div>

<script src="@Assets["_framework/blazor.web.js"]"></script>

<!-- Reference the device detection script from the SharedUI class library -->
<script src="_content/TheCanalaveLibrary.SharedUI/js/device.js"></script>
<!-- Reading-progress scroll tracker (ChapterReadingPage, WU26) -->
<script src="_content/TheCanalaveLibrary.SharedUI/js/reading-progress.js"></script>
<!-- Story view-ping trigger: first scroll or 5s dwell, never page load (StoryPage, Feature 45) -->
<script src="_content/TheCanalaveLibrary.SharedUI/js/view-ping.js"></script>
<!-- Sprite onerror fallback chain: animated webp → static png → unknown.png (TagChip, CharacterEntry) -->
<script src="_content/TheCanalaveLibrary.SharedUI/js/sprite-fallback.js"></script>
<!-- Delegated data-* image fallbacks — the CSP-safe replacement for inline onerror attributes
     (security.md "no new raw inline on* attributes"). Must load after sprite-fallback.js. -->
<script src="_content/TheCanalaveLibrary.SharedUI/js/img-fallback.js"></script>
<!-- Editor draft autosave to localStorage (DraftAutosave, SharedUI/Drafts/ — WU-ErrorHandling) -->
<script src="_content/TheCanalaveLibrary.SharedUI/js/draft-autosave.js"></script>

<!-- Uniform Overlay dismissal: outside-click + Escape for flyouts and details dropdowns (Phase C) -->
<script src="_content/TheCanalaveLibrary.SharedUI/js/dismiss.js"></script>

<!-- Quill.js + Blazored.TextEditor's interop (EditorView, SharedUI/RichText/).
     SRI required on every CDN asset (security.md); recompute the hash on any version bump. -->
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"
        integrity="sha384-utBUCeG4SYaCm4m7GQZYr8Hy8Fpy3V4KGjBZaf4WTKOcwhCYpt/0PfeEe3HNlwx8"
        crossorigin="anonymous"></script>
<script src="_content/Blazored.TextEditor/quill-blot-formatter.min.js"></script>
<script src="_content/Blazored.TextEditor/Blazored-BlazorQuill.js"></script>

<!-- Blazored.Typeahead's JS interop (TagSelector, SharedUI/Tags/) -->
<script src="_content/Blazored.Typeahead/blazored-typeahead.js"></script>

<script src="@Assets["Identity/Shared/PasskeySubmit.razor.js"]" type="module"></script>
</body>

</html>

@code {
    // Identity/Pages/_Imports.razor marks Identity pages [ExcludeFromInteractiveRouting] (they need a
    // real per-request HttpContext for SignInManager/cookie auth). AcceptsInteractiveRouting() reads
    // that metadata so those pages stay static SSR while the rest of the app is InteractiveServer.
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    // Per-request CSP nonce minted by SecurityHeadersMiddleware — see <ImportMap> above.
    private string? CspNonce => HttpContext.Items[SecurityHeadersMiddleware.NonceItemKey] as string;

    // The site converts to global InteractiveAuto in a single flip (layer5-wasm.md §"The Global
    // Flip") — this expression is where that flip lands. If a page must run as a WASM island
    // before then (debug bisect during the flip wave), the pilot-verified recipe is
    // [ExcludeFromInteractiveRouting] + @rendermode on the page; the same check below covers it.
    private IComponentRenderMode? PageRenderMode
        => HttpContext.AcceptsInteractiveRouting() ? InteractiveServer : null;
}