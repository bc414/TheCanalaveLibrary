@namespace TheCanalaveLibrary.Server
@using Microsoft.AspNetCore.Components.Authorization
@using TheCanalaveLibrary.Core

@* Root provider nested inside <CascadingAuthenticationState> in Routes.razor.
   Reads the two sprite scalars off the cascaded ClaimsPrincipal — claims are present in both the
   SSR prerender pass and the InteractiveServer pass, so the resolved ThemeContext (and therefore
   every downstream <img src>) is byte-identical across the handoff → no flicker.
   See cross-cutting.md "ThemeContext Cascading Provider." *@

<CascadingValue Value="@_context">
    @ChildContent
</CascadingValue>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private ThemeContext _context = ThemeContext.Default;

    protected override async Task OnInitializedAsync()
    {
        AuthenticationState auth = await AuthState;
        System.Security.Claims.ClaimsPrincipal user = auth.User;

        string slug = user.FindFirst(ActiveUserClaimTypes.Theme)?.Value ?? ThemeContext.Default.Slug;
        bool animated = !bool.TryParse(user.FindFirst(ActiveUserClaimTypes.PrefersAnimatedSprites)?.Value, out bool val) || val;

        _context = new ThemeContext(slug, animated);
    }
}
