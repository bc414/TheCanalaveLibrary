@page "/Error"
@namespace TheCanalaveLibrary.Server
@using System.Diagnostics

@* The user-facing server-fault page (UseExceptionHandler target, non-dev only). Rewritten from the
   template scaffold (MA-110, 2026-07-18) to match NotFound.razor's role treatment: Wayfinding
   plaque + Container vessel, a way back, and the request id so a user report can be correlated
   with the server-side Error log line (error-handling.md: unexpected → generic-with-trace-id). *@

<PageTitle>Something went wrong</PageTitle>

<div class="mx-auto flex max-w-md flex-col gap-4 py-12">
    <h1 class="inline-block self-start rounded-md border border-(--color-border) bg-(--color-surface-raised) px-4 py-1.5 font-display text-xl font-semibold text-(--color-text)">
        Something went wrong
    </h1>
    <div class="flex flex-col gap-3 rounded-xl border border-(--color-border) bg-(--color-surface) p-6">
        <p class="text-sm text-(--color-text)">
            The library hit an unexpected error while handling your request. It wasn't anything you
            did — trying again usually works.
        </p>
        @if (ShowRequestId)
        {
            <p class="text-xs text-(--color-text-muted)">
                If this keeps happening, mention this request ID when reporting it:
                <code class="rounded bg-(--color-surface-raised) px-1 py-0.5">@RequestId</code>
            </p>
        }
        <div class="flex gap-3 text-sm">
            <a href="/" class="text-(--color-action-ink) hover:underline">Go home</a>
            <a href="/discover" class="text-(--color-action-ink) hover:underline">Discover stories</a>
        </div>
    </div>
</div>

@code{
    [CascadingParameter] private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;

}
