@namespace TheCanalaveLibrary.Server
@* WU-SiteDailyStat (Feature 62): stamps User.LastActiveUtc for authenticated users only, on
   circuit start and on every subsequent internal navigation. This is a go-forward, approximate
   "was the user doing something recently" signal — not a login/session/tracking mechanism — and
   is the honest limitation documented in layer8-data-marts.md §"site_daily_stats": a user who
   never navigates away from one page for the whole visit is stamped only once. Renders nothing;
   mounted once in Routes.razor so every route gets the same coverage. *@
@using TheCanalaveLibrary.Core
@implements IDisposable
@inject NavigationManager Navigation
@inject IActiveUserContext ActiveUser
@inject IUserActivityWriteService UserActivityWriteService

@code {
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        RecordIfAuthenticated();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => RecordIfAuthenticated();

    private void RecordIfAuthenticated()
    {
        if (ActiveUser.IsAuthenticated && ActiveUser.UserId is int userId)
        {
            // Buffered — fire-and-forget is safe: RecordActivityAsync only merges into an
            // in-process ConcurrentDictionary (see UserActivityBuffer), never awaits I/O.
            _ = UserActivityWriteService.RecordActivityAsync(userId);
        }
    }

    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;
}
