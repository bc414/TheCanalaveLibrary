@namespace TheCanalaveLibrary.Server
@using TheCanalaveLibrary.SharedUI
@using TheCanalaveLibrary.Client
@using Microsoft.AspNetCore.Components.Authorization

<Router AppAssembly="typeof(Program).Assembly"
        AdditionalAssemblies="new[] { typeof(WasmClientAssemblyIdentifier).Assembly, typeof(SharedUIAssemblyIdentifier).Assembly }"
        NotFoundPage="typeof(NotFound)">
    <Found Context="routeData">
        <CascadingAuthenticationState>
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(DeviceLayout)" />
        </CascadingAuthenticationState>
        <FocusOnNavigate RouteData="routeData" Selector="h1"/>
    </Found>
</Router>