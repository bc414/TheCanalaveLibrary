@namespace TheCanalaveLibrary.Server
@if (!string.IsNullOrEmpty(DisplayMessage))
{
    var statusMessageClass = DisplayMessage.StartsWith("Error")
        ? "rounded-md border border-(--color-danger)/40 bg-(--color-danger)/10 px-4 py-2 text-sm text-(--color-danger)"
        : "rounded-md border border-(--color-success)/40 bg-(--color-success)/10 px-4 py-2 text-sm text-(--color-success)";
    <div class="@statusMessageClass" role="alert">
        @DisplayMessage
    </div>
}

@code {
    private string? messageFromCookie;

    [Parameter] public string? Message { get; set; }

    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    private string? DisplayMessage => Message ?? messageFromCookie;

    protected override void OnInitialized()
    {
        messageFromCookie = HttpContext.Request.Cookies[IdentityRedirectManager.StatusCookieName];

        if (messageFromCookie is not null)
        {
            HttpContext.Response.Cookies.Delete(IdentityRedirectManager.StatusCookieName);
        }
    }

}