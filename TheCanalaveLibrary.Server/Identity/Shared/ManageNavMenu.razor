@namespace TheCanalaveLibrary.Server
@using Microsoft.AspNetCore.Identity

@inject SignInManager<User> SignInManager

<ul class="flex flex-col gap-1 rounded-xl border border-(--color-border) bg-(--color-surface) p-2">
    <li>
        <NavLink class="block rounded-md px-3 py-1.5 text-sm text-(--color-text) transition-colors hover:bg-(--color-surface-hover)" ActiveClass="bg-(--color-action-ink)/10 font-semibold text-(--color-action-ink)" href="Account/Manage" Match="NavLinkMatch.All">Profile</NavLink>
    </li>
    <li>
        <NavLink class="block rounded-md px-3 py-1.5 text-sm text-(--color-text) transition-colors hover:bg-(--color-surface-hover)" ActiveClass="bg-(--color-action-ink)/10 font-semibold text-(--color-action-ink)" href="Account/Manage/Email">Email</NavLink>
    </li>
    <li>
        <NavLink class="block rounded-md px-3 py-1.5 text-sm text-(--color-text) transition-colors hover:bg-(--color-surface-hover)" ActiveClass="bg-(--color-action-ink)/10 font-semibold text-(--color-action-ink)" href="Account/Manage/ChangePassword">Password</NavLink>
    </li>
    @if (hasExternalLogins)
    {
        <li>
            <NavLink class="block rounded-md px-3 py-1.5 text-sm text-(--color-text) transition-colors hover:bg-(--color-surface-hover)" ActiveClass="bg-(--color-action-ink)/10 font-semibold text-(--color-action-ink)" href="Account/Manage/ExternalLogins">External logins</NavLink>
        </li>
    }
    <li>
        <NavLink class="block rounded-md px-3 py-1.5 text-sm text-(--color-text) transition-colors hover:bg-(--color-surface-hover)" ActiveClass="bg-(--color-action-ink)/10 font-semibold text-(--color-action-ink)" href="Account/Manage/TwoFactorAuthentication">Two-factor authentication</NavLink>
    </li>
    <li>
        <NavLink class="block rounded-md px-3 py-1.5 text-sm text-(--color-text) transition-colors hover:bg-(--color-surface-hover)" ActiveClass="bg-(--color-action-ink)/10 font-semibold text-(--color-action-ink)" href="Account/Manage/Passkeys">Passkeys</NavLink>
    </li>
    <li>
        <NavLink class="block rounded-md px-3 py-1.5 text-sm text-(--color-text) transition-colors hover:bg-(--color-surface-hover)" ActiveClass="bg-(--color-action-ink)/10 font-semibold text-(--color-action-ink)" href="Account/Manage/PersonalData">Personal data</NavLink>
    </li>
</ul>

@code {
    private bool hasExternalLogins;

    protected override async Task OnInitializedAsync()
    {
        hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    }

}