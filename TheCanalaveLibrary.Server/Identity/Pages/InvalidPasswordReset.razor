@page "/Account/InvalidPasswordReset"
@namespace TheCanalaveLibrary.Server

<PageTitle>Invalid password reset</PageTitle>

<div class="mx-auto flex w-full max-w-md flex-col gap-4 py-8">
    <h1 class="inline-block self-start rounded-md border border-(--color-border) bg-(--color-surface-raised) px-4 py-1.5 font-display text-xl font-semibold text-(--color-text)">Invalid password reset</h1>
    <p role="alert" class="rounded-md border border-(--color-danger)/40 bg-(--color-danger)/10 px-4 py-2 text-sm text-(--color-danger)">
        The password reset link is invalid.
    </p>
</div>