@page "/Account/ForgotPasswordConfirmation"
@namespace TheCanalaveLibrary.Server

<PageTitle>Forgot password confirmation</PageTitle>

<div class="mx-auto flex w-full max-w-md flex-col gap-4 py-8">
    <h1 class="inline-block self-start rounded-md border border-(--color-border) bg-(--color-surface-raised) px-4 py-1.5 font-display text-xl font-semibold text-(--color-text)">Forgot password confirmation</h1>
    <p role="alert" class="rounded-md border border-(--color-border) bg-(--color-surface-raised) px-4 py-2 text-sm text-(--color-text)">
        Please check your email to reset your password.
    </p>
</div>