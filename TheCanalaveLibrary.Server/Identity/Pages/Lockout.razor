@page "/Account/Lockout"
@namespace TheCanalaveLibrary.Server

<PageTitle>Locked out</PageTitle>

<header class="mx-auto flex w-full max-w-md flex-col gap-4 py-8">
    <h1 class="inline-block self-start rounded-md border border-(--color-border) bg-(--color-surface-raised) px-4 py-1.5 font-display text-xl font-semibold text-danger">Locked out</h1>
    <p class="rounded-md border border-(--color-danger)/40 bg-(--color-danger)/10 px-4 py-2 text-sm text-(--color-danger)" role="alert">This account has been locked out, please try again later.</p>
</header>