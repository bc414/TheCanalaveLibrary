@page "/Account/ResetPasswordConfirmation"
@namespace TheCanalaveLibrary.Server
<PageTitle>Reset password confirmation</PageTitle>

<div class="mx-auto flex w-full max-w-md flex-col gap-4 py-8">
    <h1 class="inline-block self-start rounded-md border border-(--color-border) bg-(--color-surface-raised) px-4 py-1.5 font-display text-xl font-semibold text-(--color-text)">Reset password confirmation</h1>
    <p role="alert" class="rounded-md border border-(--color-border) bg-(--color-surface-raised) px-4 py-2 text-sm text-(--color-text)">
        Your password has been reset. Please <a href="Account/Login" class="text-(--color-action-ink) hover:underline">click here to log in</a>.
    </p>
</div>